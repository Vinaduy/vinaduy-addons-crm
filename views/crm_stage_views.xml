<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add SLA column to stage tree view (CHỈ ADMIN/Settings group) -->
    <record id="crm_stage_view_tree_inherit_vinaduy" model="ir.ui.view">
        <field name="name">crm.stage.tree.inherit.vinaduy</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_tree"/>
        <field name="arch" type="xml">
            <field name="sequence" position="after">
                <field name="sla_days" groups="base.group_system"/>
            </field>
        </field>
    </record>

    <!-- Add SLA field to stage form view (CHỈ ADMIN/Settings group) -->
    <record id="crm_stage_view_form_inherit_vinaduy" model="ir.ui.view">
        <field name="name">crm.stage.form.inherit.vinaduy</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_form"/>
        <field name="arch" type="xml">
            <field name="is_won" position="after">
                <field name="sla_days" groups="base.group_system"/>
            </field>
        </field>
    </record>

</odoo>
