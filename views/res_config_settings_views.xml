<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_inherit_vinaduy" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.vinaduy</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="crm.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='generate_lead_setting_container']" position="after">
                <block title="VINADUY CRM" id="vinaduy_crm_settings">
                    <setting id="vinaduy_auto_assign"
                             string="Tự động phân bổ lead cho nhân viên"
                             help="Round-robin global cho 18 NV trong 4 team HCM1/HCM2/HCM3/HN. Lead mới chưa có user_id sẽ được tự động gán theo vòng tròn.">
                        <field name="vinaduy_auto_assign_enabled"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
