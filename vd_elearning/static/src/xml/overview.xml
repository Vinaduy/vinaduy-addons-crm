<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- ============ POPUP NHAP TEN ============ -->
    <t t-name="vd_elearning.InputDialog">
        <Dialog title="props.title" size="'md'">
            <div class="o_vd_dlg">
                <label class="o_vd_dlg_label" t-esc="props.label"/>
                <input type="text" class="o_vd_dlg_input" t-model="state.name"
                       t-att-placeholder="props.placeholder || ''" autofocus="autofocus"
                       t-on-keydown="(ev) => ev.key === 'Enter' ? this.confirm() : null"/>
                <t t-if="props.withPath">
                    <label class="o_vd_dlg_label mt-3">Chọn lộ trình <span class="o_vd_dlg_req">*</span></label>
                    <select class="o_vd_dlg_input" t-model="state.pathId">
                        <option value="">-- Bắt buộc chọn lộ trình --</option>
                        <t t-foreach="props.paths" t-as="p" t-key="p.id">
                            <option t-att-value="p.id" t-esc="p.name"/>
                        </t>
                    </select>
                </t>
            </div>
            <t t-set-slot="footer">
                <button class="btn o_vd_dlg_ok" t-att-disabled="!canConfirm" t-on-click="confirm"><t t-esc="props.confirmLabel || 'Lưu'"/></button>
                <button class="btn btn-secondary" t-on-click="() => this.props.close()">Hủy</button>
            </t>
        </Dialog>
    </t>

    <!-- ============ POPUP GAN NHAN VIEN ============ -->
    <t t-name="vd_elearning.AssignDialog">
        <Dialog title="props.title" size="'md'">
            <div class="o_vd_assign">
                <input type="text" class="o_vd_assign_search" t-model="state.search"
                       placeholder="Tìm nhân viên..." autofocus="autofocus"/>
                <div class="o_vd_assign_count">Đã chọn <t t-esc="selCount"/>/<t t-esc="props.candidates.length"/> nhân viên</div>
                <div class="o_vd_assign_list">
                    <t t-foreach="filtered" t-as="c" t-key="c.id">
                        <label class="o_vd_assign_row">
                            <input type="checkbox" t-att-checked="state.sel[c.id]" t-on-change="() => this.toggle(c.id)"/>
                            <img t-attf-src="/web/image/res.users/{{c.id}}/avatar_128" t-att-alt="c.name"/>
                            <span class="o_vd_assign_main">
                                <span class="o_vd_assign_name" t-esc="c.name"/>
                                <span class="o_vd_assign_sub"><span class="o_vd_assign_team" t-esc="c.team"/> · <t t-esc="c.role"/></span>
                            </span>
                        </label>
                    </t>
                    <div t-if="!filtered.length" class="o_vd_assign_empty">Không tìm thấy nhân viên.</div>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn o_vd_dlg_ok" t-on-click="confirm">Lưu gán nhân viên</button>
                <button class="btn btn-secondary" t-on-click="() => this.props.close()">Hủy</button>
            </t>
        </Dialog>
    </t>

    <!-- ============ POPUP FULL MAN HINH: KHOA HOC (noi dung + bai thi) ============ -->
    <t t-name="vd_elearning.CourseDialog">
        <Dialog title="props.title" size="'fs'" fullscreen="true">
            <div class="o_vd_ce">
                <!-- TAB -->
                <div class="o_vd_ce_tabs">
                    <button t-if="showContentTab" t-attf-class="o_vd_ce_tab {{state.tab=='content' ? 'active' : ''}}"
                        t-on-click="() => this.setTab('content')"><i class="fa fa-book me-2"/>Nội dung</button>
                    <button t-attf-class="o_vd_ce_tab {{state.tab=='exam' ? 'active' : ''}}"
                        t-on-click="() => this.setTab('exam')"><i class="fa fa-question-circle me-2"/>Bài thi (<t t-esc="state.questions.length"/> câu)</button>
                    <span t-if="!props.editable &amp;&amp; state.examStarted &amp;&amp; !state.examResult" class="o_vd_ce_examflag"><i class="fa fa-lock me-1"/>Đang thi - nội dung đã ẩn</span>
                </div>

                <div class="o_vd_ce_body">
                    <!-- ============ TAB NOI DUNG ============ -->
                    <t t-if="state.tab=='content'">
                        <div class="o_vd_ce_list">
                            <t t-if="props.editable">
                                <div class="o_vd_ce_toolbar">
                                    <button class="o_vd_ce_add" t-on-click="addContent"><i class="fa fa-plus me-1"/>Thêm nội dung</button>
                                    <button t-attf-class="o_vd_ce_toggle {{state.editMode ? 'active' : ''}}" t-on-click="toggleEdit">
                                        <i t-attf-class="fa {{state.editMode ? 'fa-eye' : 'fa-pencil'}} me-1"/><t t-esc="state.editMode ? 'Xem trước' : 'Sửa HTML'"/>
                                    </button>
                                </div>
                                <!-- XEM TRUOC (render dep) -->
                                <t t-if="!state.editMode">
                                    <t t-foreach="state.contents" t-as="c" t-key="c._k">
                                        <article class="o_vd_ce_read">
                                            <h3 t-esc="c.name"/>
                                            <div class="o_vd_ce_read_body" t-out="bodyHtml(c.body)"/>
                                        </article>
                                    </t>
                                </t>
                                <!-- SUA HTML -->
                                <t t-else="">
                                    <t t-foreach="state.contents" t-as="c" t-key="c._k">
                                        <div class="o_vd_ce_item">
                                            <div class="o_vd_ce_item_top">
                                                <input class="o_vd_ce_title" t-model="c.name" placeholder="Tiêu đề nội dung"/>
                                                <button class="o_vd_ce_del" t-on-click="() => this.delContent(c)"><i class="fa fa-trash"/></button>
                                            </div>
                                            <textarea class="o_vd_ce_body_txt" t-model="c.body" placeholder="Nội dung chi tiết (có thể dùng HTML)..."/>
                                        </div>
                                    </t>
                                </t>
                            </t>
                            <t t-else="">
                                <t t-foreach="state.contents" t-as="c" t-key="c._k">
                                    <article class="o_vd_ce_read">
                                        <h3 t-esc="c.name"/>
                                        <div class="o_vd_ce_read_body" t-out="bodyHtml(c.body)"/>
                                    </article>
                                </t>
                                <div t-if="state.questions.length" class="o_vd_ce_gotoexam">
                                    <button class="o_vd_ce_start" t-on-click="startExam">
                                        <i class="fa fa-graduation-cap me-2"/>Vào thi (<t t-esc="state.questions.length"/> câu) <i class="fa fa-arrow-right ms-2"/>
                                    </button>
                                    <span class="o_vd_ce_hint">Khi vào thi, toàn bộ nội dung sẽ được ẩn đi.</span>
                                </div>
                            </t>
                            <div t-if="!state.contents.length" class="o_vd_ce_empty">Chưa có nội dung.</div>
                        </div>
                    </t>

                    <!-- ============ TAB BAI THI ============ -->
                    <t t-else="">
                        <!-- ADMIN: soan cau hoi -->
                        <t t-if="props.editable">
                            <div class="o_vd_ce_list">
                                <button class="o_vd_ce_add o_vd_ce_add_block" t-on-click="addQuestion"><i class="fa fa-plus me-1"/>Thêm câu hỏi</button>
                                <t t-foreach="state.questions" t-as="q" t-key="q._k">
                                    <div class="o_vd_ce_q">
                                        <div class="o_vd_ce_item_top">
                                            <span class="o_vd_ce_qnum"><t t-esc="q_index + 1"/></span>
                                            <input class="o_vd_ce_title" t-model="q.text" placeholder="Nội dung câu hỏi"/>
                                            <button class="o_vd_ce_del" t-on-click="() => this.delQuestion(q)"><i class="fa fa-trash"/></button>
                                        </div>
                                        <t t-foreach="q.answers" t-as="a" t-key="a._k">
                                            <label class="o_vd_ce_ans">
                                                <input type="checkbox" t-att-checked="a.is_correct" t-on-change="() => this.toggleCorrect(a)"/>
                                                <input class="o_vd_ce_ans_txt" t-model="a.text" placeholder="Đáp án"/>
                                                <button class="o_vd_ce_del" t-on-click="() => this.delAnswer(q, a)"><i class="fa fa-times"/></button>
                                            </label>
                                        </t>
                                        <button class="o_vd_ce_addans" t-on-click="() => this.addAnswer(q)"><i class="fa fa-plus me-1"/>Thêm đáp án</button>
                                        <div class="o_vd_ce_hint">Tick ô vuông = đáp án đúng. Cần ít nhất 1 đúng và 1 sai.</div>
                                    </div>
                                </t>
                                <div t-if="!state.questions.length" class="o_vd_ce_empty">Chưa có câu hỏi.</div>
                            </div>
                        </t>

                        <!-- HOC VIEN: lam bai thi -->
                        <t t-else="">
                            <div t-if="state.examResult" t-attf-class="o_vd_ce_score {{state.examResult.percent &gt;= 80 ? 'pass' : 'fail'}}">
                                <div class="o_vd_ce_score_big"><t t-esc="state.examResult.score"/>/<t t-esc="state.examResult.total"/></div>
                                <div class="o_vd_ce_score_sub">
                                    Đúng <t t-esc="state.examResult.percent"/>%
                                    <t t-if="state.examResult.percent &gt;= 80"> - Đạt!</t>
                                    <t t-else=""> - Chưa đạt (cần từ 80%). Xem lại đáp án đúng bên dưới rồi thi lại.</t>
                                </div>
                            </div>
                            <div t-if="!state.examStarted" class="o_vd_ce_empty">Bấm "Vào thi" ở tab Nội dung để bắt đầu.</div>
                            <div t-else="" class="o_vd_ce_list">
                                <t t-foreach="state.questions" t-as="q" t-key="q._k">
                                    <div class="o_vd_ce_q o_vd_ce_q_take">
                                        <div class="o_vd_ce_qhead">
                                            <span class="o_vd_ce_qnum"><t t-esc="q_index + 1"/></span>
                                            <span class="o_vd_ce_qtext" t-esc="q.text"/>
                                            <i t-if="state.examResult &amp;&amp; state.examResult.map[q.id]" class="fa fa-check o_vd_ce_ok"/>
                                            <i t-if="state.examResult &amp;&amp; !state.examResult.map[q.id]" class="fa fa-times o_vd_ce_no"/>
                                        </div>
                                        <t t-foreach="q.answers" t-as="a" t-key="a._k">
                                            <label t-attf-class="o_vd_ce_take_ans {{a.chosen ? 'chosen' : ''}} {{state.examResult &amp;&amp; isAnswerCorrect(q,a) ? 'correct' : ''}} {{state.examResult &amp;&amp; a.chosen &amp;&amp; !isAnswerCorrect(q,a) ? 'wrong' : ''}}"
                                                t-on-click="() => this.chooseAnswer(q, a)">
                                                <span class="o_vd_ce_take_box"><i t-if="a.chosen" class="fa fa-check"/></span>
                                                <span class="o_vd_ce_take_txt" t-esc="a.text"/>
                                                <i t-if="state.examResult &amp;&amp; isAnswerCorrect(q,a)" class="fa fa-check-circle o_vd_ce_ok ms-auto"/>
                                            </label>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </t>
                </div>
            </div>

            <t t-set-slot="footer">
                <!-- ADMIN -->
                <t t-if="props.editable">
                    <button class="btn o_vd_dlg_ok" t-att-disabled="state.saving" t-on-click="save">
                        <t t-esc="state.saving ? 'Đang lưu...' : 'Lưu khóa học'"/>
                    </button>
                </t>
                <!-- HOC VIEN dang thi -->
                <t t-elif="state.tab=='exam' &amp;&amp; state.examStarted &amp;&amp; !state.examResult">
                    <button class="btn o_vd_dlg_ok" t-att-disabled="state.saving" t-on-click="submitExam">
                        <t t-esc="state.saving ? 'Đang chấm...' : 'Nộp bài'"/>
                    </button>
                </t>
                <!-- HOC VIEN da co ket qua -->
                <t t-elif="state.examResult">
                    <button class="btn o_vd_dlg_ok" t-on-click="retryExam"><i class="fa fa-redo me-1"/>Thi lại</button>
                    <button class="btn btn-light" t-on-click="reviewContent"><i class="fa fa-book me-1"/>Xem lại nội dung</button>
                </t>
                <button class="btn btn-secondary" t-on-click="() => this.props.close()">Đóng</button>
            </t>
        </Dialog>
    </t>

    <!-- ============ TRACK: 1 hang khoa hoc ============ -->
    <t t-name="vd_elearning.Track">
        <div class="o_vd_track"
             t-on-dragover="(ev) => dropCtx ? this.onDragOver(ev) : null"
             t-on-drop="(ev) => dropCtx ? this.onTrackDrop(ev, dropCtx.zoneKey, dropCtx.pathId) : null">
            <t t-foreach="nodes" t-as="node" t-key="node.course.id">
                <div class="o_vd_step">
                    <div t-attf-class="o_vd_level o_vd_level_{{node.kind}}"
                         t-att-draggable="(draggable &amp;&amp; dropCtx) ? 'true' : 'false'"
                         t-on-dragstart="(ev) => dropCtx ? this.onDragStart(ev, node.course, dropCtx.zoneKey, dropCtx.pathId) : null"
                         t-on-dragend="(ev) => this.onDragEnd(ev)"
                         t-on-dragover="(ev) => dropCtx ? this.onDragOver(ev) : null"
                         t-on-drop="(ev) => dropCtx ? this.onDrop(ev, node.course, dropCtx.zoneKey, dropCtx.pathId) : null"
                         t-on-click="() => this.openCourse(node.course)">
                        <div t-if="node.riders.length" class="o_vd_riders">
                            <div t-if="node.moreRiders" class="o_vd_rider_more">+<t t-esc="node.moreRiders"/> người</div>
                            <t t-foreach="node.riders" t-as="rider" t-key="rider.id">
                                <div class="o_vd_rider_card">
                                    <img class="o_vd_rider_ava"
                                         t-attf-src="/web/image/res.users/{{rider.id}}/avatar_128" t-att-alt="rider.name"/>
                                    <span class="o_vd_rider_name" t-esc="rider.name"/>
                                </div>
                            </t>
                        </div>
                        <i t-if="node.kind == 'boss'" class="fa fa-trophy o_vd_emblem o_vd_emblem_boss"/>
                        <div class="o_vd_level_tile">
                            <img t-if="node.course.has_image" class="o_vd_level_logo"
                                 t-attf-src="/web/image/slide.channel/{{node.course.id}}/image_128"/>
                            <i t-else="" class="fa fa-graduation-cap o_vd_level_ico"/>
                            <span class="o_vd_level_num" t-esc="node.n"/>
                        </div>
                        <div class="o_vd_level_name" t-esc="node.course.name"/>
                    </div>
                    <div t-if="!node_last" class="o_vd_arrow"/>
                </div>
            </t>
            <div t-if="!nodes.length" class="o_vd_track_empty">Kéo khóa học vào đây</div>
        </div>
    </t>

    <!-- ============ PANEL 1 TAB DAO TAO ============ -->
    <t t-name="vd_elearning.ZonePanel">
        <div class="o_vd_panel">
            <div class="o_vd_maptools">
                <span class="o_vd_tool_count"><i class="fa fa-graduation-cap me-1"/><t t-esc="zone.courses.length"/> khóa học</span>
                <span t-if="state.isAdmin" class="o_vd_tool_hint"><i class="fa fa-arrows me-1"/>Kéo-thả khóa học (đổi thứ tự hoặc sang lộ trình khác)</span>
            </div>

            <div class="o_vd_board">
                <t t-set="entryId" t-value="zoneEntryId(zone)"/>
                <t t-foreach="zone.paths" t-as="path" t-key="path.id">
                    <div class="o_vd_path_row">
                        <div class="o_vd_path_marker">
                            <div class="o_vd_path_badge"><i class="fa fa-flag-checkered"/></div>
                            <div class="o_vd_path_label">
                                <span class="o_vd_path_kicker">LỘ TRÌNH</span>
                                <span class="o_vd_path_name" t-esc="path.name"/>
                                <span class="o_vd_path_sub"><t t-esc="path.courses.length"/> khóa học</span>
                            </div>
                            <div class="o_vd_path_tools">
                                <button t-if="state.isAdmin" class="o_vd_path_btn" title="Đổi tên lộ trình"
                                    t-on-click="() => this.renamePath(path)"><i class="fa fa-pencil"/></button>
                                <div class="o_vd_path_emp">
                                    <button class="o_vd_path_btn" t-att-title="state.isAdmin ? 'Gán nhân viên vào lộ trình' : 'Nhân viên đang học'"
                                        t-on-click="() => state.isAdmin ? this.openAssign(path) : null"><i class="fa fa-user-plus"/></button>
                                    <div class="o_vd_learners">
                                        <div class="o_vd_learners_head">NHÂN VIÊN ĐANG HỌC · <t t-esc="path.name"/></div>
                                        <table class="o_vd_learners_tbl">
                                            <thead><tr><th>Nhân viên</th><th>Đang học</th><th>Bắt đầu</th><th>Kết thúc</th></tr></thead>
                                            <tbody>
                                                <t t-foreach="pathLearners(path, zone)" t-as="lr" t-key="lr.id">
                                                    <tr>
                                                        <td class="o_vd_lr_nv">
                                                            <img t-attf-src="/web/image/res.users/{{lr.id}}/avatar_128"/>
                                                            <span t-esc="lr.name"/>
                                                        </td>
                                                        <td t-esc="lr.current"/>
                                                        <td t-esc="lr.start"/>
                                                        <td t-esc="lr.end"/>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                        <div t-if="!pathLearners(path, zone).length" class="o_vd_learners_empty">Chưa có nhân viên đang học.</div>
                                    </div>
                                </div>
                            </div>
                            <div t-if="!path_last" class="o_vd_path_link"/>
                        </div>
                        <div t-if="path.courses.length" class="o_vd_arrow o_vd_arrow_lead"/>
                        <t t-call="vd_elearning.Track">
                            <t t-set="nodes" t-value="trackNodes(path.courses, zone.employees, entryId)"/>
                            <t t-set="dropCtx" t-value="state.isAdmin ? {zoneKey: zone.key, pathId: path.id} : false"/>
                            <t t-set="draggable" t-value="state.isAdmin"/>
                        </t>
                    </div>
                </t>
                <div t-if="!zone.paths.length" class="o_vd_emp_empty">Chưa có lộ trình nào.</div>
            </div>

            <div t-if="state.isAdmin" class="o_vd_fab">
                <div class="o_vd_fab_menu">
                    <button class="o_vd_fab_item" t-on-click="() => this.openAddCourse(zone)">
                        <i class="fa fa-graduation-cap me-2"/>THÊM KHÓA HỌC
                    </button>
                    <button class="o_vd_fab_item" t-on-click="() => this.openAddPath(zone.key)">
                        <i class="fa fa-sitemap me-2"/>THÊM LỘ TRÌNH
                    </button>
                </div>
                <button class="o_vd_fab_btn" aria-label="Thêm"><i class="fa fa-plus"/></button>
            </div>
        </div>
    </t>

    <!-- ============ TRANG TONG QUAN ============ -->
    <t t-name="vd_elearning.Overview">
        <div class="o_vd_overview">
            <div t-if="state.loading" class="o_vd_loading">
                <i class="fa fa-spinner fa-spin"/> Đang tải...
            </div>

            <!-- GIAO DIEN NHAN VIEN -->
            <t t-elif="state.selectedEmp">
                <div class="o_vd_card">
                    <header class="o_vd_student_head">
                        <button t-if="!state.selectedEmp.locked" class="o_vd_back" t-on-click="backToAdmin">
                            <i class="fa fa-arrow-left me-1"/> Quay lại
                        </button>
                        <img class="o_vd_student_ava"
                            t-attf-src="/web/image/res.users/{{state.selectedEmp.id}}/avatar_128"/>
                        <div class="o_vd_student_title">
                            <span class="o_vd_student_label">HÀNH TRÌNH CHINH PHỤC CỦA</span>
                            <h2 t-esc="state.selectedEmp.name"/>
                        </div>
                        <span class="o_vd_student_count">
                            <t t-esc="studentCourseCount"/> khóa học
                        </span>
                    </header>
                    <div class="o_vd_board">
                        <t t-foreach="state.selectedEmp.paths" t-as="path" t-key="path.id">
                            <div class="o_vd_path_row">
                                <div class="o_vd_path_marker">
                                    <div class="o_vd_path_badge"><i class="fa fa-flag-checkered"/></div>
                                    <div class="o_vd_path_label">
                                        <span class="o_vd_path_kicker">LỘ TRÌNH</span>
                                        <span class="o_vd_path_name" t-esc="path.name"/>
                                        <span class="o_vd_path_sub"><t t-esc="path.courses.length"/> khóa học</span>
                                    </div>
                                    <div t-if="!path_last" class="o_vd_path_link"/>
                                </div>
                                <div t-if="path.courses.length" class="o_vd_arrow o_vd_arrow_lead"/>
                                <t t-call="vd_elearning.Track">
                                    <t t-set="nodes" t-value="studentPathNodes(path)"/>
                                    <t t-set="dropCtx" t-value="false"/>
                                    <t t-set="draggable" t-value="false"/>
                                </t>
                            </div>
                        </t>
                        <div t-if="!state.selectedEmp.paths.length" class="o_vd_emp_empty">Chưa có lộ trình đào tạo nào.</div>
                    </div>
                </div>
            </t>

            <!-- GIAO DIEN ADMIN -->
            <t t-else="">
                <nav class="o_vd_tabbar">
                    <button t-attf-class="o_vd_tab {{state.tab == 'sales' ? 'active' : ''}}"
                        t-on-mouseenter="() => this.setTab('sales')" t-on-click="() => this.setTab('sales')">
                        <i class="fa fa-graduation-cap me-2"/>ĐÀO TẠO NHÂN VIÊN
                    </button>
                    <button t-attf-class="o_vd_tab {{state.tab == 'leader' ? 'active' : ''}}"
                        t-on-mouseenter="() => this.setTab('leader')" t-on-click="() => this.setTab('leader')">
                        <i class="fa fa-shield me-2"/>ĐÀO TẠO TRƯỞNG NHÓM
                    </button>
                    <button t-attf-class="o_vd_tab {{state.tab == 'staff' ? 'active' : ''}}"
                        t-on-mouseenter="() => this.setTab('staff')" t-on-click="() => this.setTab('staff')">
                        <i class="fa fa-users me-2"/>NHÂN VIÊN
                    </button>
                    <select class="o_vd_emp_select" t-on-change="(ev) => this.selectEmpGlobal(ev)">
                        <option value="">👤 Xem theo nhân viên...</option>
                        <t t-foreach="state.report" t-as="emp" t-key="emp.id">
                            <option t-att-value="emp.id" t-esc="emp.name"/>
                        </t>
                    </select>
                </nav>

                <div class="o_vd_card">
                    <t t-if="state.tab == 'staff'">
                        <div class="o_vd_report_head">
                            <h3>Báo cáo đào tạo nhân viên</h3>
                            <span><t t-esc="state.report.length"/> nhân viên</span>
                        </div>
                        <div class="o_vd_report_grid">
                            <t t-foreach="state.report" t-as="row" t-key="row.id">
                                <div class="o_vd_report_card" t-on-click="() => this.viewEmployee(row)">
                                    <img class="o_vd_report_ava"
                                         t-attf-src="/web/image/res.users/{{row.id}}/avatar_128"/>
                                    <div class="o_vd_report_main">
                                        <span class="o_vd_report_name" t-esc="row.name"/>
                                        <span class="o_vd_report_role">
                                            <span class="o_vd_report_team" t-esc="row.team"/>
                                            <t t-esc="row.role"/>
                                        </span>
                                        <div class="o_vd_report_bar">
                                            <div class="o_vd_report_fill" t-attf-style="width:{{row.percent}}%"/>
                                        </div>
                                        <span class="o_vd_report_meta">
                                            <b t-esc="row.completed"/>/<t t-esc="row.total"/> khóa · <t t-esc="row.percent"/>%
                                            <span t-if="row.current" class="o_vd_report_cur">→ <t t-esc="row.current"/></span>
                                        </span>
                                    </div>
                                </div>
                            </t>
                            <div t-if="!state.report.length" class="o_vd_emp_empty">Chưa có nhân viên</div>
                        </div>
                    </t>

                    <t t-else="">
                        <t t-set="zone" t-value="activeZone"/>
                        <t t-if="zone" t-call="vd_elearning.ZonePanel"/>
                    </t>
                </div>
            </t>
        </div>
    </t>

</templates>
