<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============ KHU NHAN VIEN KINH DOANH ============ -->
        <!-- Khoa HOI NHAP (dau lo trinh): noi dung + 20 cau thi do _vd_seed_hoi_nhap. -->
        <record id="course_hoi_nhap" model="slide.channel">
            <field name="name">Vinaduy và Hội nhập</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
            <field name="vd_seq">1</field>
            <field name="vd_pass_percent">100</field>
            <field name="vd_max_attempts">3</field>
        </record>

        <record id="course_a1" model="slide.channel">
            <field name="name">A1 - Mẫu Nhà</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_a2" model="slide.channel">
            <field name="name">A2 - Móng</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_mong_nang_cao" model="slide.channel">
            <field name="name">Móng nâng cao</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_b3" model="slide.channel">
            <field name="name">B3 - Vật tư không có trong HĐ</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_vat_tu_xay_tho" model="slide.channel">
            <field name="name">Vật tư xây thô - Hoàn thiện</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_c1" model="slide.channel">
            <field name="name">Bảng giá</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <!-- course_c2 ("C2 - Tinh nham") da go han: noi dung tinh nham gop vao
             course_c1 ("Bang gia"). Khong giu <record> nua de -u KHONG tai tao lai. -->
        <record id="course_d" model="slide.channel">
            <field name="name">D - Cân Đối Tiền</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_d1" model="slide.channel">
            <field name="name">D1 - Giảm diện tích</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_d2" model="slide.channel">
            <field name="name">D2 - Chuyển đổi mẫu nhà</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_d3" model="slide.channel">
            <field name="name">D3 - Chuyển đổi loại móng</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_d4" model="slide.channel">
            <field name="name">D4 - Giảm vật tư</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_d5" model="slide.channel">
            <field name="name">D5 - Chuyển về xây thô</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>
        <record id="course_d6" model="slide.channel">
            <field name="name">D6 - Giảm đơn giá</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
        </record>

        <!-- Khoa hoc KY NANG: nhan dien khach hang tiem nang (noi dung + 20 cau thi
             do _vd_seed_kh_tiem_nang seed - xem ham o duoi). -->
        <record id="course_kh_tiem_nang" model="slide.channel">
            <field name="name">Kỹ năng nhận diện khách hàng tiềm năng</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
            <field name="vd_seq">5</field>
            <field name="vd_pass_percent">100</field>
            <field name="vd_max_attempts">3</field>
        </record>

        <!-- Khoa hoc: Xu ly khach CHUA hop tuoi xay nha (muon tuoi). Noi dung +
             20 cau thi do _vd_seed_khong_tuoi seed. -->
        <record id="course_khong_tuoi" model="slide.channel">
            <field name="name">Xử lý khách chưa hợp tuổi xây nhà (mượn tuổi)</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
            <field name="vd_seq">6</field>
            <field name="vd_pass_percent">100</field>
            <field name="vd_max_attempts">3</field>
        </record>

        <!-- Khoa KY NANG SALE: chuan hoa 30 giay dau khi goi dien. Noi dung +
             20 cau thi do _vd_seed_30s_dau seed. -->
        <record id="course_30s_dau" model="slide.channel">
            <field name="name">Chuẩn hóa 30 giây đầu khi gọi điện</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">sales</field>
            <field name="vd_seq">7</field>
            <field name="vd_pass_percent">100</field>
            <field name="vd_max_attempts">3</field>
        </record>

        <!-- ============ KHU TRUONG NHOM (it khoa hoc - placeholder, doi ten sau) ============ -->
        <record id="course_tn1" model="slide.channel">
            <field name="name">TN1 - Quản lý đội nhóm</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">leader</field>
        </record>
        <record id="course_tn2" model="slide.channel">
            <field name="name">TN2 - Kèm cặp nhân viên</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">leader</field>
        </record>
        <record id="course_tn3" model="slide.channel">
            <field name="name">TN3 - Đọc báo cáo nhóm</field>
            <field name="channel_type">training</field>
            <field name="vd_role_zone">leader</field>
        </record>

    </data>

    <!-- Seed noi dung + 20 cau hoi thi cho khoa "nhan dien KH tiem nang".
         Idempotent: bo qua neu khoa da co noi dung (giu nguyen sua tay cua admin). -->
    <function model="slide.channel" name="_vd_seed_hoi_nhap"/>
    <function model="slide.channel" name="_vd_seed_mau_nha"/>
    <function model="slide.channel" name="_vd_seed_mong"/>
    <function model="slide.channel" name="_vd_seed_vat_tu"/>
    <function model="slide.channel" name="_vd_seed_vat_tu_ngoai"/>
    <function model="slide.channel" name="_vd_seed_bang_gia"/>
    <function model="slide.channel" name="_vd_seed_kh_tiem_nang"/>
    <function model="slide.channel" name="_vd_seed_khong_tuoi"/>
    <function model="slide.channel" name="_vd_seed_30s_dau"/>
    <function model="slide.channel" name="_vd_seed_d1_giam_dien_tich"/>

    <!-- Ap mac dinh 100% / 3 lan / thoi gian = so cau cho TAT CA khoa (1 lan). -->
    <function model="slide.channel" name="_vd_apply_course_defaults"/>
</odoo>
