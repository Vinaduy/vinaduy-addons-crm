<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vd_stringee_hotline_search" model="ir.ui.view">
        <field name="name">vd.stringee.hotline.search</field>
        <field name="model">vd.stringee.hotline</field>
        <field name="arch" type="xml">
            <search string="Số tổng đài Stringee">
                <field name="name"/>
                <field name="number"/>
                <field name="team_label"/>
                <field name="carrier"/>
                <filter string="Đang hoạt động" name="filter_active" domain="[('active','=',True)]"/>
                <filter string="Tạm ngưng" name="filter_inactive" domain="[('active','=',False)]"/>
                <separator/>
                <filter string="Viettel" name="filter_viettel" domain="[('carrier','=','viettel')]"/>
                <filter string="MobiFone" name="filter_mobi" domain="[('carrier','=','mobi')]"/>
                <filter string="Vinaphone" name="filter_vina" domain="[('carrier','=','vina')]"/>
                <group expand="1" string="Nhóm theo">
                    <filter string="Team" name="groupby_team" context="{'group_by': 'team_label'}"/>
                    <filter string="Nhà mạng" name="groupby_carrier" context="{'group_by': 'carrier'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_vd_stringee_hotline_tree" model="ir.ui.view">
        <field name="name">vd.stringee.hotline.tree</field>
        <field name="model">vd.stringee.hotline</field>
        <field name="arch" type="xml">
            <list string="Số tổng đài Stringee" editable="bottom">
                <field name="carrier"/>
                <field name="number"/>
                <field name="name"/>
                <field name="team_label"/>
                <field name="user_count" readonly="1"/>
                <field name="assigned_user_names" readonly="1" string="NV đã gán"/>
                <button name="action_open_assign_wizard" type="object"
                        string="Gán NV" icon="fa-user-plus"
                        class="btn-link"
                        help="Mở popup chọn NV được gán số này (chọn được NHIỀU NV cho 1 số)"/>
                <field name="vd_force_alive" widget="boolean_toggle" string="Còn sống (ép)"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_vd_stringee_hotline_kanban" model="ir.ui.view">
        <field name="name">vd.stringee.hotline.kanban</field>
        <field name="model">vd.stringee.hotline</field>
        <field name="arch" type="xml">
            <kanban default_group_by="carrier" group_create="false"
                    group_delete="false" group_edit="false"
                    class="o_kanban_small_column o_vd_hotline_kanban"
                    records_draggable="false">
                <field name="carrier"/>
                <field name="number"/>
                <field name="name"/>
                <field name="team_label"/>
                <field name="user_count"/>
                <field name="assigned_user_names"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="o_vd_hotline_card {{ record.user_count.raw_value ? 'o_vd_has_user' : 'o_vd_no_user' }}">
                            <div class="o_vd_hotline_head">
                                <span class="o_vd_hotline_number" t-esc="record.number.value"/>
                                <span t-attf-class="badge {{ record.user_count.raw_value ? 'text-bg-primary' : 'text-bg-secondary' }}">
                                    <i class="fa fa-user me-1"/><t t-esc="record.user_count.value"/> NV
                                </span>
                            </div>
                            <div class="o_vd_hotline_meta text-muted small">
                                <span t-if="record.name.value" t-esc="record.name.value"/>
                                <span t-if="record.team_label.value" class="ms-1">· <t t-esc="record.team_label.value"/></span>
                            </div>
                            <div class="o_vd_hotline_users small mt-1" t-esc="record.assigned_user_names.value"/>
                            <div class="o_vd_hotline_foot mt-2">
                                <button name="action_open_assign_wizard" type="object"
                                        class="btn btn-sm btn-link p-0"
                                        title="Gán/sửa NV thủ công cho số này">
                                    <i class="fa fa-user-plus me-1"/>Gán NV
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_vd_stringee_hotline_form" model="ir.ui.view">
        <field name="name">vd.stringee.hotline.form</field>
        <field name="model">vd.stringee.hotline</field>
        <field name="arch" type="xml">
            <form string="Số tổng đài Stringee">
                <header>
                    <button name="action_open_assign_wizard" type="object"
                            string="Gán NV" class="btn-primary"
                            icon="fa-user-plus"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Vd: HCM1 - Viettel"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="number" placeholder="Vd: 84917690625"/>
                            <field name="carrier"/>
                            <field name="team_label" placeholder="HCM1 / HCM2 / HN..."/>
                            <field name="active"/>
                            <field name="vd_force_alive"/>
                        </group>
                        <group>
                            <field name="user_count" readonly="1"/>
                            <field name="note" placeholder="Ghi chú..."/>
                        </group>
                    </group>
                    <separator string="NV được gán số này"/>
                    <field name="assigned_user_ids" readonly="1">
                        <list>
                            <field name="login"/>
                            <field name="name"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vd_stringee_hotline" model="ir.actions.act_window">
        <field name="name">Số tổng đài Stringee</field>
        <field name="res_model">vd.stringee.hotline</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Quản lý pool số tổng đài Stringee.</p>
            <p>Mỗi team có thể có nhiều số (Viettel/MobiFone/Vinaphone) — gán cho từng NV ở form Users.</p>
        </field>
    </record>

</odoo>
