<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_stringee" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.vd_stringee</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Stringee" string="Stringee" name="vd_stringee" groups="base.group_system">
                    <block title="Stringee Telephony" name="stringee_credentials">

                        <setting id="stringee_api_keys" string="API Keys"
                                 help="Lấy từ Stringee Portal → Project → API Keys.">
                            <div class="content-group">
                                <div class="row mt-2">
                                    <label for="stringee_api_key_sid" class="col-3 col-form-label"/>
                                    <field name="stringee_api_key_sid" class="col-9" placeholder="SK..."/>
                                </div>
                                <div class="row mt-2">
                                    <label for="stringee_api_key_secret" class="col-3 col-form-label"/>
                                    <field name="stringee_api_key_secret" class="col-9" password="True"/>
                                </div>
                                <div class="row mt-2">
                                    <label for="stringee_project_id" class="col-3 col-form-label"/>
                                    <field name="stringee_project_id" class="col-9"/>
                                </div>
                            </div>
                        </setting>

                        <setting id="stringee_hotline_pool" string="Pool số tổng đài (per-NV)"
                                 help="Mỗi NV được assign 1 số riêng (Viettel/Mobi/Vina). Quản lý qua menu Stringee → Số tổng đài.">
                            <div class="content-group">
                                <div class="row mt-2">
                                    <span class="col-7">
                                        Đã khai báo
                                        <strong><field name="stringee_hotline_count" readonly="1" nolabel="1" class="d-inline-block" style="width:auto;"/></strong>
                                        số tổng đài
                                    </span>
                                    <button name="action_open_stringee_hotline_pool" type="object"
                                            class="btn btn-primary col-5">
                                        <i class="fa fa-list me-1"/> Quản lý pool số tổng đài
                                    </button>
                                </div>
                                <div class="text-muted mt-2 small">
                                    Thêm số mới: <b>Stringee → Số tổng đài → + Mới</b><br/>
                                    Assign cho NV: <b>Settings → Users → tab Stringee</b>
                                </div>
                            </div>
                        </setting>

                        <setting id="stringee_dialer" string="Fallback &amp; Recording"
                                 help="Số global dùng khi NV chưa được assign số riêng + bật ghi âm.">
                            <div class="content-group">
                                <div class="row mt-2">
                                    <label for="stringee_from_number" class="col-4 col-form-label"/>
                                    <field name="stringee_from_number" class="col-8" placeholder="84xxxxxxxxx"/>
                                </div>
                                <div class="row mt-2">
                                    <field name="stringee_record_calls"/>
                                    <label for="stringee_record_calls"/>
                                </div>
                            </div>
                        </setting>

                        <setting id="stringee_webhook_info" string="Webhook URLs"
                                 help="3 URL khai báo trong Stringee Portal → Project Settings hoặc URL Setting của từng số. Tất cả số dùng chung 3 URL này — controller tự route bằng payload.">
                            <div class="content-group">
                                <div class="row mt-2">
                                    <label for="stringee_webhook_base_url" string="Base URL" class="col-4 col-form-label"/>
                                    <field name="stringee_webhook_base_url" readonly="1" class="col-8"/>
                                </div>
                                <div class="row mt-2">
                                    <label for="stringee_answer_url" string="Answer URL" class="col-4 col-form-label"/>
                                    <field name="stringee_answer_url" readonly="1" class="col-8"/>
                                </div>
                                <div class="row mt-2">
                                    <label for="stringee_event_url" string="Event URL" class="col-4 col-form-label"/>
                                    <field name="stringee_event_url" readonly="1" class="col-8"/>
                                </div>
                                <div class="row mt-2">
                                    <label for="stringee_recording_url" string="Recording Event URL" class="col-4 col-form-label"/>
                                    <field name="stringee_recording_url" readonly="1" class="col-8"/>
                                </div>
                                <div class="text-muted mt-2 small">
                                    <i class="fa fa-info-circle me-1"/>
                                    Mỗi số mới thêm trên Stringee Dashboard → click <b>URL Setting</b> → paste 3 URL trên.
                                </div>
                            </div>
                        </setting>

                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
