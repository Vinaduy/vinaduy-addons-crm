<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_stringee" model="ir.ui.view">
        <field name="name">res.users.form.inherit.vd_stringee</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Stringee" name="stringee">
                    <group>
                        <field name="stringee_user_id" placeholder="vd_user_001"/>
                    </group>
                    <p class="text-muted">
                        ID đã tạo trên Stringee Portal → Project → Users. Để trống nếu NV này
                        không gọi qua Web SDK.
                    </p>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
