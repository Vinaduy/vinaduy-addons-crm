<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="vd_stringee.AssignmentBoard">
        <div class="o_vd_board">
            <div t-if="state.loading" class="o_vd_board_loading text-muted p-4">
                Đang tải bảng phân số...
            </div>
            <div t-else="" class="o_vd_board_wrap">

                <!-- CẢNH BÁO: NV thiếu số SỐNG theo mạng (số chết đã tự gỡ —
                     user spec 2026-06-09). Admin chia lại số sống cho các NV này. -->
                <div t-if="state.alerts and state.alerts.length"
                     class="o_vd_board_alerts alert alert-warning py-2 px-3 mb-2">
                    <div class="fw-bold mb-1">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        <t t-esc="state.alerts.length"/> NV đang THIẾU số sống — cần chia lại:
                    </div>
                    <div class="o_vd_alert_list">
                        <t t-foreach="state.alerts" t-as="al" t-key="al.user">
                            <span class="o_vd_alert_item me-3">
                                <b t-esc="al.user"/>: thiếu <t t-esc="al.carriers.join(', ')"/>
                            </span>
                        </t>
                    </div>
                </div>

                <!-- KHO SỐ: gom theo nhà mạng, kéo chip thả vào NV -->
                <div class="o_vd_palette">
                    <div class="o_vd_palette_title">
                        <i class="fa fa-th-large me-1"/>Kho số — kéo thả vào NV
                    </div>
                    <t t-foreach="state.carriers" t-as="c" t-key="c.code">
                        <div class="o_vd_pal_carrier" t-att-data-carrier="c.code">
                            <div class="o_vd_pal_carrier_h">
                                <t t-esc="c.label"/> <span class="o_vd_dim">(<t t-esc="c.numbers.length"/>)</span>
                            </div>
                            <div class="o_vd_pal_nums">
                                <t t-foreach="c.numbers" t-as="n" t-key="n.id">
                                    <span class="o_vd_chip"
                                          t-att-data-carrier="c.code"
                                          t-att-class="'o_vd_health_' + (n.health || 'unused')"
                                          draggable="true"
                                          t-on-dragstart="(ev) => this.onDragStart(ev, n, c.code)"
                                          t-on-mouseenter="(ev) => this.onChipEnter(ev, n)"
                                          t-on-mouseleave="() => this.onChipLeave()">
                                        <span class="o_vd_health_dot"/>
                                        <span class="o_vd_chip_num o_vd_chip_copy" title="Bấm để copy số"
                                              t-on-click="(ev) => this.copyNumber(ev, n.number)"
                                              t-esc="n.number"/>
                                        <span class="o_vd_chip_net"/>
                                        <span class="o_vd_chip_count" t-esc="n.user_count"/>
                                    </span>
                                </t>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- NHÂN VIÊN: mỗi NV 1 ô, thả số vào -->
                <div class="o_vd_users">
                    <div class="o_vd_users_toolbar">
                        <input type="text" class="form-control o_vd_search"
                               placeholder="Tìm nhân viên..." t-model="state.search"/>
                        <span class="o_vd_dim ms-2">
                            <t t-esc="filteredUsers.length"/>/<t t-esc="state.users.length"/> NV
                        </span>
                        <div class="o_vd_toolbar_btns ms-auto">
                            <button type="button" class="btn btn-success btn-sm"
                                    t-on-click="() => this.openDistModal()">
                                <i class="fa fa-random me-1"/>Chia số
                            </button>
                            <button type="button" class="btn btn-primary btn-sm ms-2"
                                    t-on-click="() => this.openDistribute()">
                                <i class="fa fa-magic me-1"/>Thêm NV &amp; chia đều
                            </button>
                            <button type="button" class="btn btn-secondary btn-sm ms-2"
                                    t-on-click="() => this.openLookup()">
                                <i class="fa fa-table me-1"/>Bảng tra cứu
                            </button>
                        </div>
                    </div>
                    <div class="o_vd_user_grid">
                        <t t-foreach="filteredUsers" t-as="u" t-key="u.id">
                            <div class="o_vd_user_box o_vd_user_row"
                                 t-on-dragover="(ev) => this.onDragOver(ev)"
                                 t-on-dragleave="(ev) => this.onDragLeave(ev)"
                                 t-on-drop="(ev) => this.onDrop(ev, u)">
                                <div class="o_vd_user_name" t-att-title="u.name">
                                    <i class="fa fa-user me-1"/><span class="o_vd_user_name_txt" t-esc="u.name"/>
                                </div>
                                <div class="o_vd_user_chips">
                                    <t t-foreach="u.hotlines" t-as="h" t-key="h.id">
                                        <span class="o_vd_chip o_vd_chip_assigned"
                                              t-att-data-carrier="h.carrier"
                                              t-att-class="'o_vd_health_' + (h.health || 'unused')">
                                            <span class="o_vd_health_dot"
                                                  t-att-class="'o_vd_health_' + (h.health || 'unused')"/>
                                            <span class="o_vd_chip_num o_vd_chip_copy" title="Bấm để copy số"
                                                  t-on-click="(ev) => this.copyNumber(ev, h.number)"
                                                  t-esc="h.number"/>
                                            <span class="o_vd_chip_net"/>
                                            <span class="o_vd_chip_x"
                                                  t-on-click="() => this.onRemove(u, h)">×</span>
                                        </span>
                                    </t>
                                    <span t-if="!u.hotlines.length" class="o_vd_empty">
                                        Chưa có số — kéo số vào đây
                                    </span>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>

            </div>

            <!-- Popover chi tiết số (hiện khi hover chip kho số) -->
            <div t-if="state.hover" class="o_vd_pop" t-att-style="popStyle">
                <div class="o_vd_pop_h">
                    <span class="o_vd_health_dot" t-att-class="'o_vd_health_' + (state.hover.number.health || 'unused')"/>
                    <i class="fa fa-phone ms-1 me-1"/><t t-esc="state.hover.number.number"/>
                    <span class="o_vd_pop_badge" t-att-class="'o_vd_health_' + (state.hover.number.health || 'unused')">
                        <t t-if="state.hover.number.health === 'alive'">CÒN SỐNG</t>
                        <t t-elif="state.hover.number.health === 'dead'">SỐ CHẾT</t>
                        <t t-else="">CHƯA DÙNG</t>
                    </span>
                </div>

                <!-- Thống kê tổng của SỐ -->
                <div class="o_vd_pop_stats">
                    <div class="o_vd_pop_stat">
                        <span class="o_vd_pop_stat_v"><t t-esc="state.hover.number.total_calls"/></span>
                        <span class="o_vd_pop_stat_l">cuộc gọi</span>
                    </div>
                    <div class="o_vd_pop_stat">
                        <span class="o_vd_pop_stat_v"><t t-esc="state.hover.number.reached"/></span>
                        <span class="o_vd_pop_stat_l">đổ chuông</span>
                    </div>
                    <div class="o_vd_pop_stat">
                        <span class="o_vd_pop_stat_v"><t t-esc="state.hover.number.talk_hm"/></span>
                        <span class="o_vd_pop_stat_l">thời lượng gọi</span>
                    </div>
                    <div class="o_vd_pop_stat">
                        <span class="o_vd_pop_stat_v"><t t-esc="state.hover.number.per_day"/></span>
                        <span class="o_vd_pop_stat_l">cuộc/ngày (TB)</span>
                    </div>
                </div>
                <div class="o_vd_pop_span" t-if="state.hover.number.first">
                    Hoạt động: <b t-esc="state.hover.number.first"/> → <b t-esc="state.hover.number.last"/>
                    <span class="o_vd_dim">(<t t-esc="state.hover.number.active_days"/> ngày)</span>
                </div>
                <div class="o_vd_pop_span o_vd_dim" t-else="">Chưa phát sinh cuộc gọi nào.</div>

                <div class="o_vd_pop_sub">Nhân viên được gán (<t t-esc="state.hover.number.detail.length"/>)</div>
                <table class="o_vd_pop_tbl" t-if="state.hover.number.detail.length">
                    <thead>
                        <tr><th>Nhân viên</th><th>Dùng từ</th><th class="text-end">Phút gọi</th><th class="text-end">Cuộc</th></tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.hover.number.detail" t-as="d" t-key="d_index">
                            <tr>
                                <td t-esc="d.user"/>
                                <td>
                                    <t t-if="d.first"><t t-esc="d.first"/> <span class="o_vd_dim">(<t t-esc="d.days"/>n)</span></t>
                                    <t t-else=""><span class="o_vd_dim">chưa gọi</span></t>
                                </td>
                                <td class="text-end" t-esc="d.minutes"/>
                                <td class="text-end" t-esc="d.count"/>
                            </tr>
                        </t>
                    </tbody>
                </table>
                <div t-else="" class="o_vd_dim o_vd_pop_empty">Chưa gán cho NV nào.</div>
            </div>

            <!-- ===== POPUP CHIA SỐ: chọn số → chọn NV → CHIA SỐ ===== -->
            <div t-if="state.dist.open" class="o_vd_dist_overlay"
                 t-on-click="() => this.closeDistModal()">
                <div class="o_vd_dist_modal" t-on-click.stop="() => {}">
                    <div class="o_vd_dist_head">
                        <span><i class="fa fa-random me-2"/>Chia số tổng đài</span>
                        <button type="button" class="o_vd_dist_close"
                                t-on-click="() => this.closeDistModal()">×</button>
                    </div>

                    <div class="o_vd_dist_body">
                        <!-- Bước 1: chọn số -->
                        <div class="o_vd_dist_step">
                            <div class="o_vd_dist_step_h">
                                <span class="o_vd_dist_no">1</span> Chọn số
                                <span class="o_vd_dim ms-2"><t t-esc="distNumIds.length"/> số đã chọn</span>
                                <div class="o_vd_dist_quick ms-auto">
                                    <a t-on-click="() => this.distSelectAlive()">Chọn số sống</a>
                                    <a t-on-click="() => this.distClearNums()">Bỏ chọn hết</a>
                                </div>
                            </div>
                            <t t-foreach="state.carriers" t-as="c" t-key="c.code">
                                <div class="o_vd_dist_carrier"><t t-esc="c.label"/></div>
                                <div class="o_vd_dist_chips">
                                    <t t-foreach="c.numbers" t-as="n" t-key="n.id">
                                        <label class="o_vd_dist_chip"
                                               t-att-data-carrier="c.code"
                                               t-att-class="{'o_vd_sel': state.dist.nums[n.id]}">
                                            <input type="checkbox"
                                                   t-att-checked="state.dist.nums[n.id]"
                                                   t-on-change="() => this.toggleDistNum(n.id)"/>
                                            <span class="o_vd_health_dot"
                                                  t-att-class="'o_vd_health_' + (n.health || 'unused')"/>
                                            <span t-esc="n.number"/>
                                        </label>
                                    </t>
                                </div>
                            </t>
                        </div>

                        <!-- Bước 2: chọn nhân viên -->
                        <div class="o_vd_dist_step">
                            <div class="o_vd_dist_step_h">
                                <span class="o_vd_dist_no">2</span> Chọn nhân viên
                                <span class="o_vd_dim ms-2"><t t-esc="distUserIds.length"/> NV đã chọn</span>
                                <div class="o_vd_dist_quick ms-auto">
                                    <a t-on-click="() => this.distSelectEligible()">Chọn NV đủ ĐK</a>
                                    <a t-on-click="() => this.distClearUsers()">Bỏ chọn hết</a>
                                </div>
                            </div>
                            <div class="o_vd_dist_users">
                                <t t-foreach="state.users" t-as="u" t-key="u.id">
                                    <label class="o_vd_dist_user"
                                           t-att-class="{'o_vd_sel': state.dist.users[u.id]}">
                                        <input type="checkbox"
                                               t-att-checked="state.dist.users[u.id]"
                                               t-on-change="() => this.toggleDistUser(u.id)"/>
                                        <span class="o_vd_dist_user_n" t-esc="u.name"/>
                                        <span t-if="u.no_share" class="o_vd_dim">(không chia)</span>
                                    </label>
                                </t>
                            </div>
                        </div>
                    </div>

                    <div class="o_vd_dist_foot">
                        <span class="o_vd_dim">Chia đều round-robin: mỗi NV nhận 1 số/mạng, thay số cùng mạng đang có.</span>
                        <button type="button" class="btn btn-success o_vd_dist_go"
                                t-att-disabled="state.busy"
                                t-on-click="() => this.doDistribute()">
                            <i class="fa fa-check me-1"/>CHIA SỐ
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </t>

</templates>
