<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         BÁO GIÁ FULL — DỰNG 100% BẰNG CODE (thử nghiệm 2026-07-02).
         Nhiều trang, tự lắp section theo Móng / Mái của lead. Xuất PDF
         tải về gửi khách. Gam màu VINADUY (xanh/cam). KHÔNG phụ thuộc
         file PowerPoint template.
         Demo cấu hình: Móng băng · Mái bằng · Miền Bắc.
         ============================================================ -->
    <record id="action_vd_quote_full_report" model="ir.actions.report">
        <field name="name">Báo giá FULL (dựng bằng code)</field>
        <field name="model">crm.lead</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">vd_crm_lead.report_vd_quote_full</field>
        <field name="report_file">vd_crm_lead.report_vd_quote_full</field>
        <field name="paperformat_id" ref="paperformat_vd_a4_landscape"/>
        <field name="binding_model_id" ref="crm.model_crm_lead"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Dải tiêu đề dùng chung mỗi trang (title truyền qua t-set band_title) -->
    <template id="report_vd_quote_full_band">
        <div style="position:relative;width:100%;height:52px;margin-bottom:0.6rem;">
            <svg width="100%" height="52" viewBox="0 0 1200 52" preserveAspectRatio="none"
                 xmlns="http://www.w3.org/2000/svg" style="display:block;position:absolute;top:0;left:0;">
                <defs>
                    <linearGradient id="qf_blue" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" stop-color="#a9c4da"/>
                        <stop offset="50%" stop-color="#3f74a3"/>
                        <stop offset="100%" stop-color="#a9c4da"/>
                    </linearGradient>
                </defs>
                <rect x="0" y="4" width="1200" height="44" fill="url(#qf_blue)"/>
                <polygon points="1112,4 1200,4 1200,48 1052,48" fill="#ec7a2a"/>
                <text x="42" y="35" font-family="Georgia,'Times New Roman',serif"
                      font-weight="700" font-size="23" letter-spacing="4" fill="#ffffff"><t t-esc="band_title"/></text>
            </svg>
            <img t-att-src="ctx.get('logo_data_uri', '')" alt="VINADUY"
                 style="position:absolute;top:9px;right:20px;height:34px;"/>
        </div>
    </template>

    <template id="report_vd_quote_full">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="ctx" t-value="o._build_quote_context()"/>
                <t t-set="region_lbl" t-value="{'bac':'MIỀN BẮC','trung':'MIỀN TRUNG','nam':'MIỀN NAM'}.get(o.vd_intake_region or 'bac','MIỀN BẮC')"/>
                <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
                <meta charset="UTF-8"/>

                <!-- ============ TRANG 1 — BÌA ============ -->
                <div class="page" lang="vi" style="font-family:Georgia,'Times New Roman',serif;color:#23303d;page-break-after:always;position:relative;height:530px;">
                    <div style="position:relative;width:100%;height:150px;">
                        <svg width="100%" height="150" viewBox="0 0 1200 150" preserveAspectRatio="none"
                             xmlns="http://www.w3.org/2000/svg" style="display:block;position:absolute;top:0;left:0;">
                            <defs>
                                <linearGradient id="qf_cover" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" stop-color="#5a85ad"/>
                                    <stop offset="100%" stop-color="#1864ab"/>
                                </linearGradient>
                            </defs>
                            <rect x="0" y="0" width="1200" height="150" fill="url(#qf_cover)"/>
                            <polygon points="1080,0 1200,0 1200,150 980,150" fill="#ec7a2a"/>
                            <rect x="0" y="143" width="1200" height="7" fill="#c9b48a"/>
                        </svg>
                        <img t-att-src="ctx.get('logo_data_uri', '')" alt="VINADUY"
                             style="position:absolute;top:44px;left:40px;height:62px;background:#fff;padding:6px 10px;border-radius:6px;"/>
                    </div>

                    <div style="text-align:center;margin-top:60px;">
                        <div style="font-size:34pt;font-weight:700;color:#1864ab;letter-spacing:3px;">BÁO GIÁ XÂY NHÀ TRỌN GÓI</div>
                        <div style="font-size:14pt;color:#ec7a2a;letter-spacing:6px;margin-top:8px;font-weight:700;">NHÀ Ở DÂN DỤNG</div>
                        <div style="width:180px;height:3px;background:#c9b48a;margin:18px auto;"/>
                    </div>

                    <!-- Card khách hàng -->
                    <table style="width:60%;margin:26px auto 0;border-collapse:collapse;font-size:12pt;border:1px solid #cddff2;">
                        <tr>
                            <td style="padding:0.5rem 1rem;background:#eaf1f9;font-weight:700;color:#1864ab;width:32%;border-bottom:1px solid #d5e3f1;">Kính gửi</td>
                            <td style="padding:0.5rem 1rem;border-bottom:1px solid #d5e3f1;font-weight:700;"><t t-esc="ctx.get('kh_name') or '—'"/></td>
                        </tr>
                        <tr>
                            <td style="padding:0.5rem 1rem;background:#eaf1f9;font-weight:700;color:#1864ab;border-bottom:1px solid #d5e3f1;">Địa chỉ</td>
                            <td style="padding:0.5rem 1rem;border-bottom:1px solid #d5e3f1;"><t t-esc="ctx.get('kh_address') or '—'"/></td>
                        </tr>
                        <tr>
                            <td style="padding:0.5rem 1rem;background:#eaf1f9;font-weight:700;color:#1864ab;">Ngày lập</td>
                            <td style="padding:0.5rem 1rem;"><t t-esc="ctx.get('today')"/></td>
                        </tr>
                    </table>

                    <!-- Chips cấu hình -->
                    <div style="text-align:center;margin-top:22px;">
                        <span style="display:inline-block;margin:3px 4px;padding:5px 14px;background:#1864ab;color:#fff;border-radius:999px;font-size:10pt;font-weight:700;"><t t-esc="region_lbl"/></span>
                        <span style="display:inline-block;margin:3px 4px;padding:5px 14px;background:#eaf1f9;color:#1864ab;border:1px solid #93c5fd;border-radius:999px;font-size:10pt;font-weight:700;"><t t-esc="ctx.get('foundation')"/></span>
                        <span style="display:inline-block;margin:3px 4px;padding:5px 14px;background:#eaf1f9;color:#1864ab;border:1px solid #93c5fd;border-radius:999px;font-size:10pt;font-weight:700;"><t t-esc="ctx.get('roof')"/></span>
                        <span style="display:inline-block;margin:3px 4px;padding:5px 14px;background:#eaf1f9;color:#1864ab;border:1px solid #93c5fd;border-radius:999px;font-size:10pt;font-weight:700;"><t t-esc="ctx.get('floors')"/> tầng</span>
                        <span style="display:inline-block;margin:3px 4px;padding:5px 14px;background:#fff3e6;color:#d9480f;border:1px solid #ffcc99;border-radius:999px;font-size:10pt;font-weight:700;">Tổng sàn <t t-esc="ctx.get('total_floor_area')"/> m²</span>
                    </div>

                    <div style="position:absolute;bottom:14px;left:0;width:100%;text-align:center;color:#1864ab;font-size:11pt;font-weight:700;">
                        <span style="color:#ec7a2a;font-weight:700;">Hotline:</span> 1900 9999 46 – 024 99999 868 &#160;&#160;·&#160;&#160; vinaduy.com
                    </div>
                </div>

                <!-- ============ TRANG 2 — BÁO GIÁ CHI TIẾT ============ -->
                <div class="page" lang="vi" style="font-family:Georgia,'Times New Roman',serif;color:#23303d;page-break-after:always;">
                    <t t-call="vd_crm_lead.report_vd_quote_full_band"><t t-set="band_title">BẢNG BÁO GIÁ CHI TIẾT</t></t>

                    <ul style="padding-left:0.2rem;margin:0.3rem 0 0.7rem;line-height:1.6;font-size:10.5pt;list-style:none;">
                        <li><span style="color:#1864ab;">&#9670;</span>&#160;&#160;<b style="color:#1864ab;">VINADUY</b> xin gửi tới Quý Khách hàng bảng báo giá chi tiết xây nhà trọn gói nhà ở dân dụng</li>
                        <li><span style="color:#1864ab;">&#9670;</span>&#160;&#160;Áp dụng mẫu nhà <b style="color:#c0392b;text-transform:uppercase;"><t t-esc="ctx.get('house_type')"/></b> · kết cấu móng <b style="color:#c0392b;text-transform:uppercase;"><t t-esc="ctx.get('foundation')"/></b></li>
                    </ul>

                    <t t-set="floor_rows" t-value="ctx.get('floor_breakdown') or []"/>
                    <t t-set="km_items" t-value="ctx.get('km_items') or []"/>
                    <t t-set="ps_items" t-value="ctx.get('ps_items') or []"/>
                    <t t-set="num_rows" t-value="2 + max(len(floor_rows), 1) + len(km_items) + len(ps_items)"/>
                    <div style="border:1.5px solid #cddff2;border-radius:12px;overflow:hidden;">
                    <table style="width:100%;border-collapse:collapse;font-size:10.5pt;">
                        <thead>
                            <tr style="background:#1864ab;color:#fff;">
                                <th style="padding:0.6rem 0.85rem;text-align:left;letter-spacing:0.6px;text-transform:uppercase;font-size:9.5pt;">Nội dung</th>
                                <th style="padding:0.6rem 0.85rem;text-align:center;letter-spacing:0.6px;text-transform:uppercase;font-size:9.5pt;">Diện tích</th>
                                <th style="padding:0.6rem 0.85rem;text-align:right;letter-spacing:0.6px;text-transform:uppercase;font-size:9.5pt;">Đơn giá</th>
                                <th style="padding:0.6rem 0.85rem;text-align:right;letter-spacing:0.6px;text-transform:uppercase;font-size:9.5pt;">Thành Tiền</th>
                                <th style="padding:0.6rem 0.85rem;text-align:center;letter-spacing:0.6px;text-transform:uppercase;font-size:9.5pt;background:#12507f;">Tổng Tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;font-weight:700;color:#16324f;"><t t-esc="ctx.get('foundation')"/></td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:center;"><t t-esc="ctx.get('found_area')"/> m² x <t t-esc="ctx.get('found_pct')"/>%</td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:right;color:#55677a;"><t t-esc="ctx.get('unit_price')"/> đ</td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:right;font-weight:700;color:#16324f;"><t t-esc="ctx.get('found_cost')"/> đ</td>
                                <td t-att-rowspan="num_rows" style="padding:0.55rem 0.7rem;border-left:2px solid #93c5fd;background:#dbeafe;text-align:center;font-weight:800;font-size:15pt;color:#1864ab;vertical-align:middle;"><t t-esc="ctx.get('total_price', '0')"/> đ</td>
                            </tr>
                            <t t-foreach="floor_rows" t-as="fr" t-key="fr_index">
                                <t t-set="rbg" t-value="'#f4f8fd' if (fr_index % 2 == 0) else '#ffffff'"/>
                                <tr>
                                    <td t-att-style="'padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;font-weight:700;color:#16324f;background:' + rbg"><t t-esc="fr['label']"/></td>
                                    <td t-att-style="'padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:center;background:' + rbg"><t t-esc="fr['area']"/> m²<t t-if="fr.get('pct')"> x <t t-esc="fr['pct']"/>%</t></td>
                                    <td t-att-style="'padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:right;color:#55677a;background:' + rbg"><t t-esc="ctx.get('unit_price')"/> đ</td>
                                    <td t-att-style="'padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:right;font-weight:700;color:#16324f;background:' + rbg"><t t-esc="fr['cost']"/> đ</td>
                                </tr>
                            </t>
                            <tr>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;font-weight:700;color:#16324f;"><t t-esc="ctx.get('roof')"/></td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:center;"><t t-esc="ctx.get('roof_area')"/> m² x <t t-esc="ctx.get('roof_pct')"/>%</td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:right;color:#55677a;"><t t-esc="ctx.get('unit_price')"/> đ</td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:right;font-weight:700;color:#16324f;"><t t-esc="ctx.get('roof_cost')"/> đ</td>
                            </tr>
                        </tbody>
                    </table>
                    </div>
                    <p style="margin-top:0.6rem;font-size:9.5pt;font-style:italic;color:#6b7b8a;">* Đơn giá đã bao gồm nhân công + vật tư thô hoàn thiện theo chủng loại tiêu chuẩn. Khối lượng kết cấu căn cứ theo bản vẽ thiết kế.</p>
                </div>

                <!-- ============ TRANG 3 — KẾT CẤU MÓNG BĂNG ============ -->
                <div class="page" lang="vi" style="font-family:Georgia,'Times New Roman',serif;color:#23303d;page-break-after:always;">
                    <t t-call="vd_crm_lead.report_vd_quote_full_band"><t t-set="band_title">KẾT CẤU MÓNG BĂNG</t></t>
                    <table style="width:100%;"><tr>
                        <td style="width:46%;vertical-align:top;padding-right:14px;">
                            <!-- Sơ đồ mặt cắt móng băng (SVG) -->
                            <svg width="100%" height="230" viewBox="0 0 400 230" xmlns="http://www.w3.org/2000/svg" style="border:1px solid #cddff2;border-radius:8px;background:#f7fbff;">
                                <!-- đất -->
                                <rect x="0" y="150" width="400" height="80" fill="#efe3d0"/>
                                <line x1="0" y1="150" x2="400" y2="150" stroke="#c9b48a" stroke-width="2"/>
                                <!-- bản móng -->
                                <rect x="70" y="150" width="260" height="30" fill="#9fb6c9" stroke="#1864ab" stroke-width="2"/>
                                <!-- dầm/cổ móng -->
                                <rect x="175" y="70" width="50" height="80" fill="#c3d4e2" stroke="#1864ab" stroke-width="2"/>
                                <!-- cột -->
                                <rect x="188" y="20" width="24" height="50" fill="#ec7a2a" stroke="#b85410" stroke-width="1.5"/>
                                <!-- thép chờ -->
                                <line x1="194" y1="20" x2="194" y2="8" stroke="#b85410" stroke-width="2"/>
                                <line x1="206" y1="20" x2="206" y2="8" stroke="#b85410" stroke-width="2"/>
                                <text x="200" y="205" text-anchor="middle" font-size="13" fill="#1864ab" font-weight="700">MẶT CẮT MÓNG BĂNG</text>
                                <text x="200" y="145" text-anchor="middle" font-size="10" fill="#33475b">Bản móng 900 x 350</text>
                            </svg>
                            <div style="margin-top:10px;text-align:center;font-size:9.5pt;color:#6b7b8a;font-style:italic;">Khối lượng căn cứ theo bản vẽ kết cấu</div>
                        </td>
                        <td style="width:54%;vertical-align:top;">
                            <div style="font-size:12pt;font-weight:700;color:#1864ab;border-left:4px solid #ec7a2a;padding-left:10px;margin-bottom:10px;">Thông số kỹ thuật</div>
                            <table style="width:100%;border-collapse:collapse;font-size:10.5pt;">
                                <tr><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;color:#33475b;">Kích thước bản móng</td><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;text-align:right;font-weight:700;color:#16324f;">900 x 350 mm</td></tr>
                                <tr><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;color:#33475b;">Kích thước dầm móng</td><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;text-align:right;font-weight:700;color:#16324f;">300 x 500 mm</td></tr>
                                <tr><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;color:#33475b;">Thép bản móng</td><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;text-align:right;font-weight:700;color:#16324f;">Φ12 a150</td></tr>
                                <tr><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;color:#33475b;">Thép dầm móng</td><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;text-align:right;font-weight:700;color:#16324f;">dọc 6Φ18 · đai Φ8 a150</td></tr>
                                <tr><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;color:#33475b;">Bê tông móng</td><td style="padding:0.42rem 0.6rem;border-bottom:1px solid #e4eef9;text-align:right;font-weight:700;color:#16324f;">MÁC #300</td></tr>
                                <tr><td style="padding:0.42rem 0.6rem;color:#33475b;">Sắt cột móng</td><td style="padding:0.42rem 0.6rem;text-align:right;font-weight:700;color:#16324f;">Φ16 – 18</td></tr>
                            </table>
                            <div style="margin-top:14px;background:#eaf1f9;border-radius:8px;padding:10px 14px;font-size:10pt;color:#1864ab;">
                                <b>Ưu điểm móng băng:</b> phân bố tải đều theo tuyến tường/cột, phù hợp nền đất trung bình – tốt, chống lún lệch hiệu quả cho nhà 2–4 tầng.
                            </div>
                        </td>
                    </tr></table>
                </div>

                <!-- ============ TRANG 4 — KẾT CẤU THÂN &amp; SÀN ============ -->
                <div class="page" lang="vi" style="font-family:Georgia,'Times New Roman',serif;color:#23303d;page-break-after:always;">
                    <t t-call="vd_crm_lead.report_vd_quote_full_band"><t t-set="band_title">KẾT CẤU THÂN VÀ SÀN</t></t>
                    <table style="width:100%;border-collapse:collapse;font-size:10.5pt;">
                        <tr style="background:#1864ab;color:#fff;">
                            <th style="padding:0.55rem 0.8rem;text-align:left;width:26%;">Hạng mục</th>
                            <th style="padding:0.55rem 0.8rem;text-align:left;">Quy cách kỹ thuật</th>
                        </tr>
                        <tr><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;font-weight:700;color:#1864ab;">Cột BTCT</td><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;">Thép dọc Φ16 – 18, đai Φ8 a150 – 200; bê tông MÁC #250 – 300.</td></tr>
                        <tr style="background:#f4f8fd;"><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;font-weight:700;color:#1864ab;">Dầm sàn</td><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;">Thép chủ Φ16 – 20, đai Φ8 a150; bố trí theo bản vẽ kết cấu.</td></tr>
                        <tr><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;font-weight:700;color:#1864ab;">Sàn BTCT</td><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;">Dày 100 – 120 mm, thép 2 lớp Φ8 – 10 a150 – 200; bê tông thương phẩm đổ bơm.</td></tr>
                        <tr style="background:#f4f8fd;"><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;font-weight:700;color:#1864ab;">Tường xây</td><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;">Tường 220 bao che / 110 ngăn phòng, gạch tuynel loại 1, vữa XM MÁC #75.</td></tr>
                        <tr><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;font-weight:700;color:#1864ab;">Cầu thang</td><td style="padding:0.5rem 0.8rem;border-bottom:1px solid #e4eef9;">Bản thang BTCT, thép Φ10 – 12; bậc xây gạch cán vữa.</td></tr>
                        <tr style="background:#f4f8fd;"><td style="padding:0.5rem 0.8rem;font-weight:700;color:#1864ab;">Chống thấm</td><td style="padding:0.5rem 0.8rem;">WC, ban công, mái: quét chống thấm gốc xi măng – polymer (Sika / tương đương).</td></tr>
                    </table>
                    <div style="margin-top:14px;background:#fff8ef;border:1px solid #ffd8b0;border-radius:8px;padding:10px 14px;font-size:10pt;color:#b3560a;">
                        <b>Cam kết vật liệu:</b> toàn bộ sắt thép, xi măng, bê tông đúng chủng loại &amp; mác thiết kế, có phiếu xuất kho / chứng chỉ chất lượng khi Khách hàng yêu cầu.
                    </div>
                </div>

                <!-- ============ TRANG 5 — MÁI BẰNG + VẬT TƯ ============ -->
                <div class="page" lang="vi" style="font-family:Georgia,'Times New Roman',serif;color:#23303d;page-break-after:always;">
                    <t t-call="vd_crm_lead.report_vd_quote_full_band"><t t-set="band_title">MÁI BẰNG VÀ VẬT TƯ HOÀN THIỆN</t></t>
                    <div style="font-size:11.5pt;font-weight:700;color:#1864ab;border-left:4px solid #ec7a2a;padding-left:10px;margin-bottom:8px;">Kết cấu mái bằng</div>
                    <ul style="margin:0 0 12px;padding-left:1.2rem;line-height:1.6;font-size:10.5pt;">
                        <li>Mái BTCT đổ toàn khối dày 100 – 120 mm, thép 2 lớp; bê tông MÁC #250 – 300.</li>
                        <li>Chống thấm gốc xi măng – polymer (Sika / Kova); cán nền tạo dốc thoát nước.</li>
