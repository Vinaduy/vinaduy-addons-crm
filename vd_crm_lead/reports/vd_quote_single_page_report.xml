<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Paperformat custom 10x7.5 inch — KHỚP CHÍNH XÁC kích thước các trang
         template PDF VINADUY (720x540pt). page_width > page_height nên đã là
         landscape về mặt dimension; KHÔNG set orientation=Landscape vì sẽ làm
         wkhtmltopdf xoay thêm 90° → trang bị lật ngược. -->
    <record id="paperformat_vd_a4_landscape" model="report.paperformat">
        <field name="name">VD Slide 10x7.5</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">254</field>
        <field name="page_height">190</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">8</field>
        <field name="margin_right">8</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- Single-page báo giá chi tiết — redesign khớp mẫu chuẩn VINADUY.
         Fix UTF-8 encoding (mojibake font tiếng Việt) bằng cách wrap template
         bằng <html><head><meta charset="UTF-8"></head> đầy đủ thay vì
         dùng web.html_container (web.html_container có thể không inject
         charset đúng cho wkhtmltopdf trên 1 số setup). -->
    <record id="action_vd_quote_single_page_report" model="ir.actions.report">
        <field name="name">Báo giá chi tiết (1 trang)</field>
        <field name="model">crm.lead</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">vd_crm_lead.report_vd_quote_single_page</field>
        <field name="report_file">vd_crm_lead.report_vd_quote_single_page</field>
        <field name="paperformat_id" ref="paperformat_vd_a4_landscape"/>
    </record>

    <template id="report_vd_quote_single_page">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="ctx" t-value="o._build_quote_context()"/>
                <!-- Labels lấy từ ctx (đã resolve selection trong Python) — KHÔNG
                     dùng dict(o._fields[...].selection) vì Odoo 18 safe_eval
                     fail "'function' object is not iterable" với dynamic selection. -->
                <t t-set="house_lbl" t-value="ctx.get('house_type') or 'NHÀ DÂN DỤNG'"/>
                <t t-set="found_lbl" t-value="ctx.get('foundation') or 'MÓNG ĐƠN'"/>
                <t t-set="roof_lbl" t-value="ctx.get('roof') or 'Mái'"/>
                <t t-set="addr_parts" t-value="[
                    o.vd_intake_district.name if o.vd_intake_district else '',
                    o.vd_intake_province_id.name if o.vd_intake_province_id else ''
                ]"/>
                <t t-set="addr" t-value="', '.join([p for p in addr_parts if p])"/>
                <t t-set="kh_name" t-value="o.partner_name or o.contact_name or o.name or '—'"/>

                <!-- FORCE UTF-8 trong từng page để wkhtmltopdf đọc đúng encoding -->
                <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
                <meta charset="UTF-8"/>

                <div class="page" lang="vi"
                     style="font-family:Georgia,'Times New Roman','Liberation Serif','DejaVu Serif',Times,serif;color:#23303d;font-size:10pt;padding:0;margin:0;page-break-inside:avoid;">

                    <!-- ============ HEADER theo design mẫu VINADUY chuẩn ============
                         Dùng ảnh logo thật + SVG cho banner & slant -->
                    <div style="position:relative;width:100%;height:90px;margin-bottom:0.4rem;">
                        <!-- Banner XANH + nêm cam (gam màu VINADUY) — sắc nét + tagline. -->
                        <svg width="100%" height="90" viewBox="0 0 1200 90"
                             preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"
                             style="display:block;position:absolute;top:0;left:0;">
                            <defs>
                                <linearGradient id="vd_blue_banner" x1="0%" y1="0%" x2="0%" y2="100%">
                                    <stop offset="0%" stop-color="#a9c4da"/>
                                    <stop offset="50%" stop-color="#4e80ad"/>
                                    <stop offset="100%" stop-color="#a9c4da"/>
                                </linearGradient>
                            </defs>
                            <!-- Dải xanh -->
                            <rect x="170" y="6" width="1030" height="78" fill="url(#vd_blue_banner)"/>
                            <!-- Nêm cam góc phải -->
                            <polygon points="1140,6 1200,6 1200,84 1096,84" fill="#ec7a2a"/>
                            <!-- Tiêu đề -->
                            <text x="685" y="46" text-anchor="middle"
                                  font-family="Georgia,'Times New Roman',serif" font-weight="700" font-size="29"
                                  letter-spacing="6" fill="#ffffff">BẢNG BÁO GIÁ CHI TIẾT</text>
                            <!-- Tagline -->
                            <text x="685" y="69" text-anchor="middle"
                                  font-family="Georgia,'Times New Roman',serif" font-weight="400" font-size="12"
                                  letter-spacing="5" fill="#eef4fa">XÂY NHÀ TRỌN GÓI · KIẾN TẠO TỔ ẤM</text>
                        </svg>
                        <!-- Logo VINADUY thật (data URI base64) đè lên góc trái -->
                        <img t-att-src="ctx.get('logo_data_uri', '')" alt="VINADUY"
                             style="position:absolute;top:16px;left:14px;height:56px;"/>
                    </div>

                    <!-- ============ INTRO BULLETS ============ -->
                    <ul style="padding-left:0.2rem;margin:0.55rem 0 0.7rem;line-height:1.62;font-size:10pt;list-style:none;">
                        <li style="margin-bottom:0.12rem;"><span style="color:#1864ab;font-size:8pt;">&#9670;</span>&#160;&#160;<b style="color:#1864ab;">VINADUY</b> xin gửi tới Quý Khách hàng bảng báo giá chi tiết xây nhà trọn gói nhà ở dân dụng</li>
                        <li style="margin-bottom:0.12rem;"><span style="color:#1864ab;font-size:8pt;">&#9670;</span>&#160;&#160;Bảng báo giá áp dụng với mẫu nhà <b style="color:#c0392b;text-transform:uppercase;letter-spacing:0.6px;"><t t-esc="house_lbl"/></b></li>
                        <li><span style="color:#1864ab;font-size:8pt;">&#9670;</span>&#160;&#160;Kết cấu móng sử dụng hệ <b style="color:#c0392b;text-transform:uppercase;letter-spacing:0.6px;"><t t-esc="found_lbl"/></b></li>
                    </ul>

                    <!-- ============ KHÁCH HÀNG INFO ============ -->
                    <table style="width:62%;border-collapse:collapse;margin:0.55rem 0 0.85rem;font-size:10pt;border-left:3px solid #ec7a2a;">
                        <tr>
                            <td style="padding:0.44rem 0.9rem;background:#eaf1f9;font-weight:700;border-bottom:1px solid #d5e3f1;width:32%;color:#1864ab;text-transform:uppercase;letter-spacing:0.6px;font-size:8.5pt;">Khách hàng</td>
                            <td style="padding:0.44rem 0.9rem;background:#fff;border-bottom:1px solid #d5e3f1;font-weight:600;color:#23303d;"><t t-esc="kh_name"/></td>
                        </tr>
                        <tr>
                            <td style="padding:0.44rem 0.9rem;background:#eaf1f9;font-weight:700;border-bottom:1px solid #d5e3f1;color:#1864ab;text-transform:uppercase;letter-spacing:0.6px;font-size:8.5pt;">Ngày tạo</td>
                            <td style="padding:0.44rem 0.9rem;background:#fff;border-bottom:1px solid #d5e3f1;color:#23303d;"><t t-esc="ctx.get('today', '')"/></td>
                        </tr>
                        <tr>
                            <td style="padding:0.44rem 0.9rem;background:#eaf1f9;font-weight:700;color:#1864ab;text-transform:uppercase;letter-spacing:0.6px;font-size:8.5pt;">Địa chỉ</td>
                            <td style="padding:0.44rem 0.9rem;background:#fff;color:#23303d;"><t t-esc="addr or '—'"/></td>
                        </tr>
                    </table>

                    <!-- ============ PRICING TABLE ============
                         Render INLINE bằng QWeb để không phụ thuộc Html field
                         (t-raw đã bị remove trong Odoo 18). Logic 1:1 với UI
                         panel BÁO GIÁ CHI TIẾT:
                         - Móng: diện tích Tầng 1 × %
                         - Mỗi tầng (Tầng 1, Tầng 2, ..., Tum): area × san_unit
                         - Mái: diện tích tầng trên cùng × %
                         -->
                    <t t-set="floor_rows" t-value="ctx.get('floor_breakdown') or []"/>
                    <t t-set="surcharges" t-value="ctx.get('surcharges') or []"/>
                    <t t-set="km_items" t-value="ctx.get('km_items') or []"/>
                    <t t-set="ps_items" t-value="ctx.get('ps_items') or []"/>
                    <t t-set="num_rows" t-value="2 + max(len(floor_rows), 1) + len(surcharges) + len(km_items) + len(ps_items)"/>
                    <!-- Bảng redesign 2026-07-02: bo góc, header đậm, bỏ lưới dọc
                         (chỉ giữ kẻ ngang nhẹ), sọc so le (zebra) cho dễ đọc, cột
                         tiền in đậm, ô Tổng Tiền nổi bật. wkhtmltopdf: border-radius
                         chạy trên div bọc overflow:hidden. -->
                    <div style="border:1.5px solid #cddff2;border-radius:12px;overflow:hidden;margin-bottom:0.8rem;">
                    <table style="width:100%;border-collapse:collapse;font-size:10pt;">
                        <thead>
                            <tr style="background:#1864ab;color:#fff;">
                                <th style="padding:0.64rem 0.85rem;text-align:left;font-weight:700;letter-spacing:0.7px;text-transform:uppercase;font-size:9.5pt;">Nội dung</th>
                                <th style="padding:0.64rem 0.85rem;text-align:center;font-weight:700;letter-spacing:0.7px;text-transform:uppercase;font-size:9.5pt;">Diện tích</th>
                                <th style="padding:0.64rem 0.85rem;text-align:right;font-weight:700;letter-spacing:0.7px;text-transform:uppercase;font-size:9.5pt;">Đơn giá</th>
                                <th style="padding:0.64rem 0.85rem;text-align:right;font-weight:700;letter-spacing:0.7px;text-transform:uppercase;font-size:9.5pt;">Thành Tiền</th>
                                <th style="padding:0.64rem 0.85rem;text-align:center;font-weight:700;letter-spacing:0.7px;text-transform:uppercase;font-size:9.5pt;background:#12507f;">Tổng Tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Móng — diện tích = Tầng 1 (KHÔNG phải total) -->
                            <tr>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;font-weight:700;color:#16324f;"><t t-esc="found_lbl"/></td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;text-align:center;color:#33475b;"><t t-esc="ctx.get('found_area', '0')"/> M2 x <t t-esc="ctx.get('found_pct', '0')"/>%</td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;text-align:right;color:#55677a;"><t t-esc="ctx.get('unit_price', '0')"/> VNĐ</td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;text-align:right;font-weight:700;color:#16324f;"><t t-esc="ctx.get('found_cost', '0')"/> VNĐ</td>
                                <td t-att-rowspan="num_rows" style="padding:0.55rem 0.7rem;border-left:2px solid #93c5fd;background:#dbeafe;text-align:center;font-weight:800;font-size:14.5pt;color:#1864ab;vertical-align:middle;letter-spacing:0.5px;"><t t-esc="ctx.get('total_price', '0')"/> VNĐ</td>
                            </tr>
                            <!-- Per-floor rows (Tầng 1, Tầng 2, ..., Tum) — zebra theo index -->
                            <t t-if="floor_rows">
                                <t t-foreach="floor_rows" t-as="fr" t-key="fr_index">
                                    <t t-set="rbg" t-value="'#f4f8fd' if (fr_index % 2 == 0) else '#ffffff'"/>
                                    <tr>
                                        <td t-att-style="'padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;font-weight:700;color:#16324f;background:' + rbg"><t t-esc="fr['label']"/></td>
                                        <td t-att-style="'padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:center;color:#33475b;background:' + rbg"><t t-esc="fr['area']"/> M2<t t-if="fr.get('pct')"> x <t t-esc="fr['pct']"/>%</t></td>
                                        <td t-att-style="'padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:right;color:#55677a;background:' + rbg"><t t-esc="ctx.get('unit_price', '0')"/> VNĐ</td>
                                        <td t-att-style="'padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;text-align:right;font-weight:700;color:#16324f;background:' + rbg"><t t-esc="fr['cost']"/> VNĐ</td>
                                    </tr>
                                </t>
                            </t>
                            <t t-else="">
                                <tr>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#f4f8fd;font-weight:700;color:#16324f;">Tổng sàn (<t t-esc="ctx.get('floors', '1')"/> tầng)</td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#f4f8fd;text-align:center;color:#33475b;"><t t-esc="ctx.get('total_floor_area', '0')"/> M2</td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#f4f8fd;text-align:right;color:#55677a;"><t t-esc="ctx.get('unit_price', '0')"/> VNĐ</td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#f4f8fd;text-align:right;font-weight:700;color:#16324f;"><t t-esc="ctx.get('floor_cost', '0')"/> VNĐ</td>
                                </tr>
                            </t>
                            <!-- Mái — diện tích = tầng trên cùng -->
                            <tr>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;font-weight:700;color:#16324f;"><t t-esc="roof_lbl"/></td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;text-align:center;color:#33475b;"><t t-esc="ctx.get('roof_area', '0')"/> M2 x <t t-esc="ctx.get('roof_pct', '0')"/>%</td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;text-align:right;color:#55677a;"><t t-esc="ctx.get('unit_price', '0')"/> VNĐ</td>
                                <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;text-align:right;font-weight:700;color:#16324f;"><t t-esc="ctx.get('roof_cost', '0')"/> VNĐ</td>
                            </tr>
                            <!-- Phát sinh (Thêm WC, cầu thang...) — append sau Mái -->
                            <t t-foreach="surcharges" t-as="sc" t-key="sc_index">
                                <tr>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;font-weight:700;color:#16324f;"><t t-esc="sc['name']"/></td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;text-align:center;color:#33475b;"><t t-esc="sc['qty_label']"/></td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;text-align:right;color:#55677a;"><t t-esc="sc['unit_price']"/> VNĐ</td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #e4eef9;background:#fff;text-align:right;font-weight:700;color:#16324f;"><t t-esc="sc['total']"/> VNĐ</td>
                                </tr>
                            </t>
                            <!-- PHÁT SINH VẬT TƯ — round 12.1. Xanh — CỘNG tiền. -->
                            <t t-foreach="ps_items" t-as="ps" t-key="ps_index">
                                <tr>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #c3f0e2;background:#e6fcf5;font-weight:700;color:#0b7285;">
                                        <t t-esc="ps['label']"/>
                                    </td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #c3f0e2;background:#e6fcf5;text-align:center;color:#0b7285;">—</td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #c3f0e2;background:#e6fcf5;text-align:right;color:#0b7285;">—</td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #c3f0e2;background:#e6fcf5;text-align:right;font-weight:700;color:#0b7285;">
                                        + <t t-esc="ps['amount']"/> VNĐ
                                    </td>
                                </tr>
                            </t>
                            <!-- KHUYẾN MÃI / GIẢM GIÁ — round 12. Vàng — TRỪ tiền. -->
                            <t t-foreach="km_items" t-as="km" t-key="km_index">
                                <tr>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #ffe8a3;background:#fff8e1;font-weight:700;color:#d9480f;">
                                        <t t-esc="km['label']"/>
                                    </td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #ffe8a3;background:#fff8e1;text-align:center;color:#d9480f;">—</td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #ffe8a3;background:#fff8e1;text-align:right;color:#d9480f;">—</td>
                                    <td style="padding:0.5rem 0.85rem;border-bottom:1px solid #ffe8a3;background:#fff8e1;text-align:right;font-weight:700;color:#d9480f;">
                                        − <t t-esc="km['amount']"/> VNĐ
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    </div>

                    <!-- ============ FOOTER theo design mẫu VINADUY chuẩn ============
                         SVG layer: parallelogram + khaki bar + hotline; PNG: dấu mộc thật -->
                    <div style="position:relative;width:100%;height:170px;margin-top:0.9rem;">
                        <svg width="100%" height="170" viewBox="0 0 1200 170"
                             preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"
                             style="display:block;position:absolute;top:0;left:0;">
                            <!-- Panel xanh nhạt -->
                            <polygon points="0,10 540,10 420,132 0,132" fill="#e6eef6"/>
                            <!-- Chỉ khaki đôi -->
                            <rect x="150" y="150" width="1050" height="4" fill="#c9b48a"/>
                            <rect x="150" y="156" width="1050" height="1.1" fill="#c9b48a" opacity="0.55"/>
                            <g transform="translate(30,150)">
                                <path d="M5 0 C2 0 0 2 0 5 C0 18 12 30 25 30 C28 30 30 28 30 25 L30 21 C30 19 28 17 26 17 L21 17 L18 20 C13 17 13 17 10 12 L13 9 L13 4 C13 2 11 0 9 0 Z"
                                      fill="#ec7a2a" transform="scale(0.92) translate(0,-40)"/>
                                <text x="42" y="-20" font-family="Georgia,'Times New Roman',serif"
                                      font-weight="700" font-size="17" fill="#1a1a1a">
                                    1900 9999 46 – 024 99999 868
                                </text>
                                <text x="42" y="-2" font-family="Georgia,'Times New Roman',serif"
                                      font-weight="400" font-size="12" letter-spacing="1.5" fill="#d9480f">
                                    vinaduy.com · Kiến tạo không gian sống đẳng cấp
                                </text>
                            </g>
                        </svg>
                        <!-- Dấu mộc thật (data URI base64) đè lên góc phải -->
                        <img t-att-src="ctx.get('stamp_data_uri', '')" alt="VINADUY Stamp"
                             style="position:absolute;top:8px;right:30px;height:138px;"/>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
