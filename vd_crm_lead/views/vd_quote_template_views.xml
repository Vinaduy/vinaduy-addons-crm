<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         📁 FOLDER TEMPLATE (Category) — gọn, chỉ là folder
         ============================================================ -->
    <record id="view_vd_quote_template_category_tree" model="ir.ui.view">
        <field name="name">vd.quote.template.category.tree</field>
        <field name="model">vd.quote.template.category</field>
        <field name="arch" type="xml">
            <list string="Folder template" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="template_count" readonly="1"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_vd_quote_template_category_form" model="ir.ui.view">
        <field name="name">vd.quote.template.category.form</field>
        <field name="model">vd.quote.template.category</field>
        <field name="arch" type="xml">
            <form string="Folder template">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Vd: BG MB, BG MN, BG - Gói 5T9"/></h1>
                    </div>
                    <group>
                        <field name="description" placeholder="Mô tả ngắn..."/>
                        <field name="sequence"/>
                        <field name="color" widget="color_picker"/>
                        <field name="active"/>
                        <field name="template_count" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vd_quote_template_category" model="ir.actions.act_window">
        <field name="name">Folder template báo giá</field>
        <field name="res_model">vd.quote.template.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============================================================
         📄 TEMPLATE BÁO GIÁ — tag 4 chiều trực tiếp + folder
         ============================================================ -->
    <record id="view_vd_quote_template_search" model="ir.ui.view">
        <field name="name">vd.quote.template.search</field>
        <field name="model">vd.quote.template</field>
        <field name="arch" type="xml">
            <search string="Template báo giá">
                <field name="name" string="Tên / mô tả"
                       filter_domain="['|', ('name','ilike',self), ('description','ilike',self)]"/>
                <field name="category_id"/>
                <field name="region_ids"/>
                <field name="file_name"/>
                <filter string="Đang hoạt động" name="filter_active"
                        domain="[('active','=',True)]"/>
                <filter string="Ngưng dùng" name="filter_inactive"
                        domain="[('active','=',False)]"/>
                <separator/>
                <filter string="Miền Bắc" name="filter_bac"
                        domain="[('region_ids.code','=','bac')]"/>
                <filter string="Miền Trung" name="filter_trung"
                        domain="[('region_ids.code','=','trung')]"/>
                <filter string="Miền Nam" name="filter_nam"
                        domain="[('region_ids.code','=','nam')]"/>
                <group expand="1" string="Nhóm theo">
                    <filter string="Folder" name="groupby_category"
                            context="{'group_by': 'category_id'}"/>
                    <filter string="Vùng miền" name="groupby_region"
                            context="{'group_by': 'region_ids'}"/>
                    <filter string="Loại móng" name="groupby_foundation"
                            context="{'group_by': 'foundation'}"/>
                    <filter string="Loại mái" name="groupby_roof"
                            context="{'group_by': 'roof_simple'}"/>
                    <filter string="Số tầng" name="groupby_floor"
                            context="{'group_by': 'floor_range'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_vd_quote_template_kanban" model="ir.ui.view">
        <field name="name">vd.quote.template.kanban</field>
        <field name="model">vd.quote.template</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category_id"
                    class="o_vd_quote_tpl_kanban"
                    records_draggable="1">
                <field name="id"/>
                <field name="name"/>
                <field name="file_name"/>
                <field name="category_id"/>
                <field name="region_ids"/>
                <field name="foundation"/>
                <field name="roof_simple"/>
                <field name="floor_range"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card_content"
                             style="display:flex;flex-direction:column;gap:0.4rem;padding:0.7rem;">
                            <div style="display:flex;align-items:center;gap:0.5rem;">
                                <i class="fa fa-file-pdf-o" style="color:#dc2626;font-size:1.4rem;"/>
                                <strong style="flex:1;font-size:0.92rem;line-height:1.25;">
                                    <field name="name"/>
                                </strong>
                            </div>
                            <div style="display:flex;gap:0.3rem;flex-wrap:wrap;font-size:0.7rem;">
                                <span t-if="record.floor_range.raw_value"
                                      style="background:#dbeafe;color:#1e40af;padding:0.1rem 0.45rem;border-radius:8px;">
                                    🏢 <field name="floor_range"/>
                                </span>
                                <span t-if="record.foundation.raw_value"
                                      style="background:#fef3c7;color:#92400e;padding:0.1rem 0.45rem;border-radius:8px;">
                                    🧱 <field name="foundation"/>
                                </span>
                                <span t-if="record.roof_simple.raw_value"
                                      style="background:#fee2e2;color:#991b1b;padding:0.1rem 0.45rem;border-radius:8px;">
                                    🏠 <field name="roof_simple"/>
                                </span>
                            </div>
                            <div style="display:flex;gap:0.25rem;flex-wrap:wrap;font-size:0.68rem;">
                                <span t-foreach="record.region_ids.raw_value" t-as="r" t-key="r_index"
                                      style="background:#e0e7ff;color:#3730a3;padding:0.08rem 0.45rem;border-radius:6px;">
                                    📍 <t t-esc="record.region_ids.value[r_index]"/>
                                </span>
                            </div>
                            <div t-if="record.file_name.raw_value"
                                 style="font-size:0.7rem;color:#94a3b8;font-style:italic;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                <field name="file_name"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_vd_quote_template_tree" model="ir.ui.view">
        <field name="name">vd.quote.template.tree</field>
        <field name="model">vd.quote.template</field>
        <field name="arch" type="xml">
            <list string="Template báo giá" default_order="category_id, sequence"
                  class="o_vd_quote_tpl_tree">
                <field name="sequence" widget="handle"/>
                <field name="name" string="📄 Tên file"/>
                <field name="category_id" optional="hide"/>
                <field name="region_ids" widget="many2many_tags" string="Vùng"/>
                <field name="floor_range" string="Tầng" optional="show"/>
                <field name="foundation" string="Móng" optional="show"/>
                <field name="roof_simple" string="Mái" optional="show"/>
                <field name="file_name" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_vd_quote_template_form" model="ir.ui.view">
        <field name="name">vd.quote.template.form</field>
        <field name="model">vd.quote.template</field>
        <field name="arch" type="xml">
            <form string="Template báo giá">
                <header>
                    <button name="action_create_placeholder_version" type="object"
                            class="btn-primary"
                            string="🔧 Tạo placeholder (cho file Lệ Chi)"
                            invisible="not file_attachment"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Vd: 1TĐơn - Mái Bằng"/></h1>
                    </div>
                    <group>
                        <group string="📁 Folder + File">
                            <field name="category_id"
                                   options="{'no_create': False, 'no_create_edit': False}"
                                   placeholder="— Chọn folder (BG MB / BG MN / Gói 5T9) —"/>
                            <field name="file_attachment" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                        <group string="🏷 Tag phân loại (auto-filter trên lead)">
                            <field name="region_ids" widget="many2many_tags"
                                   options="{'no_create': True, 'color_field': 'color'}"
                                   placeholder="— Chọn vùng (có thể nhiều) —"/>
                            <field name="floor_range"/>
                            <field name="foundation"/>
                            <field name="roof_simple"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Áp dụng cho loại nhà nào, vùng nào..."/>
                        <field name="quote_page_index"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <b>🏷 Tag để auto-filter:</b> Khi NV chọn intake (vùng/tầng/móng/mái) ở form Lead,
                        dropdown template tự lọc các file có tag match. Tag rỗng = template "chung", luôn hiện.
                    </div>

                    <separator string="📝 Ghi chú nội bộ"/>
                    <field name="note" placeholder="Lưu ý khi sử dụng template này..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vd_quote_template" model="ir.actions.act_window">
        <field name="name">Template báo giá</field>
        <field name="res_model">vd.quote.template</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_groupby_category': 1, 'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Upload các file template báo giá (.docx/.xlsx/.pdf/.png...).</p>
            <p>Mặc định view cây thư mục — gom theo folder, click vào folder để xem files bên trong.</p>
        </field>
    </record>

</odoo>
