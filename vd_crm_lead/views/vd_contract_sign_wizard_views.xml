<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vd_contract_sign_wizard_form" model="ir.ui.view">
        <field name="name">vd.contract.sign.wizard.form</field>
        <field name="model">vd.contract.sign.wizard</field>
        <field name="arch" type="xml">
            <form string="Ký hợp đồng + nhận cọc">
                <field name="lead_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>

                <div class="alert alert-success" role="alert" style="margin-bottom:0.85rem;">
                    <i class="fa fa-trophy"/>
                    Ký HĐ với <b><field name="lead_name" readonly="1" nolabel="1"/></b><br/>
                    💰 Giá báo: <field name="quote_price_display" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1" nolabel="1"/>
                </div>

                <div class="alert alert-warning" role="alert" style="margin-bottom:0.85rem;">
                    <b>⚠️ Quy định:</b> Tiền cọc <b>TỐI THIỂU 50.000.000đ</b>.<br/>
                    <i>Kịch bản: "Anh/chị ơi, để bên em chính thức giữ chỗ + đặt vật liệu +
                    lên kế hoạch tổ thợ thì cần cọc tối thiểu 50tr theo quy định công ty..."</i>
                </div>

                <group>
                    <group>
                        <field name="sign_date"/>
                        <field name="deposit_amount" widget="monetary"
                               options="{'currency_field': 'currency_id'}"/>
                        <field name="deposit_method" widget="radio"/>
                    </group>
                </group>
                <separator string="Ghi chú nhận cọc"/>
                <field name="deposit_note" placeholder="Số tài khoản KH chuyển từ, mã giao dịch..."/>

                <footer>
                    <button name="action_confirm_sign" type="object" string="✓ Xác nhận ký HĐ"
                            class="btn-success"/>
                    <button special="cancel" string="Đóng" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
