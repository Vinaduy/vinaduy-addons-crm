<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vd_contract_sign_wizard_form" model="ir.ui.view">
        <field name="name">vd.contract.sign.wizard.form</field>
        <field name="model">vd.contract.sign.wizard</field>
        <field name="arch" type="xml">
            <form string="Đặt lịch ký hợp đồng" class="o_vd_sign_wizard">
                <field name="lead_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>

                <!-- Header: KH info + giá báo -->
                <div class="o_vd_sign_header">
                    <div class="o_vd_sign_header_icon">📅</div>
                    <div class="o_vd_sign_header_body">
                        <div class="o_vd_sign_header_title">Đặt lịch đi ký hợp đồng</div>
                        <div class="o_vd_sign_header_sub">
                            KH: <b><field name="lead_name" readonly="1" nolabel="1"/></b>
                            <span class="o_vd_sign_price">
                                💰 <field name="quote_price_display" widget="monetary"
                                          options="{'currency_field': 'currency_id'}"
                                          readonly="1" nolabel="1"/>
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Form body -->
                <div class="o_vd_sign_body">
                    <div class="o_vd_sign_field">
                        <label for="sign_date">
                            <span>🗓️</span> Ngày &amp; giờ đi ký
                        </label>
                        <field name="sign_date" nolabel="1" widget="datetime"/>
                    </div>

                    <div class="o_vd_sign_field">
                        <label for="sign_location">
                            <span>📍</span> Địa điểm
                        </label>
                        <field name="sign_location" nolabel="1"
                               placeholder="Vd: Nhà KH / VP VINADUY / Quán cafe..."/>
                    </div>

                    <div class="o_vd_sign_field">
                        <label for="sign_note">
                            <span>📝</span> Ghi chú lịch hẹn
                        </label>
                        <field name="sign_note" nolabel="1"
                               placeholder="Vd: KH yêu cầu mang theo bản vẽ chi tiết, hẹn 14h-15h..."/>
                    </div>
                </div>

                <footer>
                    <button name="action_schedule_sign" type="object"
                            string="✓ Đặt lịch ngay"
                            class="btn-primary o_vd_sign_btn_confirm"/>
                    <button special="cancel" string="Huỷ" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
