<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vd_lead_quick_add_wizard_form" model="ir.ui.view">
        <field name="name">vd.lead.quick.add.wizard.form</field>
        <field name="model">vd.lead.quick.add.wizard</field>
        <field name="arch" type="xml">
            <form string="Thêm KH mới (nhập nhiều)">
                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;flex-wrap:wrap;">
                    <div class="alert alert-info" role="alert" style="margin:0;flex:1;min-width:280px;">
                        <b>💡 Mẹo:</b> Bấm <b>⋮</b> header bảng để hiện/ẩn cột. Gõ ô bên phải để thêm cột mới.
                        <br/><b>📋 Paste Excel:</b> Copy nhiều dòng từ Excel rồi paste (Ctrl+V) vào ô bất kỳ — tự fill cả bảng.
                    </div>
                    <div groups="vd_crm_lead.vd_crm_group_admin"
                         style="display:flex;align-items:center;gap:0.4rem;min-width:260px;">
                        <field name="quick_add_field_id" nolabel="1"
                               options="{'no_open': True}"
                               placeholder="Gõ tên cột mới + Enter..."
                               style="min-width:260px;"/>
                    </div>
                </div>
                <field name="line_ids" nolabel="1">
                    <list editable="bottom" string="Danh sách KH cần thêm">
                        <field name="sequence" widget="handle"/>
                        <field name="name" placeholder="Tên KH"/>
                        <field name="phone" placeholder="0901..." widget="phone"/>
                        <field name="source" widget="vd_selection_dropdown" options="{'extensible': True}"/>
                        <field name="date"/>
                        <field name="status" widget="vd_selection_dropdown"/>
                        <field name="user_id"
                               options="{'no_create': True, 'no_open': True}"
                               placeholder="(Auto)"/>
                        <!-- Intake mirror columns — admin bật/tắt qua ⋮ dropdown -->
                        <field name="i_house_type" optional="hide" widget="vd_selection_dropdown" options="{'extensible': True}"/>
                        <field name="i_foundation_type" optional="hide" widget="vd_selection_dropdown" options="{'extensible': True}"/>
                        <field name="i_floors_select" optional="hide" widget="vd_selection_dropdown"/>
                        <field name="i_area_m2" optional="hide"/>
                        <field name="i_floor_1_m2" optional="hide"/>
                        <field name="i_floor_2_m2" optional="hide"/>
                        <field name="i_floor_3_m2" optional="hide"/>
                        <field name="i_floor_4_m2" optional="hide"/>
                        <field name="i_floor_5_m2" optional="hide"/>
                        <field name="i_floor_6_m2" optional="hide"/>
                        <field name="i_floor_7_m2" optional="hide"/>
                        <field name="i_floor_tum_m2" optional="hide"/>
                        <field name="i_province_id" optional="hide"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="i_district" optional="hide"
                               domain="[('state_id', '=', i_province_id)]"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="i_dimensions" optional="hide" widget="vd_selection_dropdown" options="{'extensible': True}"/>
                        <field name="i_land_type" optional="hide" widget="vd_selection_dropdown" options="{'extensible': True}"/>
                        <field name="i_car_access_select" optional="hide" widget="vd_selection_dropdown"/>
                        <field name="i_budget_amount" optional="hide"/>
                        <!-- 5 cột tuỳ chọn — label dynamic từ vd.intake.custom.field
                             Admin tạo trường mới qua input "+ Thêm cột" trên header. -->
                        <field name="extra_1" optional="hide"/>
                        <field name="extra_2" optional="hide"/>
                        <field name="extra_3" optional="hide"/>
                        <field name="extra_4" optional="hide"/>
                        <field name="extra_5" optional="hide"/>
                        <field name="extra_6" optional="hide"/>
                        <field name="extra_7" optional="hide"/>
                        <field name="extra_8" optional="hide"/>
                        <field name="extra_9" optional="hide"/>
                        <field name="extra_10" optional="hide"/>
                    </list>
                </field>
                <footer>
                    <button name="action_create_leads" type="object"
                            string="💾 Tạo tất cả"
                            class="btn-primary"/>
                    <button special="cancel" string="Huỷ" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vd_lead_quick_add_wizard" model="ir.actions.act_window">
        <field name="name">➕ Thêm KH mới</field>
        <field name="res_model">vd.lead.quick.add.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_line_ids': [(0, 0, {}), (0, 0, {}), (0, 0, {})], 'dialog_size': 'fullscreen'}</field>
    </record>
</odoo>
