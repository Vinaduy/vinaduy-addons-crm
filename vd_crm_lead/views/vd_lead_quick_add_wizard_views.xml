<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vd_lead_quick_add_wizard_form" model="ir.ui.view">
        <field name="name">vd.lead.quick.add.wizard.form</field>
        <field name="model">vd.lead.quick.add.wizard</field>
        <field name="arch" type="xml">
            <form string="Thêm KH mới (nhập nhiều)">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem;gap:0.5rem;flex-wrap:wrap;">
                    <div class="alert alert-info" role="alert" style="margin:0;flex:1;min-width:300px;">
                        <b>💡 Mẹo:</b> Nhập từng dòng = 1 KH. Tab/Enter để xuống dòng kế.
                    </div>
                    <!-- Dropdown chọn / quick-create cột tuỳ chọn inline (không sang trang khác) -->
                    <div groups="vd_crm_lead.vd_crm_group_admin"
                         style="display:flex;align-items:center;gap:0.4rem;min-width:280px;">
                        <field name="quick_add_field_id" nolabel="1" string="➕ Thêm cột"
                               options="{'no_open': True}"
                               placeholder="Gõ tên cột mới + Enter, hoặc chọn từ list..."
                               style="min-width:280px;"/>
                    </div>
                </div>
                <field name="line_ids" nolabel="1">
                    <list editable="bottom" string="Danh sách KH cần thêm">
                        <field name="sequence" widget="handle"/>
                        <field name="name" placeholder="Tên KH"/>
                        <field name="phone" placeholder="0901..." widget="phone"/>
                        <field name="source"/>
                        <field name="date"/>
                        <field name="status"/>
                        <field name="user_id"
                               options="{'no_create': True, 'no_open': True}"
                               placeholder="(Auto)"/>
                        <!-- 5 cột tuỳ chọn — label dynamic từ vd.intake.custom.field
                             Cột nào không config sẽ hiện tên mặc định "Tuỳ chọn N"
                             nhưng vẫn editable; chỉ cột có config mới lưu giá trị. -->
                        <field name="extra_1" optional="show"/>
                        <field name="extra_2" optional="hide"/>
                        <field name="extra_3" optional="hide"/>
                        <field name="extra_4" optional="hide"/>
                        <field name="extra_5" optional="hide"/>
                    </list>
                </field>
                <footer>
                    <button name="action_create_leads" type="object"
                            string="💾 Tạo tất cả"
                            class="btn-primary"/>
                    <button special="cancel" string="Huỷ" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vd_lead_quick_add_wizard" model="ir.actions.act_window">
        <field name="name">➕ Thêm KH mới</field>
        <field name="res_model">vd.lead.quick.add.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_line_ids': [(0, 0, {}), (0, 0, {}), (0, 0, {})]}</field>
    </record>
</odoo>
