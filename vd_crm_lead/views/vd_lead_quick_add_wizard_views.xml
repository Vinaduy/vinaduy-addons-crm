<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vd_lead_quick_add_wizard_form" model="ir.ui.view">
        <field name="name">vd.lead.quick.add.wizard.form</field>
        <field name="model">vd.lead.quick.add.wizard</field>
        <field name="arch" type="xml">
            <form string="Thêm KH mới (nhập nhiều)">
                <div class="alert alert-info" role="alert" style="margin:0 0 0.5rem 0;">
                    <b>💡 Mẹo:</b> Nhập từng dòng = 1 KH. Tab/Enter để xuống dòng kế.
                    Bấm <b>⋮</b> ở góc phải header bảng để thêm cột intake (Loại móng, Kiểu nhà, Tầng 1, Tỉnh...).
                </div>
                <field name="line_ids" nolabel="1">
                    <list editable="bottom" string="Danh sách KH cần thêm">
                        <field name="sequence" widget="handle"/>
                        <field name="name" placeholder="Tên KH"/>
                        <field name="phone" placeholder="0901..." widget="phone"/>
                        <field name="source"/>
                        <field name="date"/>
                        <field name="status"/>
                        <field name="user_id"
                               options="{'no_create': True, 'no_open': True}"
                               placeholder="(Auto)"/>
                        <!-- Intake mirror columns — admin bật/tắt qua ⋮ dropdown -->
                        <field name="i_house_type" optional="hide"/>
                        <field name="i_foundation_type" optional="hide"/>
                        <field name="i_floors_select" optional="hide"/>
                        <field name="i_area_m2" optional="hide"/>
                        <field name="i_floor_1_m2" optional="hide"/>
                        <field name="i_floor_2_m2" optional="hide"/>
                        <field name="i_floor_3_m2" optional="hide"/>
                        <field name="i_floor_4_m2" optional="hide"/>
                        <field name="i_floor_5_m2" optional="hide"/>
                        <field name="i_floor_6_m2" optional="hide"/>
                        <field name="i_floor_7_m2" optional="hide"/>
                        <field name="i_floor_tum_m2" optional="hide"/>
                        <field name="i_province_id" optional="hide"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="i_district" optional="hide"
                               domain="[('state_id', '=', i_province_id)]"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="i_dimensions" optional="hide"/>
                        <field name="i_land_type" optional="hide"/>
                        <field name="i_car_access_select" optional="hide"/>
                        <field name="i_budget_amount" optional="hide"/>
                    </list>
                </field>
                <footer>
                    <button name="action_create_leads" type="object"
                            string="💾 Tạo tất cả"
                            class="btn-primary"/>
                    <button special="cancel" string="Huỷ" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vd_lead_quick_add_wizard" model="ir.actions.act_window">
        <field name="name">➕ Thêm KH mới</field>
        <field name="res_model">vd.lead.quick.add.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_line_ids': [(0, 0, {}), (0, 0, {}), (0, 0, {})]}</field>
    </record>
</odoo>
