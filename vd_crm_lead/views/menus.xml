<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         2 menu top-level: Kiểm soát KH + Kiểm soát NV
         Cùng action class nhưng khác context.vd_focus → component tự
         render section tương ứng.
         ============================================================ -->
    <menuitem id="menu_vd_crm_dashboard_customers"
              name="Kiểm soát khách hàng"
              parent="crm.crm_menu_root"
              action="action_vd_crm_dashboard_customers"
              sequence="1"/>

    <menuitem id="menu_vd_crm_dashboard_employees"
              name="Kiểm soát nhân viên"
              parent="crm.crm_menu_root"
              action="action_vd_crm_dashboard_employees"
              sequence="2"/>

    <!-- ⚙️ Cấu hình → Đơn giá xây dựng (chỉ admin / sales manager) -->
    <menuitem id="menu_vd_pricing_region"
              name="Đơn giá xây dựng"
              parent="crm.crm_menu_config"
              action="action_vd_pricing_region"
              sequence="50"
              groups="sales_team.group_sale_manager"/>

    <!-- ⚙️ Cấu hình → Template báo giá -->
    <menuitem id="menu_vd_quote_template"
              name="Template báo giá"
              parent="crm.crm_menu_config"
              action="action_vd_quote_template"
              sequence="55"
              groups="sales_team.group_sale_manager"/>

    <!-- ⚙️ Cấu hình → Nhóm template báo giá (Mái Nhật / Mái Thái / Miền Bắc...) -->
    <menuitem id="menu_vd_quote_template_category"
              name="Nhóm template báo giá"
              parent="crm.crm_menu_config"
              action="action_vd_quote_template_category"
              sequence="56"
              groups="sales_team.group_sale_manager"/>
</odoo>
