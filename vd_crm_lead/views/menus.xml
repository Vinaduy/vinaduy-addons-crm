<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1 menu top-level "Dashboard NV" — focus KH/NV switch ở sidebar dọc bên trong -->
    <menuitem id="menu_vd_crm_dashboard"
              name="Dashboard NV"
              parent="crm.crm_menu_root"
              action="action_vd_crm_dashboard"
              sequence="1"/>

    <!-- ⚙️ Cấu hình → Đơn giá xây dựng (chỉ admin / sales manager) -->
    <menuitem id="menu_vd_pricing_region"
              name="Đơn giá xây dựng"
              parent="crm.crm_menu_config"
              action="action_vd_pricing_region"
              sequence="50"
              groups="sales_team.group_sale_manager"/>

    <!-- ⚙️ Cấu hình → Template báo giá (gộp luôn quản lý Nhóm bên trong) -->
    <menuitem id="menu_vd_quote_template"
              name="Template báo giá"
              parent="crm.crm_menu_config"
              action="action_vd_quote_template"
              sequence="55"
              groups="sales_team.group_sale_manager"/>
    <!-- Menu Nhóm template báo giá đã xoá — quản lý nhóm qua nút trong list
         Template hoặc tạo nhanh từ Many2one dropdown khi thêm template. -->

    <!-- ⚙️ Cấu hình → Cài đặt người dùng (ngày bắt đầu + năng lực + chỉ tiêu) -->
    <menuitem id="menu_vd_users_settings"
              name="Cài đặt người dùng"
              parent="crm.crm_menu_config"
              action="action_vd_users_settings"
              sequence="60"
              groups="sales_team.group_sale_manager"/>

    <!-- ⚙️ Cấu hình → Kho số tổng đài (danh sách thô) — ĐÃ ẨN (user spec 2026-06-09):
         dùng "Chia số cho nhân viên" (bảng kéo-thả) làm màn CHÍNH thay danh sách này.
         Action vd_stringee.action_vd_stringee_hotline vẫn còn (vào bằng URL khi cần
         thêm số mới). -->
    <!--
    <menuitem id="menu_vd_hotline_pool"
              name="Kho số tổng đài"
              parent="crm.crm_menu_config"
              action="vd_stringee.action_vd_stringee_hotline"
              sequence="62"
              groups="sales_team.group_sale_manager"/>
    -->

    <!-- ⚙️ Cấu hình → Kho số tổng đài (bảng kéo-thả gán số theo NV).
         User spec 2026-06-09: gộp về 1 menu — đổi tên "Chia số cho nhân viên"
         thành "Kho số tổng đài", bỏ menu danh sách thô trùng ở trên. -->
    <menuitem id="menu_vd_assign_numbers"
              name="Kho số tổng đài"
              parent="crm.crm_menu_config"
              action="vd_stringee.action_vd_stringee_board"
              sequence="62"
              groups="sales_team.group_sale_manager"/>

    <!-- ⚙️ Cấu hình → Cài đặt khoá (3 bảng: Khách mới / Thi công gấp / Xử lý vấn đề) -->
    <menuitem id="menu_vd_crm_config_settings"
              name="Cài đặt khoá"
              parent="crm.crm_menu_config"
              action="action_vd_crm_config_settings"
              sequence="64"
              groups="sales_team.group_sale_manager"/>
</odoo>
