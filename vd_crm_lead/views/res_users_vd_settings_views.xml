<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ INHERIT FORM Người dùng — thêm Phòng ban + Cài đặt CRM ============ -->
    <record id="view_users_form_vd_crm" model="ir.ui.view">
        <field name="name">res.users.form.vd.crm</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- Chèn vào sau email (top form), trước notebook tabs.
                 User spec 2026-06-13: gọn gàng, đóng khung, bỏ helper/tooltip thừa.
                 Phòng ban = thẻ chọn được (đổi thẻ = chuyển phòng ban). -->
            <xpath expr="//field[@name='email']" position="after">
                <group string="Phòng ban và Cài đặt CRM" name="vd_crm_user_settings" col="2">
                    <group>
                        <field name="vd_team" string="Phòng ban"
                               widget="radio" options="{'horizontal': true}" help=""/>
                        <field name="vd_crm_role" string="Phân quyền" help=""/>
                    </group>
                    <group>
                        <field name="vd_work_start_date" string="Ngày bắt đầu làm việc" help=""/>
                        <field name="vd_work_months" string="Số tháng làm việc" help=""/>
                        <field name="vd_target_month" string="Chỉ tiêu HĐ/tháng" help=""/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- User spec 2026-06-13: list + action tùy biến "Cài đặt thông tin NV" đã
         BỎ — menu Cấu hình → Cài đặt người dùng giờ trỏ thẳng base.action_res_users
         (màn Người dùng chuẩn) để chỉ còn 1 thiết kế. Chỉ giữ form inherit ở trên. -->
</odoo>
