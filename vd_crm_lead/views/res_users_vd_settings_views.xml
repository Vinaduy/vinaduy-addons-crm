<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ LIST: Cài đặt NV — ngày bắt đầu + năng lực ============ -->
    <record id="view_vd_users_settings_list" model="ir.ui.view">
        <field name="name">res.users.vd.settings.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="Cài đặt thông tin NV" create="false" delete="false" editable="bottom">
                <field name="name" readonly="1"/>
                <field name="login" readonly="1"/>
                <field name="sale_team_id" string="Team" readonly="1"/>
                <field name="vd_work_start_date" string="📅 Ngày bắt đầu"/>
                <field name="vd_work_months" string="📊 Số tháng" readonly="1"/>
                <field name="vd_capacity_level" string="⭐ Năng lực" widget="badge"/>
                <field name="vd_target_month" string="🎯 Chỉ tiêu/tháng"/>
            </list>
        </field>
    </record>

    <record id="action_vd_users_settings" model="ir.actions.act_window">
        <field name="name">⚙️ Cài đặt thông tin NV</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_vd_users_settings_list"/>
        <field name="domain">[('share', '=', False), ('active', '=', True), ('groups_id', 'in', [ref('sales_team.group_sale_salesman')])]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Cài đặt thông tin từng NV</p>
            <p>Set ngày bắt đầu làm việc + năng lực. Click trực tiếp vào ô để chỉnh.</p>
        </field>
    </record>
</odoo>
