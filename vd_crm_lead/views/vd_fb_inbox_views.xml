<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ APP CONFIG ============ -->
    <record id="view_vd_fb_app_form" model="ir.ui.view">
        <field name="name">vd.fb.app.form</field>
        <field name="model">vd.fb.app</field>
        <field name="arch" type="xml">
            <form string="Facebook App">
                <header>
                    <button name="action_rotate_verify_token" type="object"
                            string="Sinh lại Verify Token" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tên App"/></h1>
                    </div>
                    <group>
                        <group string="Thông tin App (Meta)">
                            <field name="app_id"/>
                            <field name="app_secret" password="True"/>
                            <field name="graph_version"/>
                            <field name="active"/>
                        </group>
                        <group string="Webhook (dán vào Meta)">
                            <field name="webhook_url" readonly="1"/>
                            <field name="verify_token" readonly="1"/>
                        </group>
                    </group>
                    <field name="page_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="fb_page_id"/>
                            <field name="platform"/>
                            <field name="page_access_token" password="True"/>
                            <field name="auto_create_lead"/>
                            <field name="team_id"/>
                            <button name="action_subscribe_page" type="object"
                                    string="Đăng ký webhook" icon="fa-bell"
                                    help="Đăng ký page nhận tin nhắn + bình luận"/>
                            <button name="action_check_token" type="object"
                                    string="Kiểm tra token" icon="fa-search"
                                    help="Soát quyền token + subscribe feed"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vd_fb_app" model="ir.actions.act_window">
        <field name="name">Kết nối Facebook</field>
        <field name="res_model">vd.fb.app</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============ PAGE ============ -->
    <record id="view_vd_fb_page_form" model="ir.ui.view">
        <field name="name">vd.fb.page.form</field>
        <field name="model">vd.fb.page</field>
        <field name="arch" type="xml">
            <form string="Fanpage">
                <header>
                    <button name="action_subscribe_page" type="object"
                            string="🔔 Đăng ký nhận tin nhắn + bình luận"
                            class="btn-primary"
                            help="Đăng ký fanpage với App để Meta đẩy webhook về. Bấm sau khi đã dán Page Access Token."/>
                    <button name="action_check_token" type="object"
                            string="🔍 Kiểm tra token"
                            class="btn-secondary"
                            help="Soát Page Token: xem có đủ quyền (messaging/read_engagement/manage_engagement/metadata) và đã subscribe field 'feed' (bình luận) chưa"/>
                    <button name="action_pull_comments" type="object"
                            string="🔄 Tải bình luận mới"
                            class="btn-secondary"
                            help="Quét bình luận mới qua Graph API (dùng khi Dev mode chưa có webhook feed). Cron cũng tự quét mỗi 2 phút."/>
                    <button name="action_create_test_conversation" type="object"
                            string="🧪 Tạo hội thoại thử nghiệm"
                            class="btn-secondary" groups="vd_crm_lead.vd_crm_group_admin"
                            help="[TEST] Tạo hội thoại giả + tin khách để thử cửa sổ chat trước khi quay video"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_conversations" type="object"
                                class="oe_stat_button" icon="fa-comments">
                            <field name="conversation_count" widget="statinfo" string="Hội thoại"/>
                        </button>
                    </div>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="fb_page_id"/>
                            <field name="platform"/>
                            <field name="app_id"/>
                        </group>
                        <group>
                            <field name="page_access_token" password="True"/>
                            <field name="auto_create_lead"/>
                            <field name="team_id"/>
                            <field name="last_event_at" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============ CONVERSATION (inbox) ============ -->
    <record id="view_vd_fb_conversation_list" model="ir.ui.view">
        <field name="name">vd.fb.conversation.list</field>
        <field name="model">vd.fb.conversation</field>
        <field name="arch" type="xml">
            <list string="Hội thoại" default_order="last_message_at desc">
                <field name="kind" widget="badge"
                       decoration-info="kind == 'message'" decoration-warning="kind == 'comment'"/>
                <field name="customer_name"/>
                <field name="platform"/>
                <field name="snippet"/>
                <field name="lead_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="unread"/>
                <field name="last_message_at"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'" decoration-info="state == 'open'"/>
            </list>
        </field>
    </record>

    <record id="view_vd_fb_conversation_form" model="ir.ui.view">
        <field name="name">vd.fb.conversation.form</field>
        <field name="model">vd.fb.conversation</field>
        <field name="arch" type="xml">
            <form string="Hội thoại" class="vd_fb_chat_form">
                <header>
                    <button name="action_refresh" type="object" string="🔄 Tải lại"
                            class="btn-secondary"
                            help="Hứng tin nhắn mới khách vừa gửi (không cần F5 cả trang)"/>
                    <button name="action_mark_read" type="object" string="Đánh dấu đã đọc"
                            invisible="unread == 0"/>
                    <button name="action_mark_done" type="object" string="Xong"
                            invisible="state == 'done'"/>
                    <button name="action_simulate_inbound" type="object" string="🧪 Giả lập tin khách"
                            class="btn-secondary" groups="vd_crm_lead.vd_crm_group_admin"
                            help="[TEST] Tạo 1 tin khách giả để thử cửa sổ chat — không gửi gì ra Facebook"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <!-- Header hội thoại kiểu Messenger -->
                    <div class="vd_fb_chat_head">
                        <div class="vd_fb_avatar"><i class="fa fa-user"/></div>
                        <div class="vd_fb_head_info">
                            <span class="vd_fb_head_name"><field name="customer_name" nolabel="1" readonly="1"/></span>
                            <span class="vd_fb_head_sub">
                                <field name="platform" nolabel="1" readonly="1"/> ·
                                <field name="page_id" nolabel="1" readonly="1"/>
                            </span>
                        </div>
                    </div>

                    <!-- Thông tin gắn KH CRM (gọn) -->
                    <group col="4">
                        <field name="lead_id"/>
                        <field name="user_id" widget="many2one_avatar_user"/>
                        <field name="last_inbound_at" readonly="1"/>
                        <field name="unread" readonly="1"/>
                    </group>

                    <!-- Khung tin nhắn — bong bóng chat -->
                    <field name="message_ids" mode="kanban" nolabel="1" readonly="1" class="vd_fb_stream">
                        <kanban class="vd_fb_chat_kanban" create="false" edit="false"
                                records_draggable="0" default_order="sent_at">
                            <field name="direction"/>
                            <field name="body"/>
                            <field name="sent_at"/>
                            <field name="attachment_url"/>
                            <field name="attachment_type"/>
                            <field name="send_error"/>
                            <templates>
                                <t t-name="kanban-box">
                                    <div t-attf-class="vd_fb_row #{record.direction.raw_value == 'out' ? 'vd_fb_row_out' : 'vd_fb_row_in'}">
                                        <div t-attf-class="vd_fb_bubble #{record.direction.raw_value == 'out' ? 'vd_fb_bubble_out' : 'vd_fb_bubble_in'}">
                                            <span class="vd_fb_text"><field name="body"/></span>
                                            <div class="vd_fb_att" t-if="record.attachment_url.raw_value">
                                                <a t-att-href="record.attachment_url.raw_value" target="_blank">📎 Xem đính kèm</a>
                                            </div>
                                            <div class="vd_fb_meta">
                                                <field name="sent_at" widget="datetime"/>
                                                <t t-if="record.send_error.raw_value"> · <span class="text-danger">⚠ lỗi gửi</span></t>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>

                    <!-- Thanh soạn tin + nút Gửi -->
                    <div class="vd_fb_composer">
                        <field name="reply_text" nolabel="1"
                               placeholder="Nhập tin nhắn trả lời khách rồi bấm Gửi..."/>
                        <button name="action_send_reply" type="object" string="Gửi ➤"
                                class="btn-primary vd_fb_send"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vd_fb_conversation" model="ir.actions.act_window">
        <field name="name">Hộp thư hội thoại</field>
        <field name="res_model">vd.fb.conversation</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Giao diện chat kiểu Pancake (client action OWL 3 cột) -->
    <record id="action_vd_fb_chat" model="ir.actions.client">
        <field name="name">Hộp thư chat</field>
        <field name="tag">vd_crm_lead.fb_chat</field>
    </record>

    <!-- ============ COMMENT ============ -->
    <record id="view_vd_fb_comment_list" model="ir.ui.view">
        <field name="name">vd.fb.comment.list</field>
        <field name="model">vd.fb.comment</field>
        <field name="arch" type="xml">
            <list string="Bình luận">
                <field name="created_time"/>
                <field name="from_name"/>
                <field name="body"/>
                <field name="lead_id"/>
                <field name="replied" widget="boolean_toggle"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_vd_fb_comment_form" model="ir.ui.view">
        <field name="name">vd.fb.comment.form</field>
        <field name="model">vd.fb.comment</field>
        <field name="arch" type="xml">
            <form string="Bình luận">
                <header>
                    <button name="action_send_reply" type="object" string="📤 Trả lời bình luận"
                            class="btn-primary" invisible="not reply_text"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="from_name"/>
                            <field name="created_time"/>
                            <field name="page_id"/>
                        </group>
                        <group>
                            <field name="lead_id"/>
                            <field name="replied"/>
                            <field name="post_id"/>
                        </group>
                    </group>
                    <separator string="Nội dung bình luận"/>
                    <field name="body" readonly="1"/>
                    <separator string="Trả lời"/>
                    <field name="reply_text" placeholder="Nhập trả lời bình luận..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Bình luận = hội thoại kind='comment' (đã gộp inbox 2026-06-13) -->
    <record id="action_vd_fb_comment" model="ir.actions.act_window">
        <field name="name">Bình luận</field>
        <field name="res_model">vd.fb.conversation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('kind', '=', 'comment')]</field>
        <field name="context">{'default_kind': 'comment'}</field>
    </record>

    <!-- ============ MENU ============ -->
    <menuitem id="menu_vd_fb_root" name="Hộp thư FB/TikTok"
              parent="vd_crm_lead.menu_vd_crm_dashboard" sequence="25"/>
    <menuitem id="menu_vd_fb_chat" name="Chat (Pancake)"
              parent="menu_vd_fb_root" action="action_vd_fb_chat" sequence="5"/>
    <menuitem id="menu_vd_fb_inbox" name="Hội thoại (bảng)"
              parent="menu_vd_fb_root" action="action_vd_fb_conversation" sequence="10"/>
    <menuitem id="menu_vd_fb_comments" name="Bình luận"
              parent="menu_vd_fb_root" action="action_vd_fb_comment" sequence="20"/>
    <menuitem id="menu_vd_fb_app" name="Kết nối Facebook"
              parent="menu_vd_fb_root" action="action_vd_fb_app" sequence="90"
              groups="vd_crm_lead.vd_crm_group_admin"/>

</odoo>
