<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         CLIENT ACTIONS — cùng tag "vd_crm_lead.dashboard", chỉ khác
         context.vd_focus để component render section phù hợp.
         ============================================================ -->

    <!-- Kiểm soát khách hàng: focus='customers' → ẩn section NV performance,
         giữ 🚨 KH urgent + 📊 pipeline + 🎯 KH insight -->
    <record id="action_vd_crm_dashboard_customers" model="ir.actions.client">
        <field name="name">Kiểm soát khách hàng</field>
        <field name="tag">vd_crm_lead.dashboard</field>
        <field name="context">{"vd_focus": "customers"}</field>
    </record>

    <!-- Kiểm soát nhân viên: focus='employees' → ẩn KH urgent + KH insight,
         giữ 🚨 NV idle + 🏆 hiệu suất NV + thành tích leaderboard -->
    <record id="action_vd_crm_dashboard_employees" model="ir.actions.client">
        <field name="name">Kiểm soát nhân viên</field>
        <field name="tag">vd_crm_lead.dashboard</field>
        <field name="context">{"vd_focus": "employees"}</field>
    </record>

    <!-- Legacy action: giữ lại cho bookmark cũ + NV personal view -->
    <record id="action_vd_crm_dashboard" model="ir.actions.client">
        <field name="name">Dashboard NV</field>
        <field name="tag">vd_crm_lead.dashboard</field>
    </record>
</odoo>
