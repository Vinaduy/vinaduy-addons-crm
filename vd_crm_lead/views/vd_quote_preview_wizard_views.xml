<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vd_quote_preview_wizard_form" model="ir.ui.view">
        <field name="name">vd.quote.preview.wizard.form</field>
        <field name="model">vd.quote.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Xem trước báo giá PDF" class="o_vd_preview_wizard_form">
                <sheet style="padding:0;background:#1a1a2e;">
                    <div class="o_vd_preview_wizard_body">
                        <field name="pdf_data" widget="pdf_viewer"
                               filename="pdf_name" nolabel="1"/>
                        <field name="pdf_name" invisible="1"/>
                        <field name="lead_id" invisible="1"/>
                    </div>
                </sheet>
                <footer>
                    <button string="✕ Đóng" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
