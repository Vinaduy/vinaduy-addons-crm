<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vd_crm_lead_list" model="ir.ui.view">
        <field name="name">vd.crm.lead.list</field>
        <field name="model">vd.crm.lead</field>
        <field name="arch" type="xml">
            <list string="Khách hàng"
                  decoration-success="probability >= 75"
                  decoration-info="probability >= 50 and probability &lt; 75"
                  decoration-warning="is_overdue_callback"
                  decoration-danger="is_stale and stage_code in ('new','potential')">
                <field name="name"/>
                <field name="phone"/>
                <field name="stage_id" widget="badge" decoration-info="stage_code in ('new','potential')"
                       decoration-success="stage_is_won"
                       decoration-danger="stage_is_lost"/>
                <field name="probability" widget="progressbar"/>
                <field name="callback_date" optional="show"/>
                <field name="last_call_date" optional="show"/>
                <field name="call_count" optional="hide"/>
                <field name="no_answer_streak" optional="hide"/>
                <field name="user_id" optional="show"/>
                <field name="priority" widget="priority"/>
                <field name="stage_code" column_invisible="1"/>
                <field name="stage_is_won" column_invisible="1"/>
                <field name="stage_is_lost" column_invisible="1"/>
                <field name="is_overdue_callback" column_invisible="1"/>
                <field name="is_stale" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_vd_crm_lead_kanban" model="ir.ui.view">
        <field name="name">vd.crm.lead.kanban</field>
        <field name="model">vd.crm.lead</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column"
                    quick_create="false" archivable="false">
                <field name="stage_id"/>
                <field name="probability"/>
                <field name="phone"/>
                <field name="callback_date"/>
                <field name="user_id"/>
                <field name="priority"/>
                <field name="color"/>
                <field name="is_overdue_callback"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record p-2"
                             t-att-class="record.is_overdue_callback.raw_value ? 'border border-warning' : ''">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong><field name="name"/></strong>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="text-muted small">
                                <i class="fa fa-phone"/> <field name="phone"/>
                            </div>
                            <div class="mt-1">
                                <field name="probability" widget="progressbar"/>
                            </div>
                            <div t-if="record.callback_date.raw_value" class="small mt-1">
                                <i class="fa fa-clock-o"/> <field name="callback_date"/>
                            </div>
                            <div class="mt-1">
                                <field name="user_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_vd_crm_lead_form" model="ir.ui.view">
        <field name="name">vd.crm.lead.form</field>
        <field name="model">vd.crm.lead</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="stage_id" widget="statusbar"
                           options="{'clickable': '1'}"/>
                    <button name="action_call" type="object" string="Gọi"
                            class="btn-success" icon="fa-phone"
                            invisible="not phone"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-phone" type="object"
                                name="action_call" invisible="not phone">
                            <field name="call_count" string="Cuộc gọi" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tên khách hàng"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                            <field name="address"/>
                            <field name="user_id"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group>
                            <field name="probability" widget="progressbar"/>
                            <field name="callback_date"/>
                            <field name="expected_close_date"/>
                            <field name="expected_revenue"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Hoạt động">
                        <group>
                            <field name="last_call_date" readonly="1"/>
                            <field name="last_answered_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="call_count" readonly="1"/>
                            <field name="no_answer_streak" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ghi chú" name="notes">
                            <field name="notes" placeholder="Ghi chú về khách hàng..."/>
                        </page>
                        <page string="Lịch sử gọi" name="calls">
                            <field name="call_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="direction"/>
                                    <field name="state" widget="badge"/>
                                    <field name="duration" widget="float_time"/>
                                    <field name="recording_attachment_id" widget="boolean"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_vd_crm_lead_search" model="ir.ui.view">
        <field name="name">vd.crm.lead.search</field>
        <field name="model">vd.crm.lead</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="phone"/>
                <field name="user_id"/>
                <field name="stage_id"/>
                <separator/>
                <filter name="my_leads" string="Của tôi" domain="[('user_id','=',uid)]"/>
                <filter name="overdue" string="Quá hạn gọi lại"
                        domain="[('is_overdue_callback','=',True)]"/>
                <filter name="hot" string="Tỉ lệ chốt &gt;= 50%"
                        domain="[('probability','&gt;=',50)]"/>
                <filter name="not_won_lost" string="Đang chăm sóc"
                        domain="[('stage_is_won','=',False),('stage_is_lost','=',False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_stage" string="Trạng thái" context="{'group_by':'stage_id'}"/>
                    <filter name="group_user" string="NV phụ trách" context="{'group_by':'user_id'}"/>
                    <filter name="group_priority" string="Ưu tiên" context="{'group_by':'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_vd_crm_lead" model="ir.actions.act_window">
        <field name="name">Khách hàng</field>
        <field name="res_model">vd.crm.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_vd_crm_lead_search"/>
        <field name="context">{'search_default_my_leads': 1}</field>
    </record>

</odoo>
