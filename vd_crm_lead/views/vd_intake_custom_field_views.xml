<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ CONFIG: Định nghĩa custom field ============ -->
    <record id="view_vd_intake_custom_field_list" model="ir.ui.view">
        <field name="name">vd.intake.custom.field.list</field>
        <field name="model">vd.intake.custom.field</field>
        <field name="arch" type="xml">
            <list string="Trường khai thác tuỳ chọn" editable="bottom"
                  default_order="sequence, id">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="help_text"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_vd_intake_custom_field_form" model="ir.ui.view">
        <field name="name">vd.intake.custom.field.form</field>
        <field name="model">vd.intake.custom.field</field>
        <field name="arch" type="xml">
            <form string="Trường khai thác tuỳ chọn">
                <sheet>
                    <group>
                        <field name="name" placeholder='Vd: "Mong muốn KH", "Phong cách", "Số phòng ngủ"...'/>
                        <field name="help_text" placeholder="Gợi ý hiện cho NV (placeholder)"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        Tạo trường mới = mọi lead (cũ + mới) đều có trường này trong
                        phiếu khai thác. NV nhập riêng từng KH.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vd_intake_custom_field" model="ir.actions.act_window">
        <field name="name">⚙️ Trường khai thác tuỳ chọn</field>
        <field name="res_model">vd.intake.custom.field</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có trường tuỳ chọn nào.</p>
            <p>Admin thêm trường ở đây → NV thấy trong phiếu khai thác KH ở mọi lead.</p>
        </field>
    </record>

    <!-- ============ INLINE LIST: hiện trong form lead ============ -->
    <record id="view_vd_lead_custom_value_inline_list" model="ir.ui.view">
        <field name="name">vd.lead.custom.value.inline.list</field>
        <field name="model">vd.lead.custom.value</field>
        <field name="arch" type="xml">
            <list string="Trường tuỳ chọn" editable="bottom" create="false" delete="false">
                <field name="field_id" readonly="1"
                       options="{'no_create': True, 'no_open': True}"/>
                <field name="field_help" string="Gợi ý" readonly="1" optional="hide"/>
                <field name="value" widget="text" placeholder="Nhập giá trị..."/>
            </list>
        </field>
    </record>

</odoo>
