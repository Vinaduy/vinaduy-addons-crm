<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vd_password_view_wizard_form" model="ir.ui.view">
        <field name="name">vd.password.view.wizard.form</field>
        <field name="model">vd.password.view.wizard</field>
        <field name="arch" type="xml">
            <form>
                <field name="user_id" invisible="1"/>
                <field name="revealed" invisible="1"/>
                <div class="alert alert-warning" role="alert">
                    <b>Bảo mật:</b> Bạn phải nhập lại mật khẩu của chính mình (admin)
                    để xem mật khẩu và lịch sử đổi của nhân viên này.
                </div>
                <group invisible="revealed">
                    <field name="admin_password" password="True" string="Mật khẩu của bạn"
                           placeholder="Nhập mật khẩu admin để xác thực"/>
                </group>
                <field name="result_html" invisible="not revealed"/>
                <footer>
                    <button name="action_reveal" type="object" string="Xác thực và xem"
                            class="btn-primary" invisible="revealed"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
