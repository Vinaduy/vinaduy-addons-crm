<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add lead context on stringee.call form -->
    <record id="view_stringee_call_form_lead" model="ir.ui.view">
        <field name="name">stringee.call.form.lead</field>
        <field name="model">stringee.call</field>
        <field name="inherit_id" ref="vd_stringee.view_stringee_call_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="oe_button_box" name="button_box">
                    <button class="oe_stat_button" type="object" name="action_open_lead"
                            icon="fa-user" invisible="not lead_id">
                        <div class="o_stat_info">
                            <field name="lead_stage_name" class="o_stat_value text-truncate"/>
                            <span class="o_stat_text">KH</span>
                        </div>
                    </button>
                </div>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="lead_id"/>
                <field name="lead_stage_name" invisible="1"/>
                <field name="lead_probability" widget="progressbar" invisible="not lead_id"/>
                <div class="o_form_label">
                    <button name="action_mark_wrong_number" type="object"
                            string="📵 Đánh dấu KHÔNG ĐÚNG SỐ"
                            class="btn btn-sm btn-outline-danger"
                            invisible="not lead_id"
                            confirm="Đánh dấu cuộc gọi sai số? KH sẽ tự động chuyển vào thùng rác (Hủy)."
                            help="Khi gọi nhầm số / số sai → đánh dấu để tự động move KH vào thùng rác."/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Add lead_id field on stringee.call list + button download ghi âm -->
    <record id="view_stringee_call_list_lead" model="ir.ui.view">
        <field name="name">stringee.call.list.lead</field>
        <field name="model">stringee.call</field>
        <field name="inherit_id" ref="vd_stringee.view_stringee_call_list"/>
        <field name="arch" type="xml">
            <!-- Khi mở popup per-lead (action_view_calls đặt vd_hide_lead_col):
                 - Direction luôn outbound từ system → ẩn cột direction
                 - Call ID đã optional="show" sẵn → giữ
                 - lead_id redundant (tất cả rows = 1 lead) → ẩn theo context
                 - user_id redundant (per-NV view) → ẩn theo context
                 - Recording attachment ẩn (chuyển sang audio widget) -->
            <xpath expr="//field[@name='direction']" position="attributes">
                <attribute name="optional">hide</attribute>
                <attribute name="column_invisible">context.get('vd_hide_lead_col')</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="column_invisible">context.get('vd_hide_user_col')</attribute>
            </xpath>
            <xpath expr="//field[@name='callee_number']" position="after">
                <field name="lead_id" optional="show"
                       column_invisible="context.get('vd_hide_lead_col')"/>
            </xpath>
            <!-- Column ghi âm: audio player INLINE để nghe trực tiếp + nút tải nếu chưa có -->
            <xpath expr="//field[@name='recording_attachment_id']" position="replace">
                <field name="recording_attachment_id" string="🎵 Ghi âm"
                       widget="vd_audio_player"
                       readonly="1"/>
                <button name="action_download_recording" type="object"
                        string="🎵 Tải"
                        class="btn btn-sm btn-outline-primary"
                        invisible="recording_attachment_id or state not in ('ended','no_answer','busy','declined','cancelled','failed')"
                        help="Force-retry tải file ghi âm từ Stringee"/>
            </xpath>
        </field>
    </record>

</odoo>
