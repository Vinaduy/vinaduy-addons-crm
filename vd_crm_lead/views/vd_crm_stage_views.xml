<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vd_crm_stage_list" model="ir.ui.view">
        <field name="name">vd.crm.stage.list</field>
        <field name="model">vd.crm.stage</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="default_probability"/>
                <field name="is_won"/>
                <field name="is_lost"/>
                <field name="fold"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_vd_crm_stage" model="ir.actions.act_window">
        <field name="name">Trạng thái khách hàng</field>
        <field name="res_model">vd.crm.stage</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
