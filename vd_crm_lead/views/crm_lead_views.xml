<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VD redesigned crm.lead form: card-based, single-page, no chatter, no notebook.
         Khai thác card slides in only when there's an active call (or already filled). -->
    <record id="crm_lead_view_form_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.vd</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- Hide stage flow widget in header -->
            <xpath expr="//header/field[@name='stage_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide Won / Lost buttons in header -->
            <xpath expr="//header/button[@name='action_set_won_rainbowman']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_set_lost']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide entire smart-button row (No Meeting / Quotations / etc.) -->
            <xpath expr="//div[@name='button_box']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide all standard notebook pages (Internal Notes / Extra Information) -->
            <xpath expr="//page[@name='internal_notes']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='extra']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Drop the chatter (activity log) -->
            <xpath expr="//chatter" position="replace"/>

            <!-- Insert call dock + hidden flag fields before the title -->
            <xpath expr="//sheet/div[hasclass('oe_title')]" position="before">
                <field name="vd_in_call" invisible="1"/>
                <field name="vd_active_call_id" invisible="1"/>
                <field name="vd_has_intake_data" invisible="1"/>
                <field name="stage_code" invisible="1"/>
                <field name="stage_is_won" invisible="1"/>
                <field name="stage_is_lost" invisible="1"/>

                <div class="o_vd_call_dock">
                    <div class="o_vd_call_left">
                        <button name="action_call" type="object"
                                class="o_vd_phone_btn o_vd_phone_btn_call"
                                title="Gọi qua Stringee"
                                invisible="vd_in_call or (not phone and not mobile)">
                            <i class="fa fa-phone"/>
                        </button>
                        <button name="action_hangup_active" type="object"
                                class="o_vd_phone_btn o_vd_phone_btn_hangup"
                                title="Cúp máy"
                                invisible="not vd_in_call">
                            <i class="fa fa-phone"/>
                        </button>
                        <div class="o_vd_call_status">
                            <div class="text-danger fw-bold" invisible="not vd_in_call">
                                <i class="fa fa-circle"/> Đang trong cuộc gọi…
                            </div>
                            <div class="text-muted" invisible="vd_in_call or phone or mobile">
                                Thiếu số điện thoại
                            </div>
                            <div class="text-muted" invisible="vd_in_call or (not phone and not mobile)">
                                Sẵn sàng gọi
                            </div>
                        </div>
                    </div>
                    <div class="o_vd_call_right">
                        <label for="stage_id" string="Trạng thái" class="text-muted small"/>
                        <field name="stage_id" widget="selection"
                               options="{'no_create': True, 'no_open': True}"/>
                        <div class="o_vd_prob mt-2">
                            <span class="small text-muted">Tỉ lệ chốt</span>
                            <field name="probability" widget="progressbar"/>
                        </div>
                    </div>
                </div>
            </xpath>

            <!-- Add callback_date alongside date_deadline -->
            <xpath expr="//field[@name='date_deadline']" position="after">
                <field name="callback_date"/>
            </xpath>

            <!-- After the contact group, insert the cards -->
            <xpath expr="//notebook" position="before">

                <!-- KHAI THÁC CARD — vertical list, slides in when call active or data filled -->
                <div class="o_vd_card o_vd_card_intake o_vd_intake_v2"
                     invisible="not vd_in_call and not vd_has_intake_data">
                    <h5 class="o_vd_intake_title">
                        ✅ TỔNG HỢP NHU CẦU KHÁCH HÀNG
                    </h5>
                    <div class="alert alert-info py-2" invisible="not vd_in_call">
                        <i class="fa fa-microphone"/>
                        Đang gọi — hỏi và điền theo các kịch bản gợi ý dưới đây.
                    </div>

                    <div class="o_vd_intake_row">
                        <label for="vd_intake_address">ĐỊA CHỈ</label>
                        <field name="vd_intake_address" nolabel="1"
                               placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_timeline">THỜI GIAN</label>
                        <field name="vd_intake_timeline" nolabel="1" placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_area">DIỆN TÍCH</label>
                        <field name="vd_intake_area" nolabel="1"
                               placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_house_type">KIỂU NHÀ</label>
                        <field name="vd_intake_house_type" nolabel="1" placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_floors">SỐ TẦNG</label>
                        <field name="vd_intake_floors" nolabel="1"
                               placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_function">CÔNG NĂNG</label>
                        <field name="vd_intake_function" nolabel="1"
                               placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_function_notes">GHI CHÚ CÔNG NĂNG</label>
                        <field name="vd_intake_function_notes" nolabel="1"
                               placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_land_type">LOẠI ĐẤT</label>
                        <field name="vd_intake_land_type" nolabel="1" placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_position">VỊ TRÍ</label>
                        <field name="vd_intake_position" nolabel="1" placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_budget">NGÂN SÁCH DỰ KIẾN</label>
                        <field name="vd_intake_budget" nolabel="1" placeholder="Chưa có dữ liệu"/>
                    </div>
                    <div class="o_vd_intake_row">
                        <label for="vd_intake_dimensions">SỔ ĐỎ / CẤP PHÉP</label>
                        <field name="vd_intake_dimensions" nolabel="1" placeholder="Chưa có dữ liệu"/>
                    </div>
                </div>

                <!-- LỊCH SỬ GỌI CARD — always visible -->
                <div class="o_vd_card">
                    <h5>
                        <i class="fa fa-phone"/>
                        Lịch sử cuộc gọi
                    </h5>
                    <group>
                        <group>
                            <field name="last_call_date" readonly="1"/>
                            <field name="last_answered_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="call_count" readonly="1"/>
                            <field name="no_answer_streak" readonly="1"/>
                        </group>
                    </group>
                    <field name="call_ids" readonly="1">
                        <list>
                            <field name="create_date"/>
                            <field name="direction"/>
                            <field name="state" widget="badge"/>
                            <field name="duration" widget="float_time"/>
                            <field name="recording_attachment_id" widget="boolean"/>
                        </list>
                    </field>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Stage form: add code, default_probability, is_lost -->
    <record id="crm_stage_view_form_inherit" model="ir.ui.view">
        <field name="name">crm.stage.form.vd</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_won']" position="after">
                <field name="code"/>
                <field name="default_probability"/>
                <field name="is_lost"/>
            </xpath>
        </field>
    </record>

</odoo>
