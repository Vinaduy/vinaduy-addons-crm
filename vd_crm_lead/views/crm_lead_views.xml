<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VD redesigned crm.lead form: summary card + floating call button +
         intake editing happens in a popup launched from the call button. -->
    <record id="crm_lead_view_form_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.vd</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- Hide entire form header (Won / Lost / New Quotation / stage flow / etc.) -->
            <xpath expr="//header" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the entire standard notebook -->
            <xpath expr="//notebook" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide standard title (h1 with name) -->
            <xpath expr="//div[hasclass('oe_title')]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the main info group (Expected Revenue / Contact / etc.) -->
            <xpath expr="//sheet/group" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Drop the chatter -->
            <xpath expr="//chatter" position="replace"/>

            <!-- All our content goes before the title (which is now hidden) -->
            <xpath expr="//sheet/div[hasclass('oe_title')]" position="before">
                <field name="vd_in_call" invisible="1"/>
                <field name="vd_active_call_id" invisible="1"/>
                <field name="vd_has_intake_data" invisible="1"/>
                <field name="stage_code" invisible="1"/>
                <field name="stage_is_won" invisible="1"/>
                <field name="stage_is_lost" invisible="1"/>
                <field name="vd_active_call_state" invisible="1"/>
                <field name="vd_active_call_answer_time" invisible="1"/>

                <!-- ============ CUSTOMER SUMMARY CARD ============ -->
                <div class="o_vd_summary_card">

                    <!-- Banner: stage as colored top strip -->
                    <div class="o_vd_summary_banner">
                        <field name="stage_id" widget="badge" readonly="1" nolabel="1"/>
                    </div>

                    <!-- Header: name + phone + salesperson -->
                    <div class="o_vd_summary_header">
                        <h2 class="o_vd_summary_name">
                            <field name="name" placeholder="Tên khách hàng" nolabel="1"/>
                        </h2>
                        <div class="o_vd_summary_meta">
                            <span class="o_vd_meta_item">
                                <i class="fa fa-phone"/>
                                <field name="phone" placeholder="0xxxxxxxxx" nolabel="1"/>
                            </span>
                            <span class="o_vd_meta_item">
                                <i class="fa fa-user"/>
                                <field name="user_id" widget="many2one_avatar_user" nolabel="1" readonly="1"/>
                            </span>
                        </div>
                    </div>

                    <!-- Intake summary — visible only when there's data; 1-line per item -->
                    <div class="o_vd_summary_body" invisible="not vd_has_intake_data">
                        <div class="o_vd_summary_section_title">
                            <i class="fa fa-clipboard-list"/> THÔNG TIN KHAI THÁC
                        </div>

                        <div class="o_vd_summary_grid_inline">

                            <div class="o_vd_row_inline" invisible="not vd_intake_province_id">
                                <span class="o_vd_lbl"><i class="fa fa-map-marker"/> Tỉnh:</span>
                                <field name="vd_intake_province_id" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_district">
                                <span class="o_vd_lbl"><i class="fa fa-map"/> Huyện:</span>
                                <field name="vd_intake_district" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_address">
                                <span class="o_vd_lbl"><i class="fa fa-road"/> Địa chỉ:</span>
                                <field name="vd_intake_address" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_position">
                                <span class="o_vd_lbl"><i class="fa fa-location-arrow"/> Vị trí:</span>
                                <field name="vd_intake_position" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_land_type">
                                <span class="o_vd_lbl"><i class="fa fa-th"/> Loại đất:</span>
                                <field name="vd_intake_land_type" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_dimensions">
                                <span class="o_vd_lbl"><i class="fa fa-file-text-o"/> Sổ đỏ:</span>
                                <field name="vd_intake_dimensions" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_area">
                                <span class="o_vd_lbl"><i class="fa fa-square-o"/> Diện tích:</span>
                                <field name="vd_intake_area" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_house_type">
                                <span class="o_vd_lbl"><i class="fa fa-home"/> Kiểu nhà:</span>
                                <field name="vd_intake_house_type" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_floors">
                                <span class="o_vd_lbl"><i class="fa fa-building"/> Số tầng:</span>
                                <field name="vd_intake_floors" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_function">
                                <span class="o_vd_lbl"><i class="fa fa-list"/> Công năng:</span>
                                <field name="vd_intake_function" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_timeline">
                                <span class="o_vd_lbl"><i class="fa fa-clock-o"/> Thời gian:</span>
                                <field name="vd_intake_timeline" readonly="1" nolabel="1"/>
                            </div>

                            <div class="o_vd_row_inline" invisible="not vd_intake_budget">
                                <span class="o_vd_lbl"><i class="fa fa-money"/> Ngân sách:</span>
                                <field name="vd_intake_budget" readonly="1" nolabel="1"/>
                            </div>

                        </div>

                        <div class="o_vd_row_inline o_vd_notes" invisible="not vd_intake_function_notes">
                            <span class="o_vd_lbl"><i class="fa fa-sticky-note-o"/> Ghi chú:</span>
                            <field name="vd_intake_function_notes" readonly="1" nolabel="1"/>
                        </div>
                    </div>

                    <!-- Empty state -->
                    <div class="o_vd_summary_empty" invisible="vd_has_intake_data">
                        <i class="fa fa-info-circle"/>
                        Chưa có thông tin khai thác. Bấm nút <strong>Gọi</strong> ở góc phải dưới để bắt đầu khai thác khách hàng.
                    </div>
                </div>
            </xpath>

            <!-- Lịch sử cuộc gọi menu pill + Floating call FAB inserted before notebook -->
            <xpath expr="//notebook" position="before">

                <!-- MENU BAR — small action toolbar -->
                <div class="o_vd_menu_bar">
                    <field name="call_count" invisible="1"/>
                    <button name="action_view_calls" type="object"
                            class="btn btn-sm btn-outline-info o_vd_menu_btn">
                        <i class="fa fa-history me-1"/>
                        Lịch sử cuộc gọi
                        <span class="badge bg-info ms-2">
                            <field name="call_count" nolabel="1" readonly="1"/>
                        </span>
                    </button>
                </div>

                <!-- FLOATING CALL BUTTON — bottom-right corner with status pill -->
                <div class="o_vd_call_fab">
                    <button name="action_call" type="object"
                            class="o_vd_phone_btn o_vd_phone_btn_call"
                            title="Gọi qua Stringee"
                            invisible="vd_in_call or (not phone and not mobile)">
                        <i class="fa fa-phone"/>
                    </button>
                    <button name="action_hangup_active" type="object"
                            class="o_vd_phone_btn o_vd_phone_btn_hangup"
                            title="Cúp máy"
                            invisible="not vd_in_call">
                        <i class="fa fa-phone"/>
                    </button>
                    <field name="vd_in_call" widget="vd_call_status" nolabel="1"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- ============ INTAKE POPUP FORM VIEW (ultra compact, hidden hints) ============ -->
    <!-- Each row = 1 line (label + field inline). Each row has title= so the
         Vietnamese script hint shows as a native browser tooltip on hover —
         no clutter in the dialog itself. -->
    <record id="view_crm_lead_intake_popup" model="ir.ui.view">
        <field name="name">crm.lead.intake.popup</field>
        <field name="model">crm.lead</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Khai thác thông tin" class="o_vd_intake_compact">
                <sheet>
                    <div class="o_vd_popup_banner">
                        <i class="fa fa-microphone"/>
                        Đang gọi <strong><field name="phone" readonly="1" nolabel="1"/></strong>
                        <span class="text-muted ms-2">— hỏi theo gợi ý mờ trong từng ô</span>
                    </div>

                    <div class="o_vd_pf_grid">

                        <!-- Cột 1: Vị trí & đất -->
                        <div class="o_vd_pf_section">
                            <div class="o_vd_pf_section_title">📍 Vị trí &amp; đất</div>

                            <div class="o_vd_pf">
                                <label for="vd_intake_province_id">Tỉnh / Thành</label>
                                <field name="vd_intake_province_id" nolabel="1"
                                       placeholder="Anh/chị xây ở tỉnh / thành nào ạ?"
                                       options="{'no_create': True, 'no_open': True}"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_district">Huyện / Quận</label>
                                <field name="vd_intake_district" nolabel="1"
                                       placeholder="Khu vực huyện / quận / TP nào?"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_address">Địa chỉ chi tiết</label>
                                <field name="vd_intake_address" nolabel="1"
                                       placeholder="Cho em xin số nhà, tên đường, phường?"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_position">Vị trí</label>
                                <field name="vd_intake_position" nolabel="1"
                                       placeholder="Mặt tiền hay trong hẻm? Đường có thuận lợi xe?"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_land_type">Loại đất</label>
                                <field name="vd_intake_land_type" nolabel="1"
                                       placeholder="Đất sổ đỏ thổ cư hay nông nghiệp / phân lô?"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_dimensions">Sổ đỏ / cấp phép</label>
                                <field name="vd_intake_dimensions" nolabel="1"
                                       placeholder="Đã có sổ đỏ chưa? Đã có giấy phép xây dựng chưa?"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_area">Diện tích</label>
                                <field name="vd_intake_area" nolabel="1"
                                       placeholder="Tổng diện tích đất / sàn xây dựng? (vd: 5x20m)"/>
                            </div>
                        </div>

                        <!-- Cột 2: Công trình -->
                        <div class="o_vd_pf_section">
                            <div class="o_vd_pf_section_title">🏠 Công trình</div>

                            <div class="o_vd_pf">
                                <label for="vd_intake_house_type">Kiểu nhà</label>
                                <field name="vd_intake_house_type" nolabel="1"
                                       placeholder="Mái bằng, mái thái, biệt thự…?"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_floors">Số tầng</label>
                                <field name="vd_intake_floors" nolabel="1"
                                       placeholder="Quy mô bao nhiêu tầng? (vd: 2,5 tầng)"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_function">Công năng</label>
                                <field name="vd_intake_function" nolabel="1"
                                       placeholder="Bao nhiêu PN, có thang máy / sân thượng? (vd: 3PN+2WC)"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_timeline">Thời gian</label>
                                <field name="vd_intake_timeline" nolabel="1"
                                       placeholder="Anh/chị dự kiến khởi công khi nào?"/>
                            </div>
                            <div class="o_vd_pf">
                                <label for="vd_intake_budget">Ngân sách dự kiến</label>
                                <field name="vd_intake_budget" nolabel="1"
                                       placeholder="Anh/chị dự kiến đầu tư khoảng bao nhiêu?"/>
                            </div>
                        </div>

                    </div>

                    <div class="o_vd_pf o_vd_pf_notes">
                        <label for="vd_intake_function_notes">📝 Ghi chú công năng</label>
                        <field name="vd_intake_function_notes" nolabel="1"
                               placeholder="Có yêu cầu đặc biệt gì về phong thủy / ánh sáng / spa / phòng thờ không?"/>
                    </div>
                </sheet>
                <footer>
                    <button string="✓ Lưu" special="save" class="btn btn-primary"/>
                    <button string="Đóng" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Stage form: add code, default_probability, is_lost -->
    <record id="crm_stage_view_form_inherit" model="ir.ui.view">
        <field name="name">crm.stage.form.vd</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_won']" position="after">
                <field name="code"/>
                <field name="default_probability"/>
                <field name="is_lost"/>
            </xpath>
        </field>
    </record>

</odoo>
