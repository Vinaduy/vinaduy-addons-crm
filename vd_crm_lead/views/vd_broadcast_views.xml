<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ CHIẾN DỊCH SPAM ZALO ============ -->
    <record id="view_vd_broadcast_campaign_form" model="ir.ui.view">
        <field name="name">vd.broadcast.campaign.form</field>
        <field name="model">vd.broadcast.campaign</field>
        <field name="arch" type="xml">
            <form string="Chiến dịch Spam Zalo">
                <header>
                    <button name="action_start_now" type="object" string="BẮT ĐẦU CHIẾN DỊCH"
                            class="btn-primary"
                            confirm="Đặt giờ bắt đầu = bây giờ và bắt toàn bộ nhân viên spam chiến dịch này NGAY?"/>
                    <button name="action_end_campaign" type="object" string="KẾT THÚC CHIẾN DỊCH"
                            class="btn-danger"
                            confirm="KẾT THÚC chiến dịch? Mọi ràng buộc (chờ giờ / bắt tải / bắt báo cáo) sẽ được HUỶ. Toàn bộ nhân viên đang giang dở được thả, tự thoát vào CRM mà không cần làm nữa."/>
                    <!-- Luồng theo dõi LIVE: trạng thái + đếm ngược + giờ + % (user 2026-07-09) -->
                    <widget name="vd_broadcast_status"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="o_form_label"/>
                        <h1><field name="name" placeholder="VD: Thi công móng - Tuần 1 tháng 7"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="start_datetime"/>
                            <field name="window_minutes"/>
                            <field name="finish_delay_minutes" invisible="1"/>
                            <field name="vd_progress_pct" invisible="1"/>
                        </group>
                        <group>
                            <field name="target_count"/>
                            <field name="done_count"/>
                            <field name="vd_missing_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bước 1 - Ảnh / Video">
                            <div class="text-muted mb-2">Tải ảnh/video công trình vào đây (chọn nhiều cùng lúc, có thanh tiến trình, xem trực tiếp). Nhân viên sẽ tải xuống rồi gửi kèm.</div>
                            <field name="attachment_ids" widget="vd_media_field" nolabel="1"/>
                        </page>
                        <page string="Bước 2 - Tin nhắn NHÓM Zalo">
                            <div class="alert alert-info mb-2" role="alert">
                                <i class="fa fa-pencil me-1"/>Bấm thẳng vào vùng nội dung bên dưới để sửa. Sửa xong nhớ bấm <b>Lưu</b> (biểu tượng đám mây ở góc trên).
                            </div>
                            <field name="body_html" widget="html" nolabel="1"
                                   options="{'height': 400}"/>
                        </page>
                        <page string="Bước 3 - Đăng bài CÁ NHÂN">
                            <div class="alert alert-info mb-2" role="alert">
                                <i class="fa fa-pencil me-1"/>Bấm thẳng vào vùng nội dung để sửa, rồi bấm <b>Lưu</b>. Để trống sẽ dùng chung nội dung nhóm Zalo.
                            </div>
                            <field name="personal_html" widget="html" nolabel="1"
                                   options="{'height': 400}"/>
                        </page>
                        <page string="Nhân viên áp dụng">
                            <div class="text-muted mb-2">Để TRỐNG = áp cho toàn bộ nhân viên (trừ admin).</div>
                            <field name="user_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Báo cáo nhân viên">
                            <div class="alert alert-warning mb-2" role="alert" invisible="active">
                                <i class="fa fa-stop-circle me-1"/><b>CHIẾN DỊCH ĐÃ DỪNG HẲN.</b>
                                Các nhân viên dòng ĐỎ (Hoàn thành = trống) là những người
                                <b>KHÔNG thực hiện</b> chiến dịch (nghỉ phép / không làm) — đã được tự huỷ ràng buộc.
                            </div>
                            <div class="alert alert-info mb-2" role="alert" invisible="not active">
                                <i class="fa fa-clock-o me-1"/>Chiến dịch sẽ <b>tự dừng hẳn cuối ngày hôm nay</b>.
                                Ai chưa thực hiện tới lúc đó sẽ được tự huỷ ràng buộc và bị ghi nhận
                                <b>KHÔNG thực hiện</b> ở bảng dưới.
                            </div>
                            <field name="report_ids" readonly="1">
                                <list decoration-danger="not done" decoration-success="done">
                                    <field name="user_id"/>
                                    <field name="sent_count"/>
                                    <field name="committed"/>
                                    <field name="done"/>
                                    <field name="done_at"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vd_broadcast_campaign_list" model="ir.ui.view">
        <field name="name">vd.broadcast.campaign.list</field>
        <field name="model">vd.broadcast.campaign</field>
        <field name="arch" type="xml">
            <list string="Chiến dịch Spam Zalo">
                <field name="name"/>
                <field name="start_datetime"/>
                <field name="active"/>
                <field name="done_count"/>
                <field name="target_count"/>
            </list>
        </field>
    </record>

    <record id="action_vd_broadcast_campaign" model="ir.actions.act_window">
        <field name="name">Chiến dịch Spam Zalo</field>
        <field name="res_model">vd.broadcast.campaign</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_vd_broadcast_campaign"
              name="Chiến dịch Spam Zalo"
              parent="crm.crm_menu_config"
              action="action_vd_broadcast_campaign"
              sequence="66"
              groups="sales_team.group_sale_manager"/>
</odoo>
