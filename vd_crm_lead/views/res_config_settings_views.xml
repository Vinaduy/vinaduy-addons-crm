<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ Cài đặt CRM — Yêu cầu tìm vấn đề (user spec 2026-06-01) ============ -->
    <record id="view_vd_crm_config_settings_form" model="ir.ui.view">
        <field name="name">vd.crm.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Cài đặt CRM" class="oe_form_configuration">
                <sheet>
                    <div class="oe_title">
                        <h1>⚠️ Yêu cầu tìm vấn đề</h1>
                        <p class="text-muted">
                            Nhắc NV tìm/tạo vấn đề cho khách sau báo giá. Vượt ngưỡng
                            quá số ngày gia hạn → tự khoá không cho mở khách mới.
                        </p>
                    </div>
                    <group>
                        <field name="vd_problem_find_enabled"/>
                        <field name="vd_problem_find_pct"
                               invisible="not vd_problem_find_enabled"/>
                        <field name="vd_problem_find_grace_days"
                               invisible="not vd_problem_find_enabled"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Lưu" type="object" name="execute"
                            class="btn-primary"/>
                    <button string="Huỷ" type="object" name="cancel"
                            class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vd_crm_config_settings" model="ir.actions.act_window">
        <field name="name">⚙️ Cài đặt CRM — Tìm vấn đề</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_vd_crm_config_settings_form"/>
        <field name="target">new</field>
        <field name="context">{'module': 'vd_crm_lead'}</field>
    </record>
</odoo>
