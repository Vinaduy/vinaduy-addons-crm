<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ CÀI ĐẶT KHOÁ — 3 bảng dashboard (user spec 2026-06-05) ============ -->
    <record id="view_vd_crm_config_settings_form" model="ir.ui.view">
        <field name="name">vd.crm.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Cài đặt khoá" class="oe_form_configuration">
                <sheet>
                    <div class="oe_title">
                        <h1>🔒 Cài đặt khoá dashboard</h1>
                        <p class="text-muted">
                            Cấu hình điều kiện tự khoá cho 3 bảng. Khi 1 bảng của NV
                            quá hạn → khoá bảng đó (chặn bấm), chỉ quản lý/giám đốc gỡ.
                        </p>
                    </div>

                    <group string="🆕 KHÁCH MỚI (chưa gọi đủ)">
                        <field name="vd_callwatch_enabled"/>
                        <field name="vd_callwatch_required_days"
                               invisible="not vd_callwatch_enabled"/>
                        <field name="vd_callwatch_window_workdays"
                               invisible="not vd_callwatch_enabled"/>
                    </group>

                    <group string="🔒 KHOÁ TOÀN BỘ — KH mới chưa gọi tồn quá nhiều">
                        <field name="vd_uncalled_new_lock_threshold"/>
                        <div class="text-muted" colspan="2">
                            Tồn HƠN số này khách MỚI chưa gọi cuộc nào → khoá TẤT CẢ
                            bảng (trừ chính các khách đó), gọi cho ≤ số này thì tự mở.
                            Đặt <b>0</b> = tắt.
                        </div>
                    </group>

                    <group string="🚫 CHẶN CHIA SỐ — KH mới chưa gọi tồn quá nhiều">
                        <field name="vd_distribute_block_uncalled"/>
                        <div class="text-muted" colspan="2">
                            Không cho chia/up thêm số mới cho NV nếu TỔNG dự kiến
                            (đang tồn + sắp chia) khách MỚI chưa gọi vượt số này.
                            Mỗi NV chỉ nhận tới khi đủ số này. Đặt <b>0</b> = tắt.
                        </div>
                    </group>

                    <group string="⚡ THI CÔNG GẤP + 🛠️ XỬ LÝ VẤN ĐỀ (tìm vấn đề)">
                        <field name="vd_problem_find_enabled"/>
                    </group>
                    <group string="⚡ Thi công gấp" invisible="not vd_problem_find_enabled">
                        <field name="vd_pf_urgent_pct"/>
                        <field name="vd_pf_urgent_grace"/>
                    </group>
                    <group string="🛠️ Xử lý vấn đề" invisible="not vd_problem_find_enabled">
                        <field name="vd_pf_xlvd_pct"/>
                        <field name="vd_pf_xlvd_grace"/>
                    </group>

                    <group string="⏱️ HẠN XỬ LÝ VẤN ĐỀ (đếm ngược + gia hạn)">
                        <field name="vd_problem_deadline_days"/>
                        <field name="vd_problem_extension_days"/>
                        <field name="vd_problem_extension_max"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Lưu" type="object" name="execute"
                            class="btn-primary"/>
                    <button string="Huỷ" type="object" name="cancel"
                            class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_vd_crm_config_settings" model="ir.actions.act_window">
        <field name="name">🔒 Cài đặt khoá</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_vd_crm_config_settings_form"/>
        <field name="target">new</field>
        <field name="context">{'module': 'vd_crm_lead'}</field>
    </record>
</odoo>
