<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_vd_crm_role_list" model="ir.ui.view">
        <field name="name">res.users.vd.crm.role.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="Phân quyền CRM" editable="bottom" create="0" delete="0">
                <field name="name"/>
                <field name="login"/>
                <field name="vd_crm_role"/>
                <field name="vd_can_edit_lead" widget="boolean_toggle" optional="show"/>
                <field name="vd_can_delete_lead" widget="boolean_toggle" optional="show"/>
                <field name="vd_can_transfer_lead" widget="boolean_toggle" optional="show"/>
                <field name="vd_can_see_all_menus" widget="boolean_toggle" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_users_vd_crm_role_form" model="ir.ui.view">
        <field name="name">res.users.vd.crm.role.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="Phân quyền CRM" create="0">
                <sheet>
                    <group>
                        <group string="Thông tin user">
                            <field name="name" readonly="1"/>
                            <field name="login" readonly="1"/>
                            <field name="active"/>
                        </group>
                        <group string="Vai trò chính">
                            <field name="vd_crm_role"/>
                            <field name="vd_can_see_all_menus" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Quyền thao tác trên khách hàng">
                        <group>
                            <field name="vd_can_edit_lead" widget="boolean_toggle"/>
                            <field name="vd_can_delete_lead" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="vd_can_transfer_lead" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <div class="text-muted mt-3">
                        <p><strong>Hướng dẫn:</strong></p>
                        <ul>
                            <li><b>Vai trò</b> — chọn 1 trong 4: Admin / Trưởng phòng / Nhân viên / Không có quyền.</li>
                            <li><b>Xem toàn bộ menu</b> — bật để user thấy tất cả module Odoo
                                (kế toán, tuyển dụng…). Tắt → chỉ CRM + Mail.</li>
                            <li><b>Sửa khách</b> — tắt → user chỉ ĐỌC, không lưu được thay đổi nào.</li>
                            <li><b>Xoá khách</b> — tắt → không xoá được KH.</li>
                            <li><b>Chuyển khách cho NV khác</b> — tắt → không đổi được "NV phụ trách".</li>
                        </ul>
                        <p class="text-warning small">
                            <i class="fa fa-info-circle"/> Các giới hạn trên CHỈ áp dụng cho Nhân viên và Trưởng phòng.
                            Admin luôn có toàn quyền (bypass mọi giới hạn).
                        </p>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vd_crm_user_roles" model="ir.actions.act_window">
        <field name="name">Phân quyền nhân viên</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('share', '=', False)]</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_users_vd_crm_role_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_users_vd_crm_role_form')}),
        ]"/>
    </record>

    <menuitem id="menu_vd_crm_user_roles"
              name="Phân quyền nhân viên"
              parent="crm.crm_menu_config"
              action="action_vd_crm_user_roles"
              groups="base.group_system"
              sequence="50"/>

</odoo>
