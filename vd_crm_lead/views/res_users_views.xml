<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_vd_crm_role_list" model="ir.ui.view">
        <field name="name">res.users.vd.crm.role.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="Phân quyền CRM" editable="bottom" create="0" delete="0">
                <field name="name"/>
                <field name="login"/>
                <field name="vd_crm_role"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_users_vd_crm_role_form" model="ir.ui.view">
        <field name="name">res.users.vd.crm.role.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="Phân quyền CRM" create="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="login" readonly="1"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="vd_crm_role"/>
                        </group>
                    </group>
                    <div class="text-muted mt-3">
                        <p><strong>Giải thích 3 vai trò:</strong></p>
                        <ul>
                            <li><b>Nhân viên:</b> chỉ xem/sửa/xoá KH có "NV phụ trách" = chính họ.
                                Menu hệ thống bị ẩn — chỉ thấy CRM + Mail.</li>
                            <li><b>Trưởng phòng:</b> xem/sửa/xoá tất cả KH của mọi NV. Vẫn không có quyền hệ thống
                                (không thấy Settings, Apps, Users…).</li>
                            <li><b>Admin:</b> toàn quyền hệ thống — cấu hình, phân quyền, tất cả module.</li>
                            <li><b>Không có quyền CRM:</b> không vào được module CRM.</li>
                        </ul>
                        <p class="text-warning small">
                            <i class="fa fa-info-circle"/> Khi đổi sang NV/Trưởng phòng, các quyền thừa
                            (kế toán, tuyển dụng, web designer…) sẽ tự động được gỡ.
                        </p>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vd_crm_user_roles" model="ir.actions.act_window">
        <field name="name">Phân quyền nhân viên</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('share', '=', False)]</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_users_vd_crm_role_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_users_vd_crm_role_form')}),
        ]"/>
    </record>

    <menuitem id="menu_vd_crm_user_roles"
              name="Phân quyền nhân viên"
              parent="crm.crm_menu_config"
              action="action_vd_crm_user_roles"
              groups="base.group_system"
              sequence="50"/>

</odoo>
