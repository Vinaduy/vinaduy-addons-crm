<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_vd_crm_role_list" model="ir.ui.view">
        <field name="name">res.users.vd.crm.role.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="Phân quyền CRM" editable="bottom" create="0" delete="0">
                <field name="name"/>
                <field name="login"/>
                <field name="vd_crm_role"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_users_vd_crm_role_form" model="ir.ui.view">
        <field name="name">res.users.vd.crm.role.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="Phân quyền CRM" create="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="login" readonly="1"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="vd_crm_role"/>
                        </group>
                    </group>
                    <div class="text-muted mt-3">
                        <p><strong>Giải thích quyền:</strong></p>
                        <ul>
                            <li><b>NV thường:</b> chỉ xem / sửa / xoá KH có "NV phụ trách" = chính họ.</li>
                            <li><b>NV xem tất cả KH:</b> xem được KH của mọi NV, nhưng chỉ sửa được KH của mình.</li>
                            <li><b>Quản trị CRM:</b> xem / sửa / xoá toàn bộ KH của mọi NV.</li>
                            <li><b>Không có quyền CRM:</b> không vào được module CRM.</li>
                        </ul>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vd_crm_user_roles" model="ir.actions.act_window">
        <field name="name">Phân quyền nhân viên</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('share', '=', False)]</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_users_vd_crm_role_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_users_vd_crm_role_form')}),
        ]"/>
    </record>

    <menuitem id="menu_vd_crm_user_roles"
              name="Phân quyền nhân viên"
              parent="crm.crm_menu_config"
              action="action_vd_crm_user_roles"
              groups="base.group_system,sales_team.group_sale_manager"
              sequence="50"/>

</odoo>
