<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- 1 nút tròn duy nhất — KHÔNG morph kích thước, chỉ ĐỔI MÀU theo state.
         Ghi chú hiện DƯỚI nút (Đang đổ chuông… / 0:15) khi đang gọi. -->
    <t t-name="vd_crm_lead.CallStatusWidget">
        <div class="o_vd_call_btn_wrap">
            <button type="button"
                    class="o_vd_call_btn"
                    t-att-class="{
                        'o_vd_call_btn_idle': statusType === 'idle',
                        'o_vd_call_btn_no_phone': statusType === 'no_phone',
                        'o_vd_call_btn_ringing': statusType === 'ringing',
                        'o_vd_call_btn_incall': statusType === 'in_call',
                    }"
                    t-att-disabled="statusType === 'no_phone' or state.busy"
                    t-on-click="onCallClick">
                <img t-if="statusType === 'idle'" src="/vd_crm_lead/static/src/img/phone-2.png" class="o_vd_call_icon_img" alt="Gọi"/>
                <i t-elif="statusType === 'no_phone'" class="fa fa-phone o_vd_icon_slash"/>
                <i t-elif="statusType === 'ringing'" class="fa fa-bell o_vd_ring_pulse"/>
                <i t-elif="statusType === 'in_call'" class="fa fa-phone o_vd_icon_hangup"/>
            </button>
            <!-- Ghi chú dưới nút — chỉ hiện khi có call (ringing/in_call) hoặc thiếu SĐT -->
            <div t-if="statusType === 'ringing'" class="o_vd_call_caption o_vd_caption_ringing">
                Đang đổ chuông…
            </div>
            <div t-elif="statusType === 'in_call'" class="o_vd_call_caption o_vd_caption_incall">
                <t t-esc="formatted"/>
            </div>
            <div t-elif="statusType === 'no_phone'" class="o_vd_call_caption o_vd_caption_no_phone">
                Thiếu SĐT
            </div>
            <!-- TƯ VẤN QUA ZALO — ngay DƯỚI nút gọi (user spec 2026-06-07).
                 Hover hiện bảng xác nhận "KH này tư vấn qua Zalo để lấy thông tin". -->
            <div t-if="hasPhone and hasRealCall" class="o_vd_zalo_box">
                <button type="button" class="o_vd_call_btn o_vd_zalo_fab"
                        t-att-class="{ o_vd_zalo_fab_active: zaloProgress > 0 and zaloProgress &lt; 3,
                                       o_vd_zalo_fab_done: zaloProgress === 3 }"
                        t-on-click="() => this.openCustomerZalo()"
                        title="BẤM: mở Zalo của khách · Đưa chuột vào: xác nhận chăm Zalo + copy lời chào.">
                    <img src="/vd_crm_lead/static/src/img/zalo.webp" class="o_vd_zalo_fab_icon" alt="Zalo"/>
                </button>
                <!-- Bảng hover — quy trình chăm Zalo 3 NGÀY (progressive) -->
                <div class="o_vd_zalo_panel">
                    <div class="o_vd_zalo_panel_head"
                         t-att-class="{ o_vd_zalo_head_active: zaloProgress > 0 and zaloProgress &lt; 3 }">
                        <img src="/vd_crm_lead/static/src/img/zalo.webp" class="o_vd_zalo_panel_logo" alt="Zalo"/>
                        <span class="o_vd_zalo_panel_title">
                            <t t-if="zaloProgress === 0"><t t-esc="zaloPanel.title"/></t>
                            <t t-elif="zaloProgress &lt; 3">ĐANG TƯ VẤN QUA ZALO ĐỂ LẤY THÔNG TIN</t>
                            <t t-else="">ĐÃ TƯ VẤN ĐỦ QUA ZALO</t>
                        </span>
                    </div>
                    <div class="o_vd_zalo_panel_body">
                        <div class="o_vd_zalo_panel_warn">📵 Gọi không nghe máy! Chăm khách qua Zalo 3 ngày:</div>
                        <!-- Lời chào mẫu + nút COPY (user spec 2026-06-10) -->
                        <div class="o_vd_zalo_greeting">
                            <div class="o_vd_zalo_greeting_lbl">📋 Lời chào mẫu — Copy rồi dán vào Zalo:</div>
                            <div class="o_vd_zalo_greeting_txt"><t t-esc="zaloGreeting"/></div>
                            <button type="button" class="o_vd_zalo_copy_btn"
                                    t-on-click="() => this.copyZaloGreeting()">
                                <i class="fa fa-copy me-1"/> Copy lời chào
                            </button>
                        </div>
                        <div class="o_vd_zalo_steps">
                            <!-- NGÀY 1 — phần mềm tự hiểu là ngày 1, chỉ cần 1 button -->
                            <!-- ĐÃ bấm xác nhận → badge XANH LÁ "ĐÃ NHẮN ZALO" -->
                            <div t-if="zaloDays.d1" class="o_vd_zalo_done_green">
                                <i class="fa fa-check-circle me-1"/> ĐÃ NHẮN ZALO
                            </div>
                            <!-- CHƯA bấm → nút XANH DƯƠNG "NHẮN ZALO" (bấm xác nhận sau khi nhắn) -->
                            <button t-else="" type="button" class="o_vd_zbig_btn"
                                    t-on-click="() => this.confirmZaloDay(1)">
                                <span class="o_vd_zbig_main">NHẮN ZALO</span>
                                <span class="o_vd_zbig_sub">Bấm xác nhận sau khi đã nhắn (kết bạn khi khách trả lời)</span>
                            </button>
                            <!-- Không tìm thấy Zalo (user spec 2026-06-10) -->
                            <div t-if="props.record.data.vd_zalo_not_found" class="o_vd_zstep_done_line o_vd_znotfound_done">
                                <i class="fa fa-ban"/> Đã đánh dấu: KHÔNG TÌM THẤY Zalo
                            </div>
                            <button t-elif="!zaloDays.d1" type="button" class="o_vd_znotfound_btn"
                                    t-on-click="() => this.confirmZaloNotFound()">
                                🚫 Không tìm thấy Zalo của khách
                            </button>
                            <!-- Chờ sang ngày mai mới hiện NGÀY 2 -->
                            <div t-if="zaloDays.d1 and !zaloDays.d2avail" class="o_vd_zstep_wait">
                                ⏳ Quay lại <b>NGÀY MAI</b> để gọi điện + nhắn Zalo.
                            </div>
                            <!-- NGÀY 2 — chỉ hiện khi đã SANG NGÀY mới sau Ngày 1 -->
                            <t t-if="zaloDays.d2avail">
                                <div t-if="zaloDays.d2" class="o_vd_zstep_done_line"><i class="fa fa-check"/> Đã GỌI + NHẮN Zalo (ngày 2)</div>
                                <button t-else="" type="button" class="o_vd_zbig_btn"
                                        t-on-click="() => this.confirmZaloDay(2)">
                                    <span class="o_vd_zbig_main">✓ XÁC NHẬN GỌI + NHẮN ZALO</span>
                                    <span class="o_vd_zbig_sub">Chăm khách ngày 2</span>
                                </button>
                            </t>
                            <!-- Chờ sang ngày mai mới hiện NGÀY 3 -->
                            <div t-if="zaloDays.d2 and !zaloDays.d3avail" class="o_vd_zstep_wait">
                                ⏳ Quay lại <b>NGÀY MAI</b> để gọi điện + nhắn Zalo.
                            </div>
                            <!-- NGÀY 3 — chỉ hiện khi đã SANG NGÀY mới sau Ngày 2 -->
                            <t t-if="zaloDays.d3avail">
                                <div t-if="zaloDays.d3" class="o_vd_zstep_done_line"><i class="fa fa-check"/> Đã GỌI + NHẮN Zalo (ngày 3)</div>
                                <button t-else="" type="button" class="o_vd_zbig_btn"
                                        t-on-click="() => this.confirmZaloDay(3)">
                                    <span class="o_vd_zbig_main">✓ XÁC NHẬN GỌI + NHẮN ZALO</span>
                                    <span class="o_vd_zbig_sub">Chăm khách ngày 3</span>
                                </button>
                            </t>
                        </div>
                        <div class="o_vd_zalo_panel_note">⏳ Mỗi bước xác nhận vào 1 NGÀY KHÁC NHAU · hạn 7 ngày.</div>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <!-- Compact timer: chỉ hiện "M:SS" tăng dần — dùng inline trong banner -->
    <t t-name="vd_crm_lead.CallTimer">
        <span class="o_vd_call_timer_compact"><t t-esc="formatted"/></span>
    </t>

</templates>
