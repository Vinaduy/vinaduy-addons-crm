<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="vd_crm_lead.VdM2oHoverPicker">
        <div class="o_vd_m2o_hover_picker" t-ref="root"
             t-att-class="{ 'o_vd_mhp_open': state.open, 'o_vd_mhp_has_value': hasValue }">
            <!-- Bar = INPUT (gõ trực tiếp để search, click để mở dropdown) -->
            <div class="o_vd_mhp_bar">
                <input type="text" class="o_vd_mhp_input"
                       t-ref="searchInput"
                       t-att-value="inputValue"
                       t-att-placeholder="props.placeholder or 'Bấm để chọn…'"
                       t-on-focus="onInputFocus"
                       t-on-input="onSearchInput"
                       t-on-keydown="onSearchKeydown"
                       autocomplete="off"/>
                <button type="button" class="o_vd_mhp_clear" t-if="hasValue" title="Xoá">×</button>
                <i class="fa fa-caret-down o_vd_mhp_caret"/>
            </div>

            <!-- Dropdown menu — chỉ chứa options (search input đã chuyển lên bar) -->
            <div class="o_vd_mhp_menu" t-if="state.open"
                 t-on-mousedown="onMenuMouseDown">
                <t t-if="state.options.length === 0">
                    <div class="o_vd_mhp_empty">
                        <i class="fa fa-info-circle"/>
                        <t t-if="props.name === 'vd_intake_district'">
                            <t t-if="!fetchDomain">Chọn Tỉnh/Thành trước.</t>
                            <t t-else="">Chưa có dữ liệu Xã/Phường cho tỉnh này.</t>
                        </t>
                        <t t-else="">Không có lựa chọn nào.</t>
                    </div>
                </t>
                <t t-elif="filteredOptions.length === 0">
                    <div class="o_vd_mhp_empty">
                        <i class="fa fa-search"/>
                        Không khớp "<t t-esc="state.search"/>"
                    </div>
                </t>
                <t t-else="">
                    <t t-foreach="filteredOptions" t-as="opt" t-key="opt.id">
                        <button type="button" class="o_vd_mhp_item"
                                t-att-data-rec-id="opt.id"
                                t-att-data-rec-name="opt.display_name or opt.name">
                            <t t-esc="opt.display_name or opt.name"/>
                        </button>
                    </t>
                </t>
            </div>
        </div>
    </t>

</templates>
