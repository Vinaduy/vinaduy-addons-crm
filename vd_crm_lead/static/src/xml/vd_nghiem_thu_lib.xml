<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- 3 nút nổi THƯ VIỆN tài liệu (đặt dưới nút Mẫu nhà) -->
    <t t-name="vd_crm_lead.DriveLibsButton">
        <t t-if="!hidden">
            <t t-foreach="libs" t-as="lib" t-key="lib.key">
                <button t-attf-class="o_vd_lib_filter {{lib.cls}}"
                        t-on-click="() => this.open(lib)" t-att-title="lib.title">
                    <span class="o_vd_lib_ico"><i t-attf-class="fa {{lib.icon}}"/></span>
                    <span class="o_vd_lib_txt"><t t-esc="lib.title"/></span>
                </button>
            </t>
        </t>
    </t>

    <!-- Popup: lưới PHẲNG toàn bộ file (mỗi file 1 thẻ: tên + Tải cùng dòng) -->
    <t t-name="vd_crm_lead.DriveLibDialog">
        <Dialog title="props.libTitle" size="'xl'" contentClass="'o_vd_nt_modal'">
            <div class="o_vd_nt_wrap">
                <div t-if="state.loading" class="o_vd_nt_center">
                    <i class="fa fa-spinner fa-spin me-1"/>Đang tải danh sách…
                </div>
                <div t-elif="state.error" class="o_vd_nt_err">
                    <i class="fa fa-exclamation-triangle me-1"/><t t-esc="state.error"/>
                </div>
                <div t-elif="!allFiles.length" class="o_vd_nt_center">Chưa có tài liệu.</div>
                <t t-else="">
                    <t t-foreach="state.groups" t-as="g" t-key="g_index">
                        <div t-if="g.files.length" class="o_vd_nt_group">
                            <div class="o_vd_nt_grouphead">
                                <i class="fa fa-folder-open me-1"/><t t-esc="g.name"/>
                                <span class="o_vd_nt_gcount">(<t t-esc="g.files.length"/>)</span>
                            </div>
                            <div class="o_vd_nt_grid">
                                <t t-foreach="g.files" t-as="f" t-key="f.id">
                                    <!-- VIDEO/ẢNH: thẻ có ảnh xem trước -->
                                    <div t-if="hasThumb(f)" class="o_vd_dl_card">
                                        <div class="o_vd_dl_thumb" t-on-click="() => this.openFile(f.id)">
                                            <i t-attf-class="fa {{fileIcon(f)}} o_vd_dl_fallico"/>
                                            <img t-att-src="thumb(f.id)" loading="lazy"/>
                                        </div>
                                        <div class="o_vd_dl_foot">
                                            <span class="o_vd_dl_name" t-att-title="f.name"><t t-esc="displayName(f.name)"/></span>
                                            <a class="o_vd_dl_btn" t-att-href="dlUrl(f.id)"><i class="fa fa-download"/> Tải</a>
                                        </div>
                                    </div>
                                    <!-- TÀI LIỆU: thẻ NHỎ ngang; bấm tên = mở xem; nút chính = Tạo bản sao -->
                                    <div t-else="" class="o_vd_dl_doc">
                                        <i t-attf-class="fa {{fileIcon(f)}} o_vd_dl_docmini"/>
                                        <span class="o_vd_dl_docname" t-att-title="f.name"
                                              t-on-click="() => this.openFile(f.id)"><t t-esc="displayName(f.name)"/></span>
                                        <a t-if="canCopy(f)" class="o_vd_dl_copybtn"
                                           t-att-href="copyUrl(f)" target="_blank"
                                           title="Tạo bản sao để điền (cần đăng nhập Google)">
                                            <i class="fa fa-copy me-1"/>Tạo bản sao
                                        </a>
                                        <a t-else="" class="o_vd_dl_dlmini" t-att-href="dlUrl(f.id)"
                                           title="Tải về máy"><i class="fa fa-download"/></a>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>
                </t>
            </div>
            <!-- Bỏ chân popup + 2 nút (user 2026-07-18): footer slot RỖNG để không
                 hiện nút mặc định; SCSS ẩn hẳn .modal-footer của dialog này. Đóng
                 bằng nút ✕ góc phải. -->
            <t t-set-slot="footer"></t>
        </Dialog>
    </t>

</templates>
