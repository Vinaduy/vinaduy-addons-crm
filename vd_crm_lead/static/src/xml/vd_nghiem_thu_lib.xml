<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- 3 nút nổi THƯ VIỆN tài liệu (đặt dưới nút Mẫu nhà) -->
    <t t-name="vd_crm_lead.DriveLibsButton">
        <t t-if="!hidden">
            <t t-foreach="libs" t-as="lib" t-key="lib.key">
                <button t-attf-class="o_vd_lib_filter {{lib.cls}}"
                        t-on-click="() => this.open(lib)" t-att-title="lib.title">
                    <span class="o_vd_lib_ico"><i t-attf-class="fa {{lib.icon}}"/></span>
                    <span class="o_vd_lib_txt"><t t-esc="lib.title"/></span>
                </button>
            </t>
        </t>
    </t>

    <!-- Popup: lưới PHẲNG toàn bộ file (mỗi file 1 thẻ: tên + Tải cùng dòng) -->
    <t t-name="vd_crm_lead.DriveLibDialog">
        <Dialog title="props.libTitle" size="'xl'" contentClass="'o_vd_nt_modal'">
            <div class="o_vd_nt_wrap">
                <div t-if="state.loading" class="o_vd_nt_center">
                    <i class="fa fa-spinner fa-spin me-1"/>Đang tải danh sách…
                </div>
                <div t-elif="state.error" class="o_vd_nt_err">
                    <i class="fa fa-exclamation-triangle me-1"/><t t-esc="state.error"/>
                </div>
                <div t-elif="!state.files.length" class="o_vd_nt_center">Chưa có tài liệu.</div>
                <div t-else="" class="o_vd_nt_grid">
                    <div t-foreach="state.files" t-as="f" t-key="f.id" class="o_vd_dl_card">
                        <div class="o_vd_dl_thumb">
                            <t t-if="hasThumb(f)">
                                <i t-attf-class="fa {{fileIcon(f)}} o_vd_dl_fallico"/>
                                <img t-att-src="thumb(f.id)" loading="lazy"/>
                            </t>
                            <i t-else="" t-attf-class="fa {{fileIcon(f)}} o_vd_dl_docico"/>
                        </div>
                        <div class="o_vd_dl_foot">
                            <span class="o_vd_dl_name" t-att-title="f.name"><t t-esc="f.name"/></span>
                            <a class="o_vd_dl_btn" t-att-href="dlUrl(f.id)">
                                <i class="fa fa-download"/> Tải
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-success o_vd_nt_dlall"
                        t-att-disabled="state.files.length ? undefined : 'disabled'"
                        t-on-click="() => this.downloadAll()">
                    <i class="fa fa-download me-1"/>Tải tất cả (<t t-esc="state.files.length"/>)
                </button>
                <button class="btn btn-secondary" t-on-click="() => this.props.close()">Đóng</button>
            </t>
        </Dialog>
    </t>

</templates>
