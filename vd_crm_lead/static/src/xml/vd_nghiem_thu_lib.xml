<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- 3 nút nổi THƯ VIỆN tài liệu (đặt dưới nút Mẫu nhà) -->
    <t t-name="vd_crm_lead.DriveLibsButton">
        <t t-if="!hidden">
            <t t-foreach="libs" t-as="lib" t-key="lib.key">
                <button t-attf-class="o_vd_lib_filter {{lib.cls}}"
                        t-on-click="() => this.open(lib)" t-att-title="lib.title">
                    <span class="o_vd_lib_ico"><i t-attf-class="fa {{lib.icon}}"/></span>
                    <span class="o_vd_lib_txt"><t t-esc="lib.title"/></span>
                </button>
            </t>
        </t>
    </t>

    <!-- Popup: duyệt thư mục Drive (breadcrumb + folder + file có nút TẢI) -->
    <t t-name="vd_crm_lead.DriveLibDialog">
        <Dialog title="props.libTitle" size="'xl'" contentClass="'o_vd_nt_modal'">
            <div class="o_vd_nt_wrap">
                <!-- Breadcrumb -->
                <div class="o_vd_nt_crumbs">
                    <button class="o_vd_nt_crumb" t-on-click="() => this.goRoot()">
                        <i class="fa fa-home me-1"/><t t-esc="props.libTitle.replace('THƯ VIỆN - ','')"/>
                    </button>
                    <t t-foreach="state.stack" t-as="c" t-key="c_index">
                        <span class="o_vd_nt_crumb_sep">/</span>
                        <button class="o_vd_nt_crumb" t-on-click="() => this.goCrumb(c_index)">
                            <t t-esc="c.name"/>
                        </button>
                    </t>
                </div>

                <div t-if="state.loading" class="o_vd_nt_center">
                    <i class="fa fa-spinner fa-spin me-1"/>Đang tải…
                </div>
                <div t-elif="state.error" class="o_vd_nt_err">
                    <i class="fa fa-exclamation-triangle me-1"/><t t-esc="state.error"/>
                </div>
                <t t-else="">
                    <div t-if="!state.folders.length &amp;&amp; !state.files.length" class="o_vd_nt_center">
                        Thư mục này trống.
                    </div>
                    <div class="o_vd_nt_grid">
                        <!-- Thư mục con -->
                        <div t-foreach="state.folders" t-as="fo" t-key="fo.id"
                             class="o_vd_dl_card o_vd_dl_folder" t-on-click="() => this.openFolder(fo)">
                            <div class="o_vd_dl_thumb o_vd_dl_folderico">
                                <i class="fa fa-folder"/>
                            </div>
                            <div class="o_vd_dl_name" t-att-title="fo.name"><t t-esc="fo.name"/></div>
                            <span class="o_vd_dl_btn o_vd_dl_open"><i class="fa fa-folder-open"/> Mở</span>
                        </div>
                        <!-- File -->
                        <div t-foreach="state.files" t-as="f" t-key="f.id" class="o_vd_dl_card">
                            <div class="o_vd_dl_thumb">
                                <i class="fa fa-file-video-o o_vd_dl_fallico"/>
                                <img t-att-src="thumb(f.id)" loading="lazy"/>
                            </div>
                            <div class="o_vd_dl_name" t-att-title="f.name"><t t-esc="f.name"/></div>
                            <a class="o_vd_dl_btn" t-att-href="dlUrl(f.id)">
                                <i class="fa fa-download"/> Tải
                            </a>
                        </div>
                    </div>
                </t>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-success o_vd_nt_dlall"
                        t-att-disabled="state.files.length ? undefined : 'disabled'"
                        t-on-click="() => this.downloadAll()">
                    <i class="fa fa-download me-1"/>Tải tất cả file (<t t-esc="state.files.length"/>)
                </button>
                <button class="btn btn-secondary" t-on-click="() => this.props.close()">Đóng</button>
            </t>
        </Dialog>
    </t>

</templates>
