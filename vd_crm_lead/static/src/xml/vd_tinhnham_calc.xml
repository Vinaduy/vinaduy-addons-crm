<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="vd_crm_lead.VdTinhnhamCalc">
        <div class="o_vd_tncalc">
            <div class="o_vd_tncalc_head">
                <i class="fa fa-calculator me-1"/>BẢNG BÁO GIÁ TÍNH NHẨM
                <span class="o_vd_tncalc_hint">Tổng ≈ Hệ số × Diện tích × Đơn giá</span>
            </div>

            <t t-if="!state.loaded">
                <div class="o_vd_tncalc_loading"><i class="fa fa-spinner fa-spin me-1"/>Đang tải...</div>
            </t>
            <t t-else="">
                <div class="o_vd_tncalc_row">
                    <span class="o_vd_tncalc_lbl">Miền</span>
                    <div class="o_vd_tncalc_btns">
                        <t t-foreach="REGIONS" t-as="r" t-key="r.key">
                            <button t-attf-class="o_vd_tncalc_chip {{state.region === r.key ? 'active' : ''}}"
                                    t-on-click="() => this.setRegion(r.key)"><t t-esc="r.label"/></button>
                        </t>
                    </div>
                </div>

                <div class="o_vd_tncalc_row">
                    <span class="o_vd_tncalc_lbl">Kiểu nhà</span>
                    <div class="o_vd_tncalc_btns">
                        <t t-foreach="COMBOS" t-as="c" t-key="c.key">
                            <button t-attf-class="o_vd_tncalc_chip {{state.combo === c.key ? 'active' : ''}}"
                                    t-on-click="() => this.setCombo(c.key)"><t t-esc="c.label"/></button>
                        </t>
                    </div>
                </div>

                <div class="o_vd_tncalc_row">
                    <span class="o_vd_tncalc_lbl">Loại móng</span>
                    <div class="o_vd_tncalc_btns">
                        <t t-foreach="FOUNDS" t-as="f" t-key="f.key">
                            <button t-attf-class="o_vd_tncalc_chip {{state.found === f.key ? 'active' : ''}}"
                                    t-on-click="() => this.setFound(f.key)"><t t-esc="f.label"/></button>
                        </t>
                    </div>
                </div>

                <div class="o_vd_tncalc_inputs">
                    <label class="o_vd_tncalc_in">
                        <span>Diện tích sàn T1 (m²)</span>
                        <input type="number" min="0" t-att-value="state.area" t-on-input="onArea"/>
                    </label>
                    <label class="o_vd_tncalc_in">
                        <span>Đơn giá (triệu/m²)</span>
                        <input type="number" min="0" step="0.1" placeholder="VD: 5.8"
                               t-att-value="state.donGia" t-on-input="onDonGia"/>
                    </label>
                    <label class="o_vd_tncalc_small">
                        <input type="checkbox" t-att-checked="state.small" t-on-change="toggleSmall"/>
                        <span>DT &lt; 70m² (+<t t-esc="(notes and notes.small_pct) or 0"/>%)</span>
                    </label>
                </div>

                <div class="o_vd_tncalc_result">
                    <div class="o_vd_tncalc_res_line">
                        <span>Hệ số</span><b t-esc="coefLabel"/>
                    </div>
                    <div class="o_vd_tncalc_res_line">
                        <span>m² tính tiền</span><b t-esc="chargeableLabel"/>
                    </div>
                    <div class="o_vd_tncalc_total">
                        <span>TẠM TÍNH</span>
                        <b><t t-esc="totalTrieuLabel"/> triệu</b>
                        <span class="o_vd_tncalc_ty">≈ <t t-esc="totalTyLabel"/> tỷ</span>
                    </div>
                </div>

                <div t-if="notes" class="o_vd_tncalc_notes">
                    <div class="o_vd_tncalc_notes_h"><i class="fa fa-info-circle me-1"/>Phát sinh (không có trong HĐ)</div>
                    <ul>
                        <li>Gác lửng: bớt <t t-esc="notes.lung[0]"/>-<t t-esc="notes.lung[1]"/> triệu</li>
                        <li>Có tum: thêm <t t-esc="notes.tum[0]"/>-<t t-esc="notes.tum[1]"/> triệu</li>
                        <li>Ép cọc: <t t-esc="notes.epcoc[0]"/>-<t t-esc="notes.epcoc[1]"/> triệu</li>
                        <li>Nội thất: <t t-esc="notes.noithat[0]"/>-<t t-esc="notes.noithat[1]"/> triệu</li>
                        <li>Cấp phép: <t t-esc="notes.capphep[0]"/>-<t t-esc="notes.capphep[1]"/> triệu</li>
                    </ul>
                </div>
            </t>
        </div>
    </t>

</templates>
