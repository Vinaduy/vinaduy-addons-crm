<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="vd_crm_lead.VdTinhnhamCalc">
        <div class="o_vd_tncalc">
            <button class="o_vd_tncalc_trigger" type="button">
                <i class="fa fa-table me-1"/>BẢNG BÁO GIÁ
                <i class="fa fa-angle-down ms-1 o_vd_tncalc_caret"/>
            </button>

            <div class="o_vd_tncalc_drop">
            <div class="o_vd_tncalc_box">
            <div class="o_vd_tncalc_tabs">
                <t t-foreach="REGIONS" t-as="r" t-key="r.key">
                    <button t-attf-class="o_vd_tncalc_tab {{state.region === r.key ? 'active' : ''}}"
                            t-on-mouseenter="() => this.setRegion(r.key)"
                            t-on-click="() => this.setRegion(r.key)">MIỀN <t t-esc="r.label"/></button>
                </t>
            </div>

            <table class="o_vd_tncalc_table">
                <colgroup>
                    <col class="o_vd_col_lbl"/>
                    <col/><col/><col/><col/><col/>
                </colgroup>
                <tbody>
                    <!-- ===== MÓNG ===== -->
                    <tr class="o_vd_sec">
                        <td class="o_vd_sec_lbl">MÓNG</td>
                        <td colspan="3">TRÊN 70m²</td>
                        <td colspan="2">DƯỚI 70m²</td>
                    </tr>
                    <t t-foreach="mong.rows" t-as="m" t-key="m.name">
                        <tr>
                            <td class="o_vd_rh"><t t-esc="m.name"/></td>
                            <td colspan="3"><t t-esc="m.over"/></td>
                            <td colspan="2"><t t-esc="m.under"/></td>
                        </tr>
                    </t>

                    <!-- ===== SÀN ===== -->
                    <tr class="o_vd_sec">
                        <td class="o_vd_sec_lbl">SÀN (đ/m²)</td>
                        <t t-foreach="SAN_COLS" t-as="c" t-key="c"><td><t t-esc="c"/></td></t>
                    </tr>
                    <t t-foreach="SAN_ROWS" t-as="s" t-key="s.name">
                        <tr>
                            <td class="o_vd_rh"><t t-esc="s.name"/></td>
                            <t t-foreach="s.vals" t-as="v" t-key="v_index"><td><t t-esc="v"/></td></t>
                        </tr>
                    </t>
                    <tr>
                        <td class="o_vd_rh">Xây thô trọn gói</td>
                        <td colspan="3"><t t-esc="SAN_THO.over"/></td>
                        <td colspan="2"><t t-esc="SAN_THO.under"/></td>
                    </tr>
                    <tr>
                        <td colspan="6" class="o_vd_ly"><b>Lưu ý:</b> <t t-esc="MONG_LUU_Y"/></td>
                    </tr>

                    <!-- ===== MÁI ===== -->
                    <tr class="o_vd_sec">
                        <td class="o_vd_sec_lbl">MÁI</td>
                        <td colspan="5">Công thức tính (DT = diện tích sàn)</td>
                    </tr>
                    <t t-foreach="MAI" t-as="m" t-key="m.name">
                        <tr>
                            <td class="o_vd_rh"><t t-esc="m.name"/></td>
                            <t t-if="m.val">
                                <td colspan="5" class="o_vd_left"><t t-esc="m.val"/></td>
                            </t>
                            <t t-else="">
                                <td colspan="3" class="o_vd_left"><t t-esc="m.left"/></td>
                                <td colspan="2" class="o_vd_left"><t t-esc="m.right"/></td>
                            </t>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div class="o_vd_tncalc_note"><i class="fa fa-info-circle me-1"/><t t-esc="mong.note"/></div>
            </div><!-- /.o_vd_tncalc_box -->
            </div><!-- /.o_vd_tncalc_drop -->
        </div>
    </t>

</templates>
