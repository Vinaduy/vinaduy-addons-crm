<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="vd_crm_lead.VdTinhnhamCalc">
        <div class="o_vd_tncalc">
            <div class="o_vd_tncalc_head">
                <i class="fa fa-table me-1"/>BẢNG BÁO GIÁ XÂY DỰNG
                <span class="o_vd_tncalc_hint">Đưa chuột vào miền để xem bảng báo giá</span>
            </div>

            <div class="o_vd_tncalc_tabs">
                <t t-foreach="REGIONS" t-as="r" t-key="r.key">
                    <button t-attf-class="o_vd_tncalc_tab {{state.region === r.key ? 'active' : ''}}"
                            t-on-mouseenter="() => this.setRegion(r.key)"
                            t-on-click="() => this.setRegion(r.key)">MIỀN <t t-esc="r.label"/></button>
                </t>
            </div>

            <!-- ===== MÓNG ===== -->
            <div class="o_vd_tncalc_sec">MÓNG</div>
            <table class="o_vd_tncalc_table">
                <thead>
                    <tr>
                        <th>Loại móng</th>
                        <th>Trên 70m²</th>
                        <th>Dưới 70m²</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="mong.rows" t-as="m" t-key="m.name">
                        <tr>
                            <td class="o_vd_tncalc_rh"><t t-esc="m.name"/></td>
                            <td><t t-esc="m.over"/></td>
                            <td><t t-esc="m.under"/></td>
                        </tr>
                    </t>
                </tbody>
            </table>
            <div class="o_vd_tncalc_ly"><b>Lưu ý:</b> <t t-esc="MONG_LUU_Y"/></div>

            <!-- ===== SÀN ===== -->
            <div class="o_vd_tncalc_sec">SÀN - ĐƠN GIÁ XÂY THÔ (đ/m²)</div>
            <div class="o_vd_tncalc_tablewrap">
                <table class="o_vd_tncalc_table">
                    <thead>
                        <tr>
                            <th>Diện tích sàn</th>
                            <t t-foreach="SAN_COLS" t-as="c" t-key="c"><th><t t-esc="c"/></th></t>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="SAN_ROWS" t-as="s" t-key="s.name">
                            <tr>
                                <td class="o_vd_tncalc_rh"><t t-esc="s.name"/></td>
                                <t t-foreach="s.vals" t-as="v" t-key="v_index"><td><t t-esc="v"/></td></t>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
            <table class="o_vd_tncalc_table o_vd_tncalc_mt">
                <thead>
                    <tr><th colspan="2">Xây thô trọn gói</th></tr>
                </thead>
                <tbody>
                    <t t-foreach="SAN_THO" t-as="t" t-key="t.name">
                        <tr>
                            <td class="o_vd_tncalc_rh"><t t-esc="t.name"/></td>
                            <td><t t-esc="t.val"/></td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <!-- ===== MÁI ===== -->
            <div class="o_vd_tncalc_sec">MÁI</div>
            <table class="o_vd_tncalc_table">
                <tbody>
                    <t t-foreach="MAI" t-as="m" t-key="m.name">
                        <tr>
                            <td class="o_vd_tncalc_rh"><t t-esc="m.name"/></td>
                            <td class="o_vd_tncalc_left"><t t-esc="m.val"/></td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <!-- ===== PHÁT SINH ===== -->
            <div class="o_vd_tncalc_sec">BẢNG GIÁ PHÁT SINH (nhà 100m²)</div>
            <table class="o_vd_tncalc_table">
                <tbody>
                    <t t-foreach="PHAT_SINH" t-as="p" t-key="p.name">
                        <tr>
                            <td class="o_vd_tncalc_rh o_vd_tncalc_left"><t t-esc="p.name"/></td>
                            <td><t t-esc="p.val"/></td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div class="o_vd_tncalc_note"><i class="fa fa-info-circle me-1"/><t t-esc="mong.note"/></div>
        </div>
    </t>

</templates>
