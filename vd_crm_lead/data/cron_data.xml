<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <!-- Cron wipe intake — DISABLED (user spec 2026-05-27): data persist mãi mãi.
             NV chưa CHỐT thì KH vẫn ở "Khách mới"; data không bị xoá khi reload/close. -->
        <record id="ir_cron_vd_wipe_unsaved_intake" model="ir.cron">
            <field name="name">VD CRM: Wipe intake chưa CHỐT (DISABLED)</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">pass  # disabled per user spec — data persists</field>
            <field name="active" eval="False"/>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- Yêu cầu tìm vấn đề: đánh giá vi phạm + áp/gỡ khoá (user spec 2026-06-01).
             Chạy hằng ngày — đếm số ngày NV vượt ngưỡng, quá hạn gia hạn thì khoá. -->
        <record id="ir_cron_vd_problem_find_lock" model="ir.cron">
            <field name="name">VD CRM: Đánh giá khoá "Yêu cầu tìm vấn đề"</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._vd_cron_eval_problem_find_lock()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- CALL-WATCH (user spec 2026-06-04): chạy 15h VN mỗi ngày làm việc, cảnh
             báo KH mới chưa gọi + khoá bảng Khách mới nếu hôm trước chưa gọi hết.
             nextcall lưu theo UTC: 08:00 UTC = 15:00 VN. Cron tự bỏ qua ngày nghỉ. -->
        <record id="ir_cron_vd_call_watch_lock" model="ir.cron">
            <field name="name">VD CRM: Cảnh báo/khoá NV chưa gọi Khách mới (15h)</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._vd_cron_eval_call_lock()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall">2026-06-05 08:00:00</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- HẠN XỬ LÝ VẤN ĐỀ (user spec 2026-06-06): hằng ngày báo trưởng phòng
             các vấn đề KH đã quá hạn xử lý mà chưa giải quyết. 07:00 UTC = 14h VN. -->
        <record id="ir_cron_vd_notify_overdue_problems" model="ir.cron">
            <field name="name">VD CRM: Báo trưởng phòng vấn đề KH quá hạn xử lý</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._vd_cron_notify_overdue_problems()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall">2026-06-07 07:00:00</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- QUÉT BÌNH LUẬN FACEBOOK (user spec 2026-06-13): Dev mode KHÔNG đẩy
             webhook feed → Odoo tự gọi Graph API quét comment mới mỗi 2 phút.
             Khi app lên Live + đã subscribe feed thì webhook chạy song song (dedup). -->
        <record id="ir_cron_vd_fb_pull_comments" model="ir.cron">
            <field name="name">VD CRM: Quét bình luận Facebook (poll)</field>
            <field name="model_id" ref="model_vd_fb_page"/>
            <field name="state">code</field>
            <field name="code">model._cron_pull_comments()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- ĐỒNG BỘ KHÁCH BOTCAKE — TẮT (user spec 2026-07-06): Botcake API trả về
             TOÀN BỘ kho khách (không có ngày), phân trang `page` kéo cả nghìn khách
             CŨ mỗi lần chạy → tạo lead loạn + ngập worklist NV + phồng báo cáo.
             Webhook phone_info thời gian thực mới là nguồn CHÍNH. Tắt cron này. -->
        <record id="ir_cron_vd_botcake_sync" model="ir.cron">
            <field name="name">VD CRM: Đồng bộ khách Botcake (kéo SĐT)</field>
            <field name="model_id" ref="model_vd_pancake_page"/>
            <field name="state">code</field>
            <field name="code">model._cron_sync_botcake(since_days=2)</field>
            <field name="active" eval="False"/>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- KÉO SĐT PANCAKE tự nhận diện (user spec 2026-07-06): từ ~04/07 webhook
             bắn phone_info=[] rồi Pancake mới nhận diện số SAU (async) → số không
             kịp vào webhook. API conversations vẫn có recent_phone_numbers → cron
             15' kéo về tạo lead cho số CHƯA có. BÙ cho fallback bóc-số-từ-tin
             (real-time). KHÔNG đụng last_event_at nên banner DỪNG CHIA SỐ vẫn đúng. -->
        <record id="ir_cron_vd_pancake_phone_sync" model="ir.cron">
            <field name="name">VD CRM: Kéo SĐT Pancake (recent_phone_numbers)</field>
            <field name="model_id" ref="model_vd_pancake_page"/>
            <field name="state">code</field>
            <field name="code">model._cron_sync_pancake_phones(days=1)</field>
            <field name="active" eval="True"/>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- GỘP LEAD TRÙNG SĐT (user spec 2026-06-22): 1 số KH = 1 NV quản lý.
             Chạy mỗi 2 giờ, gộp lead active trùng số (chưa won/lost) vào keeper
             (lead nhiều cuộc gọi nhất, hoà thì first-touch). -->
        <record id="ir_cron_vd_merge_dup_phones" model="ir.cron">
            <field name="name">VD CRM: Gộp lead trùng số điện thoại</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">model._vd_cron_merge_dup_phones()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">2</field>
            <field name="interval_type">hours</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- BẢO MẬT: ép đổi mật khẩu sau 30 ngày (user spec 2026-06-18).
             Chạy hằng ngày, đánh dấu vd_pwd_must_change cho NV quá hạn. -->
        <record id="ir_cron_vd_password_expiry" model="ir.cron">
            <field name="name">VD CRM: Ép đổi mật khẩu chu kỳ 30 ngày</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="state">code</field>
            <field name="code">model._vd_cron_password_expiry()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- Seed cấu hình HẠN XỬ LÝ (admin chỉnh sau qua menu Cài đặt) -->
        <function model="ir.config_parameter" name="set_param" eval="('vd_crm_lead.problem_deadline_days', '7')"/>
        <function model="ir.config_parameter" name="set_param" eval="('vd_crm_lead.problem_extension_days', '7')"/>
        <function model="ir.config_parameter" name="set_param" eval="('vd_crm_lead.problem_extension_max', '3')"/>

        <!-- Seed cấu hình CALL-WATCH (admin chỉnh sau qua Tham số hệ thống) -->
        <function model="ir.config_parameter" name="set_param" eval="('vd_crm_lead.callwatch_enabled', '1')"/>
        <function model="ir.config_parameter" name="set_param" eval="('vd_crm_lead.callwatch_min_seconds', '5')"/>
        <function model="ir.config_parameter" name="set_param" eval="('vd_crm_lead.callwatch_window_workdays', '7')"/>
        <function model="ir.config_parameter" name="set_param" eval="('vd_crm_lead.callwatch_required_days', '3')"/>
        <function model="ir.config_parameter" name="set_param" eval="('vd_crm_lead.callwatch_lock_all', '1')"/>
        <!-- Ngày lễ VN 2026 (admin tự cập nhật hằng năm). Bỏ khỏi đếm ngày làm việc. -->
        <function model="ir.config_parameter" name="set_param"
                  eval="('vd_crm_lead.holidays', '2026-01-01,2026-02-15,2026-02-16,2026-02-17,2026-02-18,2026-02-19,2026-02-20,2026-02-21,2026-04-26,2026-04-30,2026-05-01,2026-09-02')"/>

        <!-- BOOTSTRAP 1 LẦN: ép đăng xuất toàn bộ NV + buộc đổi mật khẩu (user spec
             2026-06-18). Guard bằng param security_bootstrap_v1 nên chỉ chạy 1 lần. -->
        <function model="res.users" name="_vd_security_bootstrap"/>
    </data>
</odoo>
