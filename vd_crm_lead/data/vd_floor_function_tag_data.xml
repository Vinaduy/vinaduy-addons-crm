<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate=0 → mỗi lần upgrade module sẽ refresh records theo file này. -->
    <data noupdate="0">

        <!-- ============================================================
             DELETE old tags (set from before 2026-05-26 redesign).
             User chốt lại danh sách công năng theo COUNT (1 Khách, 2 Ngủ...).
             ============================================================ -->

        <!-- ============================================================
             NEW TAG SET (2026-05-26):
             - T1   : 1 Khách, 1 Bếp, 1 Ngủ, 2 Ngủ, 1 Wc, 2 Wc, 1 Thờ,
                       Cầu thang máy, Gara oto, Kho
             - T2..7: 1 Ngủ, 2 Ngủ, 3 Ngủ, 4 Ngủ, 5 Ngủ,
                       1 Wc, 2 Wc, 3 Wc, 1 Thờ, Kho
             - Tum  : 1 Thờ, 1 Ngủ
             ============================================================ -->

        <!-- ===== Khách + Bếp: TÁCH RIÊNG (user spec 2026-06-26), có cả T1 + T2 ===== -->
        <!-- Tag gộp cũ: ẩn khỏi picker (fit_floors=none) nhưng GIỮ record cho báo giá cũ. -->
        <record id="tag_1_khach_1_bep" model="vd.floor.function.tag">
            <field name="name">🛋️🍳 1 Khách 1 Bếp</field>
            <field name="sequence">10</field>
            <field name="color">4</field>
            <field name="fit_floors">none</field>
        </record>
        <record id="tag_1_bep" model="vd.floor.function.tag">
            <field name="name">🍳 1 Bếp</field>
            <field name="sequence">11</field>
            <field name="color">4</field>
            <field name="fit_floors">f1,f2,lung</field>
        </record>

        <!-- ===== Ngủ (count) ===== -->
        <record id="tag_1_ngu" model="vd.floor.function.tag">
            <field name="name">🛏️ 1 Ngủ</field>
            <field name="sequence">20</field>
            <field name="color">1</field>
            <field name="fit_floors">f1,f2,f3,f4,f5,f6,f7,tum,lung</field>
