<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="stage_new" model="vd.crm.stage">
            <field name="name">Khách mới</field>
            <field name="code">new</field>
            <field name="sequence">10</field>
            <field name="default_probability">5</field>
            <field name="color">1</field>
        </record>

        <record id="stage_potential" model="vd.crm.stage">
            <field name="name">Khách có tiềm năng</field>
            <field name="code">potential</field>
            <field name="sequence">20</field>
            <field name="default_probability">20</field>
            <field name="color">2</field>
        </record>

        <record id="stage_callback" model="vd.crm.stage">
            <field name="name">Hẹn ngày gọi lại</field>
            <field name="code">callback</field>
            <field name="sequence">30</field>
            <field name="default_probability">30</field>
            <field name="color">3</field>
        </record>

        <record id="stage_quote" model="vd.crm.stage">
            <field name="name">Khách báo giá</field>
            <field name="code">quote</field>
            <field name="sequence">40</field>
            <field name="default_probability">50</field>
            <field name="color">4</field>
        </record>

        <record id="stage_negotiate" model="vd.crm.stage">
            <field name="name">Khách đàm phán</field>
            <field name="code">negotiate</field>
            <field name="sequence">50</field>
            <field name="default_probability">75</field>
            <field name="color">5</field>
        </record>

        <record id="stage_won" model="vd.crm.stage">
            <field name="name">Khách chốt</field>
            <field name="code">won</field>
            <field name="sequence">60</field>
            <field name="default_probability">100</field>
            <field name="is_won" eval="True"/>
            <field name="color">10</field>
        </record>

        <record id="stage_lost" model="vd.crm.stage">
            <field name="name">Khách huỷ</field>
            <field name="code">lost</field>
            <field name="sequence">70</field>
            <field name="default_probability">0</field>
            <field name="is_lost" eval="True"/>
            <field name="fold" eval="True"/>
            <field name="color">9</field>
        </record>

    </data>
</odoo>
