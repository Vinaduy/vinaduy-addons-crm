<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============ RECORD RULES cho crm.lead ============
         Logic: rules cùng model + group khác = OR (record visible nếu match BẤT KỲ rule nào).
         Vì group hierarchy implied → user cấp cao auto thoả nhiều rule → thấy nhiều hơn.
         - NV: rule own → chỉ KH user_id = mình
         - Trưởng nhóm: rule own + rule team → KH của team
         - Phó GĐ: rule own + rule team + rule all → tất cả KH
         - Admin: thừa hưởng Phó GĐ + group_system → tất cả
         CHÍNH SÁCH XOÁ: chỉ Admin được xoá lead → mọi rule đặt perm_unlink=False.
         Admin có base.group_system nên bypass toàn bộ ir.rule → vẫn xoá được. -->

    <record id="vd_crm_rule_lead_own" model="ir.rule">
        <field name="name">VD CRM: NV chỉ thấy KH của mình</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('vd_crm_group_employee'))]"/>
        <field name="perm_read">True</field>
        <field name="perm_write">True</field>
        <field name="perm_create">True</field>
        <field name="perm_unlink">False</field>
    </record>

    <record id="vd_crm_rule_lead_team" model="ir.rule">
        <field name="name">VD CRM: Trưởng nhóm thấy KH của phòng ban mình</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <!-- User spec 2026-06-14: "nhóm" = PHÒNG BAN (res.users.vd_team), KHÔNG
             dùng crm.team. Trưởng nhóm thấy KH của mình + KH của NV CÙNG vd_team.
             Nếu vd_team của TN trống → chỉ thấy KH của mình (nhánh team rỗng). -->
        <field name="domain_force">['|', ('user_id', '=', user.id), '&amp;', ('user_id.vd_team', '!=', False), ('user_id.vd_team', '=', user.vd_team)]</field>
        <field name="groups" eval="[(4, ref('vd_crm_group_team_leader'))]"/>
        <field name="perm_read">True</field>
        <field name="perm_write">True</field>
        <field name="perm_create">True</field>
        <field name="perm_unlink">False</field>
    </record>

    <record id="vd_crm_rule_lead_all" model="ir.rule">
        <field name="name">VD CRM: Phó GĐ + Admin thấy tất cả KH</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('vd_crm_group_deputy_director'))]"/>
        <field name="perm_read">True</field>
        <field name="perm_write">True</field>
        <field name="perm_create">True</field>
        <field name="perm_unlink">False</field>
    </record>
</odoo>
